<?xml version="1.0" encoding="utf-8"?>
<Package xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10" xmlns:mp="http://schemas.microsoft.com/appx/2014/phone/manifest" xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10" IgnorableNamespaces="uap mp">
  <Identity Name="com.yanshuai.agent" Publisher="CN=LockWizard" Version="4.0.0.0" />
  <mp:PhoneIdentity PhoneProductId="f497554b-aafc-4bd0-bdb6-8d5230e1f556" PhonePublisherId="00000000-0000-0000-0000-000000000000" />
  <Properties>
    <DisplayName>言枢·智能体</DisplayName>
    <PublisherDisplayName>1b4e28ba-2fa1-5f3d-85e5-740e1a5a8a1f</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>
  <Dependencies>
    <TargetDeviceFamily Name="Windows.Universal" MinVersion="10.0.15063.0" MaxVersionTested="10.0.19041.0" />
  </Dependencies>
  <Resources>
    <Resource Language="x-generate" />
  </Resources>
  <Applications>
    <Application Id="App" Executable="$targetnametoken$.exe" EntryPoint="yanshuai.App">
      <uap:VisualElements DisplayName="言枢·智能体" Square150x150Logo="Assets\Logo.png" Square44x44Logo="Assets\SmallLogo.png" Description="言枢 AI 对话助手" BackgroundColor="transparent">
        <uap:DefaultTile Wide310x150Logo="Assets\WideLogo.png" Square71x71Logo="Assets\Square71x71Logo.png">
        </uap:DefaultTile>
        <uap:SplashScreen Image="Assets\SplashScreen.png" />
      </uap:VisualElements>
    </Application>
  </Applications>
  <Capabilities>
    <!-- 网络：API 调用、网页抓取、本地/局域网 MCP 与 SearXNG -->
    <Capability Name="internetClient" />
    <Capability Name="internetClientServer" />
    <Capability Name="privateNetworkClientServer" />
    <!-- 库 / 存储：list_files / read_file / read_image 经 KnownFolders 访问系统库与 SD 卡 -->
    <uap:Capability Name="removableStorage" />
    <uap:Capability Name="picturesLibrary" />
    <uap:Capability Name="musicLibrary" />
    <uap:Capability Name="videosLibrary" />
    <!-- 个人信息：calendar_* 工具需 appointments，contacts_search 需 contacts -->
    <uap:Capability Name="appointments" />
    <uap:Capability Name="contacts" />
    <!-- 注：make_call / send_sms 通过 tel:/sms: URI 启动系统应用，无需 phoneCall/sms 能力；
         media_control 使用 SystemMediaTransportControls，无需 microphone。
         已移除未被任何功能使用的能力：userAccountInformation, phoneCall, voipCall, chat,
         location, microphone, webcam, proximity, bluetooth, radios, wifiControl, activity, sms。 -->
  </Capabilities>
</Package>