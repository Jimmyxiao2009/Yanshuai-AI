<Page
    x:Class="yanshuai.DefaultAppearancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="14,16,14,8">
            <TextBlock Text="默认对话外观" FontSize="32" FontWeight="Light"/>
            <TextBlock Text="新建对话时使用这些默认外观设置" FontSize="12" Opacity="0.5" Margin="0,2,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ══ 背景 section ══ -->
                <StackPanel Margin="14,8,14,8">
                    <TextBlock Text="背景" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemAccentColor}" CharacterSpacing="80"/>
                    <Border BorderBrush="{ThemeResource SystemAccentColor}"
                            BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                </StackPanel>

                <TextBlock Text="背景类型" FontSize="13" Opacity="0.6" Margin="14,0,14,6"/>
                <ComboBox x:Name="BgTypePicker" HorizontalAlignment="Stretch"
                          Margin="14,0,14,16"
                          SelectionChanged="BgTypePicker_SelectionChanged">
                    <ComboBoxItem Content="默认（无背景）" Tag="none"/>
                    <ComboBoxItem Content="纯色" Tag="solid"/>
                </ComboBox>

                <!-- Solid color picker -->
                <StackPanel x:Name="SolidPanel" Visibility="Collapsed" Margin="0,0,0,8">
                    <Border x:Name="BgColorPreview"
                            Height="48" Margin="14,0,14,8"
                            BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="1">
                        <TextBlock x:Name="BgColorHexLabel"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="13" FontFamily="Consolas"/>
                    </Border>
                    <TextBox x:Name="BgHexBox"
                             PlaceholderText="#RRGGBB"
                             Margin="14,0,14,8"
                             TextChanged="BgHexBox_TextChanged"/>
                    <StackPanel Orientation="Horizontal" Margin="14,0,14,16">
                        <Button Tag="#000000" Click="BgPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF000000" BorderThickness="1"/>
                        <Button Tag="#1E1E1E" Click="BgPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF1E1E1E" BorderThickness="1"/>
                        <Button Tag="#1A1A2E" Click="BgPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF1A1A2E" BorderThickness="1"/>
                        <Button Tag="#2C3E50" Click="BgPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF2C3E50" BorderThickness="1"/>
                        <Button Tag="#F5F0E8" Click="BgPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FFF5F0E8" BorderThickness="1"/>
                        <Button Tag="#FFFFFF" Click="BgPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FFFFFFFF" BorderThickness="1"/>
                        <Button Tag="#0078D7" Click="BgPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF0078D7" BorderThickness="1"/>
                        <Button Tag="#C0392B" Click="BgPreset_Click" Width="36" Height="36" Margin="0,0,0,0" Padding="0" Background="#FFC0392B" BorderThickness="1"/>
                    </StackPanel>
                </StackPanel>

                <!-- ══ 气泡颜色 section ══ -->
                <StackPanel Margin="14,4,14,8">
                    <TextBlock Text="气泡颜色" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemAccentColor}" CharacterSpacing="80"/>
                    <Border BorderBrush="{ThemeResource SystemAccentColor}"
                            BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                </StackPanel>

                <!-- User bubble -->
                <Grid Margin="14,0,14,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="用户消息气泡" FontSize="13" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="清除" Click="ClearUserBubble_Click"
                            Padding="12,0" Height="34"/>
                </Grid>
                <Border x:Name="UserBubblePreview"
                        Height="36" Margin="14,0,14,6"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="UserBubbleHexLabel"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" FontFamily="Consolas" Text="（使用强调色）"/>
                </Border>
                <TextBox x:Name="UserHexBox"
                         PlaceholderText="#RRGGBB"
                         Margin="14,0,14,6"
                         TextChanged="UserHexBox_TextChanged"/>
                <StackPanel Orientation="Horizontal" Margin="14,0,14,16">
                    <Button Tag="#000000" Click="UserPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF000000" BorderThickness="1"/>
                    <Button Tag="#1E1E1E" Click="UserPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF1E1E1E" BorderThickness="1"/>
                    <Button Tag="#1A1A2E" Click="UserPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF1A1A2E" BorderThickness="1"/>
                    <Button Tag="#2C3E50" Click="UserPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF2C3E50" BorderThickness="1"/>
                    <Button Tag="#F5F0E8" Click="UserPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FFF5F0E8" BorderThickness="1"/>
                    <Button Tag="#FFFFFF" Click="UserPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FFFFFFFF" BorderThickness="1"/>
                    <Button Tag="#0078D7" Click="UserPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF0078D7" BorderThickness="1"/>
                    <Button Tag="#C0392B" Click="UserPreset_Click" Width="36" Height="36" Margin="0,0,0,0" Padding="0" Background="#FFC0392B" BorderThickness="1"/>
                </StackPanel>

                <!-- AI bubble -->
                <Grid Margin="14,0,14,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="AI 消息气泡" FontSize="13" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="清除" Click="ClearAiBubble_Click"
                            Padding="12,0" Height="34"/>
                </Grid>
                <Border x:Name="AiBubblePreview"
                        Height="36" Margin="14,0,14,6"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="AiBubbleHexLabel"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" FontFamily="Consolas" Text="（使用强调色暗色）"/>
                </Border>
                <TextBox x:Name="AiHexBox"
                         PlaceholderText="#RRGGBB"
                         Margin="14,0,14,6"
                         TextChanged="AiHexBox_TextChanged"/>
                <StackPanel Orientation="Horizontal" Margin="14,0,14,24">
                    <Button Tag="#000000" Click="AiPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF000000" BorderThickness="1"/>
                    <Button Tag="#1E1E1E" Click="AiPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF1E1E1E" BorderThickness="1"/>
                    <Button Tag="#1A1A2E" Click="AiPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF1A1A2E" BorderThickness="1"/>
                    <Button Tag="#2C3E50" Click="AiPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF2C3E50" BorderThickness="1"/>
                    <Button Tag="#F5F0E8" Click="AiPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FFF5F0E8" BorderThickness="1"/>
                    <Button Tag="#FFFFFF" Click="AiPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FFFFFFFF" BorderThickness="1"/>
                    <Button Tag="#0078D7" Click="AiPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF0078D7" BorderThickness="1"/>
                    <Button Tag="#C0392B" Click="AiPreset_Click" Width="36" Height="36" Margin="0,0,0,0" Padding="0" Background="#FFC0392B" BorderThickness="1"/>
                </StackPanel>

                <!-- ══ 引号 / 括号颜色 section ══ -->
                <StackPanel Margin="14,4,14,8">
                    <TextBlock Text="文本高亮颜色" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemAccentColor}" CharacterSpacing="80"/>
                    <Border BorderBrush="{ThemeResource SystemAccentColor}"
                            BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                </StackPanel>

                <!-- Quote color -->
                <TextBlock Text="引号颜色（「」&quot;&quot; 等）" FontSize="13" Opacity="0.7" Margin="14,0,14,4"/>
                <Border x:Name="QuoteColorPreview"
                        Height="36" Margin="14,0,14,6"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="QuoteColorHexLabel"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" FontFamily="Consolas" Text="（默认橘黄）"/>
                </Border>
                <TextBox x:Name="QuoteHexBox"
                         PlaceholderText="#RRGGBB"
                         Margin="14,0,14,6"
                         TextChanged="QuoteHexBox_TextChanged"/>
                <StackPanel Orientation="Horizontal" Margin="14,0,14,6">
                    <Button Tag="#000000" Click="QuotePreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF000000" BorderThickness="1"/>
                    <Button Tag="#1E1E1E" Click="QuotePreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF1E1E1E" BorderThickness="1"/>
                    <Button Tag="#1A1A2E" Click="QuotePreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF1A1A2E" BorderThickness="1"/>
                    <Button Tag="#2C3E50" Click="QuotePreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF2C3E50" BorderThickness="1"/>
                    <Button Tag="#F5F0E8" Click="QuotePreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FFF5F0E8" BorderThickness="1"/>
                    <Button Tag="#FFFFFF" Click="QuotePreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FFFFFFFF" BorderThickness="1"/>
                    <Button Tag="#0078D7" Click="QuotePreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF0078D7" BorderThickness="1"/>
                    <Button Tag="#C0392B" Click="QuotePreset_Click" Width="36" Height="36" Margin="0,0,0,0" Padding="0" Background="#FFC0392B" BorderThickness="1"/>
                </StackPanel>
                <Button Content="清除（使用默认橘黄）" Click="ClearQuoteColor_Click"
                        Margin="14,0,14,16" Padding="12,0" Height="34"/>

                <!-- Bracket color -->
                <TextBlock Text="括号颜色（（）* * 等）" FontSize="13" Opacity="0.7" Margin="14,0,14,4"/>
                <Border x:Name="BracketColorPreview"
                        Height="36" Margin="14,0,14,6"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="BracketColorHexLabel"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" FontFamily="Consolas" Text="（默认灰色）"/>
                </Border>
                <TextBox x:Name="BracketHexBox"
                         PlaceholderText="#RRGGBB"
                         Margin="14,0,14,6"
                         TextChanged="BracketHexBox_TextChanged"/>
                <StackPanel Orientation="Horizontal" Margin="14,0,14,6">
                    <Button Tag="#000000" Click="BracketPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF000000" BorderThickness="1"/>
                    <Button Tag="#1E1E1E" Click="BracketPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF1E1E1E" BorderThickness="1"/>
                    <Button Tag="#1A1A2E" Click="BracketPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF1A1A2E" BorderThickness="1"/>
                    <Button Tag="#2C3E50" Click="BracketPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF2C3E50" BorderThickness="1"/>
                    <Button Tag="#F5F0E8" Click="BracketPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FFF5F0E8" BorderThickness="1"/>
                    <Button Tag="#FFFFFF" Click="BracketPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FFFFFFFF" BorderThickness="1"/>
                    <Button Tag="#0078D7" Click="BracketPreset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF0078D7" BorderThickness="1"/>
                    <Button Tag="#C0392B" Click="BracketPreset_Click" Width="36" Height="36" Margin="0,0,0,0" Padding="0" Background="#FFC0392B" BorderThickness="1"/>
                </StackPanel>
                <Button Content="清除（使用默认灰色）" Click="ClearBracketColor_Click"
                        Margin="14,0,14,24" Padding="12,0" Height="34"/>

            </StackPanel>
        </ScrollViewer>

    </Grid>

    <Page.BottomAppBar>
        <CommandBar>
            <AppBarButton Icon="Refresh" Label="恢复默认" Click="ResetBtn_Click"/>
            <CommandBar.Content>
                <AppBarButton Icon="Back" Label="" Click="BackButton_Click"/>
            </CommandBar.Content>
        </CommandBar>
    </Page.BottomAppBar>
</Page>
