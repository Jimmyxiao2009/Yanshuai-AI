<Page
    x:Class="yanshuai.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:yanshuai"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <!-- SplitView: Pane = hamburger menu, Content = chat UI -->
        <SplitView x:Name="NavPane"
                   DisplayMode="Overlay"
                   IsPaneOpen="False"
                   PanePlacement="Left"
                   OpenPaneLength="260">

            <!-- ══ Hamburger pane ══════════════════════════════════════════ -->
            <SplitView.Pane>
                <Grid Background="#1A1A1A">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="51"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Pane accent header strip -->
                    <Grid Grid.Row="0" Background="{ThemeResource SystemAccentColor}">
                        <TextBlock Text="言枢"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Light"
                                   VerticalAlignment="Center"
                                   Margin="16,0"/>
                    </Grid>

                    <!-- Nav items -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,4">

                        <Button Click="Nav_Conversations_Click"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0"
                                Height="48" Padding="16,0">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE8F1;" FontSize="18" Width="28"
                                          Foreground="White" Opacity="0.85"/>
                                <TextBlock Text="对话列表" Foreground="White" Opacity="0.85"
                                           VerticalAlignment="Center" FontSize="15" Margin="14,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Click="Nav_Projects_Click"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0"
                                Height="48" Padding="16,0">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE8B7;" FontSize="18" Width="28"
                                          Foreground="White" Opacity="0.85"/>
                                <TextBlock Text="项目" Foreground="White" Opacity="0.85"
                                           VerticalAlignment="Center" FontSize="15" Margin="14,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Click="Nav_Api_Click"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0"
                                Height="48" Padding="16,0">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE774;" FontSize="18" Width="28"
                                          Foreground="White" Opacity="0.85"/>
                                <TextBlock Text="API 配置" Foreground="White" Opacity="0.85"
                                           VerticalAlignment="Center" FontSize="15" Margin="14,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Click="Nav_McpSkills_Click"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0"
                                Height="48" Padding="16,0">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE71A;" FontSize="18" Width="28"
                                          Foreground="White" Opacity="0.85"/>
                                <TextBlock Text="MCP / 技能" Foreground="White" Opacity="0.85"
                                           VerticalAlignment="Center" FontSize="15" Margin="14,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 分隔线 -->
                        <Border BorderBrush="#3A3A3A" BorderThickness="0,1,0,0" Margin="16,8,16,0"/>

                        </StackPanel>

                        <!-- 可滚动区：最近对话 + 最近项目 -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,8,0,0">
                            <StackPanel>
                                <!-- 最近对话 -->
                                <TextBlock Text="最近对话" Foreground="White" Opacity="0.45"
                                           FontSize="12" Margin="16,4,0,4"/>
                                <ItemsControl x:Name="RecentConvList" Margin="0,0,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left"
                                                    Background="Transparent" BorderThickness="0"
                                                    Height="42" Padding="16,0"
                                                    Tag="{Binding}"
                                                    Click="RecentConv_Click">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Title}"
                                                               Foreground="White" Opacity="0.7"
                                                               FontSize="13"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="160"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding DateLabel}"
                                                               Foreground="White" Opacity="0.35"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               Margin="8,0,0,0"/>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- 最近项目 -->
                                <TextBlock Text="最近项目" Foreground="White" Opacity="0.45"
                                           FontSize="12" Margin="16,12,0,4"/>
                                <ItemsControl x:Name="RecentProjectList" Margin="0,0,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Left"
                                                    Background="Transparent" BorderThickness="0"
                                                    Height="42" Padding="16,0"
                                                    Tag="{Binding}"
                                                    Click="RecentProject_Click">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding IconGlyph}"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="16" VerticalAlignment="Center"
                                                               Margin="0,0,8,0"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                               Foreground="White" Opacity="0.7"
                                                               FontSize="13"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="150"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding ConvCount}"
                                                               Foreground="White" Opacity="0.3"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               Margin="8,0,0,0"/>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- 底部固定区：设置 -->
                        <StackPanel Grid.Row="2">
                            <Border BorderBrush="#3A3A3A" BorderThickness="0,1,0,0"/>

                            <Button Click="Nav_Settings_Click"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Background="Transparent" BorderThickness="0"
                                    Height="52" Padding="16,0">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE713;" FontSize="18" Width="28"
                                              Foreground="White" Opacity="0.85"/>
                                    <TextBlock Text="设置" Foreground="White" Opacity="0.85"
                                               VerticalAlignment="Center" FontSize="15" Margin="14,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </SplitView.Pane>

            <!-- ══ Main content ═══════════════════════════════════════════ -->
            <SplitView.Content>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="51"/>   <!-- top bar -->
                        <RowDefinition Height="*"/>    <!-- chat -->
                        <RowDefinition Height="Auto"/> <!-- token bubble -->
                        <RowDefinition Height="Auto"/> <!-- input -->
                    </Grid.RowDefinitions>

                    <!-- ── Top bar (merged: hamburger + title + buttons) ── -->
                    <Grid Grid.Row="0" Background="#1A1A1A">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 汉堡按钮 -->
                        <Button Grid.Column="0"
                                Click="HamburgerBtn_Click"
                                Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                Height="51" Padding="0">
                            <Grid Width="52" Height="51">
                                <FontIcon Glyph="&#xE700;" FontSize="18" Foreground="White"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Margin="14,0,0,0"/>
                            </Grid>
                        </Button>

                        <!-- 标题 -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0">
                            <TextBlock x:Name="ConvTitleLabel"
                                       Text="新对话"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Light"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- 子代理状态 -->
                        <Button x:Name="SubagentsBtn"
                                Grid.Column="2"
                                Click="SubagentsBtn_Click"
                                Background="Transparent" BorderThickness="0"
                                Width="44" Height="51"
                                Foreground="White"
                                Visibility="Collapsed"
                                ToolTipService.ToolTip="子代理">
                            <Grid>
                                <FontIcon Glyph="&#xE716;" FontSize="15"/>
                                <Border x:Name="SubagentsBadge"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,2,4,0"
                                        Width="16" Height="16"
                                        CornerRadius="8"
                                        Background="{ThemeResource SystemAccentColor}"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="SubagentsCount"
                                               Text="0"
                                               FontSize="9"
                                               Foreground="Black"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                            <Button.Flyout>
                                <Flyout x:Name="SubagentsFlyout">
                                    <Grid Width="320" MaxHeight="400">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="子代理状态"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Margin="8,8,8,4"/>
                                        <ListView x:Name="SubagentsList"
                                                  Grid.Row="1"
                                                  SelectionMode="Single"
                                                  SelectionChanged="SubagentsList_SelectionChanged"
                                                  MinHeight="60"
                                                  Background="Transparent" BorderThickness="0"
                                                  Margin="4,0,4,4">
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                                            BorderThickness="0,0,0,1" Padding="8,6">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <FontIcon Grid.Column="0" Glyph="{Binding StatusIcon}"
                                                                      FontSize="12" Margin="0,0,8,0"
                                                                      VerticalAlignment="Center"/>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding TaskPreview}"
                                                                           FontSize="12" TextTrimming="WordEllipsis"
                                                                           MaxWidth="200"/>
                                                                <TextBlock Text="{Binding TimeLabel}"
                                                                           FontSize="10" Opacity="0.45"
                                                                           Margin="0,1,0,0"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2" Text="{Binding Status}"
                                                                       FontSize="10" Opacity="0.55"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <!-- 会话设置 -->
                        <Button x:Name="ConvSettingsBtn"
                                Grid.Column="3"
                                Click="ConvSettingsBtn_Click"
                                Background="Transparent" BorderThickness="0"
                                Width="44" Height="51"
                                Foreground="White"
                                ToolTipService.ToolTip="会话设置">
                            <FontIcon Glyph="&#xE713;" FontSize="16"/>
                        </Button>

                        <!-- 新建对话 -->
                        <Button x:Name="NewConvBtn"
                                Grid.Column="4"
                                Click="NewConvBtn_Click"
                                Background="Transparent" BorderThickness="0"
                                Width="44" Height="51"
                                Foreground="White"
                                ToolTipService.ToolTip="新建对话">
                            <FontIcon Glyph="&#xE710;" FontSize="16"/>
                        </Button>

                        <!-- 更多菜单（外观/PLAA） -->
                        <Button x:Name="TopMoreBtn"
                                Grid.Column="5"
                                Background="Transparent" BorderThickness="0"
                                Width="44" Height="51"
                                Foreground="White"
                                ToolTipService.ToolTip="更多">
                            <FontIcon Glyph="&#xE712;" FontSize="16"/>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="外观设置" Click="ConvAppearanceBtn_Click"/>
                                    <MenuFlyoutItem Text="PLAA 评估" Click="PlaaEvalBtn_Click"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>

                    <!-- ── Chat area ──────────────────────────────────── -->
                    <Grid Grid.Row="1">
                        <!-- Appearance: background layer (solid color or image) -->
                        <Border x:Name="ChatBgSolid"
                                Visibility="Collapsed"/>
                        <Image  x:Name="ChatBgImage"
                                Stretch="UniformToFill"
                                Visibility="Collapsed"/>
                        <!-- 图片背景暗度遮罩 -->
                        <Border x:Name="ChatBgDimOverlay"
                                Background="#80000000"
                                Visibility="Collapsed"/>

                        <!-- 新对话欢迎界面 -->
                        <StackPanel x:Name="WelcomePanel"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Visibility="Collapsed"
                                    Margin="32,0">
                            <FontIcon Glyph="&#xE8BD;" FontSize="52"
                                      Opacity="0.18" HorizontalAlignment="Center"/>
                            <TextBlock Text="言枢"
                                       FontSize="28" FontWeight="Light"
                                       Opacity="0.55" HorizontalAlignment="Center"
                                       Margin="0,16,0,6"/>
                            <TextBlock x:Name="WelcomeSubtitle"
                                       Text="在下方输入消息开始对话"
                                       FontSize="14" Opacity="0.35"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>

                        <!-- ListView 自身滚动以启用 UI 虚拟化：之前外层套了 ScrollViewer
                             且关掉了 ListView 的垂直滚动，导致所有气泡一次性实体化（内存暴涨/卡死）。 -->
                        <ListView x:Name="ChatItems"
                                  Margin="0,4,0,0"
                                  Loaded="ChatItems_Loaded"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  ShowsScrollingPlaceholders="False"
                                  ScrollViewer.HorizontalScrollMode="Disabled"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <!-- KeepItemsInView：向头部插入更早消息时保持当前可见项不跳动；
                                         CacheLength 调小以减少屏幕外实体化容器、降低内存峰值 -->
                                    <ItemsStackPanel ItemsUpdatingScrollMode="KeepItemsInView" CacheLength="1.0"/>
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,4" Tag="{Binding}" Tapped="BubbleTapped">

                                        <!-- ThinkChain：思考+工具统一列表，左 accent bar 风格 -->
                                        <ItemsControl Visibility="{Binding ThinkChainVisibility}"
                                                      ItemsSource="{Binding ThinkChain}"
                                                      Margin="12,2,12,4"
                                                      MaxWidth="580"
                                                      HorizontalAlignment="{Binding Align}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{ThemeResource SystemAccentColor}"
                                                            BorderThickness="2,0,0,0"
                                                            Background="{ThemeResource SystemControlBackgroundListLowBrush}"
                                                            Margin="0,2,0,2"
                                                            CornerRadius="0,4,4,0">
                                                        <StackPanel>
                                                            <!-- 标题行（折叠按钮） -->
                                                            <Button Tag="{Binding}"
                                                                    Click="ToggleThinkEntry_Click"
                                                                    Background="Transparent"
                                                                    BorderThickness="0"
                                                                    HorizontalAlignment="Stretch"
                                                                    Padding="10,6,10,6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <!-- 图标：思考用💭脑图标，工具用工具图标 -->
                                                                    <FontIcon Grid.Column="0"
                                                                              Glyph="&#xE945;"
                                                                              FontSize="12"
                                                                              Foreground="{ThemeResource SystemAccentColor}"
                                                                              Opacity="0.8"
                                                                              Margin="0,0,6,0"/>
                                                                    <!-- 标题：Reasoning 显示思考标签，Tool 显示图标+工具名 -->
                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                        <!-- Reasoning 标题 -->
                                                                        <TextBlock Text="{Binding ReasoningLabel}"
                                                                                   Visibility="{Binding ReasoningVisibility}"
                                                                                   FontSize="12" FontWeight="SemiBold"
                                                                                   Foreground="{ThemeResource SystemAccentColor}"
                                                                                   VerticalAlignment="Center"/>
                                                                        <!-- Tool 标题 -->
                                                                        <TextBlock Text="{Binding Icon}"
                                                                                   Visibility="{Binding ToolVisibility}"
                                                                                   FontSize="12"
                                                                                   Margin="0,0,4,0"
                                                                                   VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding ToolName}"
                                                                                   Visibility="{Binding ToolVisibility}"
                                                                                   FontSize="12" FontWeight="SemiBold"
                                                                                   Foreground="{ThemeResource SystemAccentColor}"
                                                                                   VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding ChevronText}"
                                                                               FontSize="10" Opacity="0.6"
                                                                               VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </Button>
                                                            <!-- 内容区 -->
                                                            <StackPanel Visibility="{Binding BodyVisibility}" Margin="10,0,10,8">
                                                                <!-- Reasoning 文本 -->
                                                                <TextBlock local:StreamFade.Text="{Binding ReasoningText}"
                                                                           Visibility="{Binding ReasoningVisibility}"
                                                                           TextWrapping="Wrap"
                                                                           FontSize="13" Opacity="0.75"/>
                                                                <!-- Tool 详情 -->
                                                                <TextBlock Text="{Binding Detail}"
                                                                           Visibility="{Binding ToolVisibility}"
                                                                           TextWrapping="Wrap"
                                                                           FontSize="11" Opacity="0.7"
                                                                           Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                                        <!-- User bubble: always plain text -->
                                        <!-- 图片缩略图（气泡上方，可点击放大） -->
                                        <Border Visibility="{Binding HasImageVisibility}"
                                                HorizontalAlignment="{Binding Align}"
                                                Margin="12,2"
                                                Tag="{Binding}"
                                                Tapped="BubbleImage_Click"
                                                CornerRadius="4">
                                            <Border.RenderTransform>
                                                <TranslateTransform/>
                                            </Border.RenderTransform>
                                            <Image Source="{Binding ImageSource}"
                                                   Width="120" Height="120"
                                                   Stretch="UniformToFill"/>
                                        </Border>
                                        <Border Background="{Binding BackgroundColor}"
                                                Visibility="{Binding UserVisibility}"
                                                Margin="12,4,12,2"
                                                MaxWidth="580"
                                                CornerRadius="18,18,4,18"
                                                HorizontalAlignment="{Binding Align}">
                                            <TextBlock Text="{Binding Content}"
                                                       FontSize="16"
                                                       Foreground="{Binding ForegroundColor}"
                                                       TextWrapping="Wrap"
                                                       Padding="12,10"/>
                                        </Border>

                                        <!-- AI bubble while streaming: plain TextBlock + blinking cursor -->
                                        <Border Background="{Binding BackgroundColor}"
                                                Visibility="{Binding AiStreamingVisibility}"
                                                Margin="12,2,12,2"
                                                MaxWidth="580"
                                                CornerRadius="4,18,18,18"
                                                HorizontalAlignment="{Binding Align}">
                                            <Grid Padding="12,10">
                                                <TextBlock local:StreamFade.Text="{Binding Content}"
                                                           FontSize="16"
                                                           Foreground="{Binding ForegroundColor}"
                                                           TextWrapping="Wrap"/>
                                                <!-- streaming cursor indicator -->
                                                <TextBlock x:Name="StreamCursor"
                                                           Text="▌"
                                                           FontSize="16"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Bottom"
                                                           Foreground="{ThemeResource SystemControlForegroundAccentBrush}"
                                                           Opacity="0.9">
                                                    <TextBlock.Triggers>
                                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <DoubleAnimation
                                                                        Storyboard.TargetName="StreamCursor"
                                                                        Storyboard.TargetProperty="Opacity"
                                                                        From="0.9" To="0"
                                                                        Duration="0:0:0.55"
                                                                        AutoReverse="True"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </TextBlock.Triggers>
                                                </TextBlock>
                                            </Grid>
                                        </Border>

                                        <!-- 搜索状态提示（tool use 进行中，有动画感） -->
                                        <Border Visibility="{Binding SearchStatusVisibility}"
                                                Margin="12,2,12,2"
                                                HorizontalAlignment="{Binding Align}"
                                                Padding="8,4" CornerRadius="4">
                                            <Border.Background>
                                                <SolidColorBrush Color="{ThemeResource SystemAccentColor}" Opacity="0.12"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding SearchStatusText}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource SystemAccentColor}"
                                                       TextWrapping="Wrap"/>
                                        </Border>

                                        <!-- AI bubble after stream: markdown-rendered RichTextBlock -->
                                        <Border Background="{Binding BackgroundColor}"
                                                Visibility="{Binding AiRenderedVisibility}"
                                                Margin="12,2,12,2"
                                                MaxWidth="580"
                                                CornerRadius="4,18,18,18"
                                                HorizontalAlignment="{Binding Align}">
                                            <RichTextBlock local:MarkdownBlock.Text="{Binding RenderedContent}"
                                                           local:MarkdownBlock.QuoteColor="{Binding QuoteColor}"
                                                           local:MarkdownBlock.BracketColor="{Binding BracketColor}"
                                                           FontSize="16"
                                                           Foreground="{Binding ForegroundColor}"
                                                           TextWrapping="Wrap"
                                                           Padding="12,10"
                                                           IsTextSelectionEnabled="True"/>
                                        </Border>

                                        <!-- ── Action strip ───────────────────────────── -->
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding ActionStripVisibility}"
                                                    HorizontalAlignment="{Binding Align}"
                                                    Margin="12,1,12,2">

                                            <!-- Copy (all messages) -->
                                            <Button Tag="{Binding}" Click="CopyMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="复制">
                                                <FontIcon Glyph="&#xE8C8;" FontSize="13" Opacity="0.55"/>
                                            </Button>

                                            <!-- Edit (user messages only) -->
                                            <Button Visibility="{Binding EditBtnVisibility}"
                                                    Tag="{Binding}" Click="EditMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="编辑">
                                                <FontIcon Glyph="&#xE70F;" FontSize="13" Opacity="0.55"/>
                                            </Button>

                                            <!-- Delete this msg + all after -->
                                            <Button Tag="{Binding}" Click="DeleteMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="删除此消息及之后所有消息">
                                                <FontIcon Glyph="&#xE74D;" FontSize="13" Opacity="0.55"/>
                                            </Button>

                                            <!-- Regenerate (AI only, after streaming) -->
                                            <Button Visibility="{Binding RegenerateBtnVisibility}"
                                                    Tag="{Binding}" Click="RegenerateMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="重新生成">
                                                <FontIcon Glyph="&#xE72C;" FontSize="13" Opacity="0.55"/>
                                            </Button>

                                            <!-- Continue (AI only, after streaming) -->
                                            <Button Visibility="{Binding ContinueBtnVisibility}"
                                                    Tag="{Binding}" Click="ContinueMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="继续">
                                                <FontIcon Glyph="&#xE768;" FontSize="13" Opacity="0.55"/>
                                            </Button>

                                            <!-- Branch navigator: < 1/3 > (user msgs with branches) -->
                                            <StackPanel Visibility="{Binding BranchNavVisibility}"
                                                        Orientation="Horizontal">
                                                <Button Tag="{Binding}" Click="PrevBranch_Click"
                                                        Background="Transparent" BorderThickness="0"
                                                        Width="26" Height="28" Padding="0">
                                                    <FontIcon Glyph="&#xE76B;" FontSize="11" Opacity="0.7"/>
                                                </Button>
                                                <TextBlock Text="{Binding BranchLabel}"
                                                           FontSize="12" Opacity="0.6"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0"/>
                                                <Button Tag="{Binding}" Click="NextBranch_Click"
                                                        Background="Transparent" BorderThickness="0"
                                                        Width="26" Height="28" Padding="0">
                                                    <FontIcon Glyph="&#xE76C;" FontSize="11" Opacity="0.7"/>
                                                </Button>
                                            </StackPanel>

                                        </StackPanel>

                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- 加载遮罩（声明在列表之后，渲染在最上层） -->
                        <Border x:Name="LoadingOverlay"
                                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                                Visibility="Collapsed"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <ProgressBar x:Name="LoadingProgress"
                                             Minimum="0" Maximum="100" Value="0"
                                             Width="200" Height="4"
                                             Margin="0,0,0,12"/>
                                <TextBlock x:Name="LoadingText"
                                           Text="加载中…"
                                           FontSize="13" Opacity="0.5"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid><!-- /ChatArea -->

                    <!-- ══ 底部弹出提问面板 ═══════════════════════════════════ -->
                    <Border x:Name="BottomAskPanel"
                            Grid.Row="1"
                            VerticalAlignment="Bottom"
                            Visibility="Collapsed"
                            Background="#E5282A36"
                            BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="0,1,0,0"
                            MaxHeight="420">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="AskPanelTransform" Y="0"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 标题栏 -->
                            <Grid Grid.Row="0" Padding="14,10,14,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="AskPanelTitle" Text="AI 向你提问"
                                           FontSize="16" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Click="AskPanelClose_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Width="36" Height="36" Padding="0">
                                    <FontIcon Glyph="&#xE711;" FontSize="14" Opacity="0.6"/>
                                </Button>
                            </Grid>

                            <!-- 问题列表 -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="AskQuestionsList" Margin="14,4,14,8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="{Binding Text}"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,6"/>
                                                <!-- text 类型 -->
                                                <TextBox Text="{Binding Answer, Mode=TwoWay}"
                                                         PlaceholderText="{Binding Placeholder}"
                                                         Visibility="{Binding IsText}"
                                                         MinHeight="42"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"/>
                                                <!-- choice 类型 -->
                                                <ComboBox ItemsSource="{Binding OptionList}"
                                                          SelectedItem="{Binding Answer, Mode=TwoWay}"
                                                          Visibility="{Binding IsChoice}"
                                                          PlaceholderText="请选择…"/>
                                                <!-- confirm 类型 -->
                                                <ToggleSwitch IsOn="{Binding IsConfirmed, Mode=TwoWay}"
                                                              Visibility="{Binding IsConfirm}"
                                                              OnContent="是" OffContent="否"/>
                                                <!-- multi 类型 -->
                                                <ItemsControl ItemsSource="{Binding MultiItems}"
                                                              Visibility="{Binding IsMulti}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding Label}"
                                                                      IsChecked="{Binding Checked, Mode=TwoWay}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- 底部按钮 -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal"
                                        Margin="14,4,14,12">
                                <Button x:Name="AskPanelSubmitBtn" Content="提交"
                                        Click="AskPanelSubmit_Click"
                                        Padding="20,10" FontSize="14"
                                        HorizontalAlignment="Left"/>
                                <Button x:Name="AskPanelCancelBtn" Content="跳过"
                                        Click="AskPanelCancel_Click"
                                        Padding="20,10" FontSize="14"
                                        Foreground="Gray" Background="Transparent"
                                        HorizontalAlignment="Left" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Token usage bar ───────────────────────────────────────── -->
                    <Border x:Name="TokenBubble"
                            Grid.Row="2"
                            Visibility="Collapsed"
                            BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="0,1,0,1">
                        <Border.Background>
                            <SolidColorBrush Color="#000000" Opacity="0.15"/>
                        </Border.Background>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- 上下文进度条 -->
                                <RowDefinition Height="Auto"/>  <!-- token 两列 -->
                            </Grid.RowDefinitions>

                            <!-- 上下文窗口进度条 -->
                            <Grid x:Name="ContextUsageBar" Grid.Row="0"
                                  Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="5"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="ContextWindowInfo"
                                           Grid.Row="0"
                                           FontSize="10" Opacity="0.5"
                                           Margin="8,2,8,1"
                                           HorizontalAlignment="Center"
                                           TextTrimming="WordEllipsis"/>
                                <!-- 进度条：填充 + 背景轨道，用 Grid 叠加 -->
                                <Grid Grid.Row="1">
                                    <Border Background="{ThemeResource SystemAccentColor}"
                                            Opacity="0.15"
                                            HorizontalAlignment="Stretch"/>
                                    <Border x:Name="ContextUsageFill"
                                            Background="{ThemeResource SystemAccentColor}"
                                            Opacity="0.8"
                                            HorizontalAlignment="Left"
                                            Width="0"/>
                                </Grid>
                            </Grid>

                            <!-- 两列：本次输入 | 累计输出 -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 本次输入 (最近一次 API 调用的 input tokens) -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0,5,0,5">
                                    <TextBlock Text="↓"
                                               FontSize="13"
                                               Foreground="{ThemeResource SystemControlForegroundAccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,5,0"/>
                                    <TextBlock Text="本次"
                                               FontSize="11" Opacity="0.55"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               Margin="0,0,5,0"/>
                                    <TextBlock x:Name="TokenInLabel"
                                               Text="0"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{ThemeResource SystemControlForegroundAccentBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <Rectangle Grid.Column="1" Width="1"
                                           Fill="White" Opacity="0.12"
                                           Margin="0,6,0,6"/>

                                <!-- 累计输出 (对话总计 output tokens) -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0,5,0,5">
                                    <TextBlock Text="↑"
                                               FontSize="13"
                                               Foreground="{ThemeResource SystemControlForegroundAccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,5,0"/>
                                    <TextBlock Text="总计"
                                               FontSize="11" Opacity="0.55"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               Margin="0,0,5,0"/>
                                    <TextBlock x:Name="TokenOutLabel"
                                               Text="0"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{ThemeResource SystemControlForegroundAccentBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ── Input bar ───────────────────────────────────── -->
                    <Grid Grid.Row="3"
                          Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                          BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="0,1,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- 图片预览 -->
                            <RowDefinition Height="Auto"/>  <!-- 输入行 -->
                        </Grid.RowDefinitions>

                        <!-- 文件预览条（有附件时显示） -->
                        <Border x:Name="ImagePreviewBar"
                                Grid.Row="0"
                                Visibility="Collapsed"
                                Padding="8,6" BorderThickness="0,0,0,1"
                                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- 预览列表 -->
                                <ItemsControl x:Name="PendingAttachList"
                                              Grid.Column="0"
                                              ItemsSource="{x:Null}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="2,0" CornerRadius="4"
                                                    BorderThickness="1"
                                                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                                    Padding="4,2">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="{Binding Thumb}" Width="40" Height="40"
                                                           Stretch="UniformToFill"
                                                           Visibility="{Binding ThumbVisibility}"/>
                                                    <FontIcon Glyph="{Binding Icon}" FontSize="20"
                                                              VerticalAlignment="Center"
                                                              Visibility="{Binding IconVisibility}"/>
                                                    <TextBlock Text="{Binding Label}" FontSize="11"
                                                               VerticalAlignment="Center"
                                                               MaxWidth="100" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Grid.Column="1"
                                        Click="ClearImageBtn_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Width="36" Height="36" Padding="0">
                                    <FontIcon Glyph="&#xE711;" FontSize="14" Opacity="0.6"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- 输入行：扩展菜单 + 附件 + 输入框 + 发送 -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- 扩展菜单 -->
                                <ColumnDefinition Width="Auto"/>  <!-- 附件 -->
                                <ColumnDefinition Width="*"/>     <!-- 输入框 -->
                                <ColumnDefinition Width="Auto"/>  <!-- 发送 -->
                            </Grid.ColumnDefinitions>

                            <!-- 扩展菜单按钮（收纳所有工具按钮） -->
                            <Button x:Name="ExpandMenuBtn"
                                    Grid.Column="0"
                                    Background="Transparent" BorderThickness="0"
                                    Width="40" MinHeight="42"
                                    Margin="4,6,0,6"
                                    VerticalAlignment="Bottom"
                                    ToolTipService.ToolTip="更多选项">
                                <FontIcon Glyph="&#xE710;" FontSize="18" Opacity="0.6"
                                          Foreground="{ThemeResource ApplicationForegroundThemeBrush}"/>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <ToggleMenuFlyoutItem x:Name="ToolsToggle" Text="🔧 工具调用"
                                                              IsChecked="True" Click="ToolsToggle_Click"/>
                                        <ToggleMenuFlyoutItem x:Name="FullTrustToggle" Text="🛡️ 完全信任模式"
                                                              IsChecked="False" Click="FullTrustToggle_Click"/>
                                        <ToggleMenuFlyoutItem x:Name="FetchToggle" Text="🌐 允许读取搜索页面"
                                                              IsChecked="False" Click="FetchToggle_Click"/>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem Text="📝 全屏输入" Click="FullscreenInputBtn_Click"/>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem Text="🗜️ 压缩上下文" Click="ManualCompressContext_Click"/>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>

                            <!-- 文件附加按钮 -->
                            <Button x:Name="AttachImageBtn"
                                    Grid.Column="1"
                                    Click="AttachImageBtn_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Width="40" MinHeight="42"
                                    Margin="0,6,0,6"
                                    VerticalAlignment="Bottom"
                                    ToolTipService.ToolTip="附加文件">
                                <FontIcon x:Name="AttachImageIcon" Glyph="&#xE8A5;" FontSize="18" Opacity="0.6"
                                          Foreground="{ThemeResource ApplicationForegroundThemeBrush}"/>
                            </Button>

                            <TextBox x:Name="InputTextBox"
                                     Grid.Column="2"
                                     PlaceholderText="说点什么…"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     TextWrapping="Wrap"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     MinHeight="42"
                                     MaxHeight="160"
                                     Margin="4,6,6,6"
                                     KeyDown="InputTextBox_KeyDown"/>

                            <Button x:Name="SubmitButton"
                                    Grid.Column="3"
                                    Click="SubmitButton_Click"
                                    Width="52"
                                    MinHeight="42"
                                    Margin="0,6,8,6"
                                    VerticalAlignment="Bottom"
                                    Background="{ThemeResource SystemAccentColor}"
                                    Foreground="White"
                                    BorderBrush="Transparent">
                                <FontIcon x:Name="SubmitIcon" Glyph="&#xE74A;" FontSize="18"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </SplitView.Content>
        </SplitView>

        <MediaElement x:Name="ReplySound" AutoPlay="False" Visibility="Collapsed"/>
    </Grid>
</Page>
