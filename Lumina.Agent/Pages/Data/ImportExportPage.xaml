<Page
    x:Class="yanshuai.ImportExportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="14,16,14,8">
            <TextBlock Text="导入 / 导出" FontSize="32" FontWeight="Light"/>
            <TextBlock Text="对话采用 ST JSONL 格式"
                       FontSize="11" Opacity="0.5" TextWrapping="Wrap" Margin="0,2,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ══ 对话 ══ -->
                <StackPanel Margin="14,8,14,8">
                    <TextBlock Text="对话记录" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemAccentColor}" CharacterSpacing="80"/>
                    <Border BorderBrush="{ThemeResource SystemAccentColor}"
                            BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="14,0,14,6">
                    <Button Content="导出当前对话" Click="ExportCurrentConv_Click"
                            Padding="14,8" Margin="0,0,8,0"/>
                    <Button Content="批量导出所有" Click="ExportAllConv_Click"
                            Padding="14,8" Margin="0,0,8,0"/>
                    <Button Content="导入对话(.jsonl)" Click="ImportConv_Click"
                            Padding="14,8"/>
                </StackPanel>
                <TextBlock x:Name="ConvStatus" Text="" FontSize="12" Opacity="0.6"
                           Margin="14,4,14,16" TextWrapping="Wrap"/>

<!-- ══ API 配置 ══ -->
                <StackPanel Margin="14,8,14,8">
                    <TextBlock Text="API 配置" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource SystemAccentColor}" CharacterSpacing="80"/>
                    <Border BorderBrush="{ThemeResource SystemAccentColor}"
                            BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                </StackPanel>
                <TextBlock Text="导出文件包含 API Key，请妥善保管"
                           FontSize="12" Opacity="0.55" Margin="14,0,14,8"
                           Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                <StackPanel Orientation="Horizontal" Margin="14,0,14,6">
                    <Button Content="导出 API 配置" Click="ExportApi_Click"
                            Padding="14,8" Margin="0,0,8,0"/>
                    <Button Content="导入 API 配置(.json)" Click="ImportApi_Click"
                            Padding="14,8"/>
                </StackPanel>
                <TextBlock x:Name="ApiStatus" Text="" FontSize="12" Opacity="0.6"
                           Margin="14,4,14,24" TextWrapping="Wrap"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>

    <Page.BottomAppBar>
        <CommandBar>
            <CommandBar.Content>
                <AppBarButton Icon="Back" Label="" Click="BackButton_Click"/>
            </CommandBar.Content>
        </CommandBar>
    </Page.BottomAppBar>
</Page>
