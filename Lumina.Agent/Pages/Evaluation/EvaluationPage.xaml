<Page
    x:Class="yanshuai.EvaluationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:yanshuai"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 标题 ── -->
        <TextBlock Text="PLAA 评估实验台"
                   FontSize="24" FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <!-- ── 服务器配置 ── -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox x:Name="ServerUrlBox"
                     PlaceholderText="PLAA 服务器地址"
                     Width="400" FontSize="13" Margin="0,0,8,0"/>
            <Button Click="SaveConfig_Click" Content="保存配置"
                    Background="{ThemeResource SystemAccentColor}"
                    Foreground="White" FontSize="13" Margin="0,0,8,0"/>
            <Button Click="LoadExperiments_Click" Content="刷新实验"
                    FontSize="13"/>
        </StackPanel>

        <!-- ── 实验列表 + 结果 ── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：实验列表 -->
            <ScrollViewer Grid.Column="0" Margin="0,0,12,0">
                <StackPanel x:Name="ExperimentsPanel">
                    <TextBlock Text="可用实验" FontSize="16" FontWeight="SemiBold"/>
                    <!-- 实验卡片由代码生成 -->
                </StackPanel>
            </ScrollViewer>

            <!-- 右侧：结果显示 -->
            <ScrollViewer Grid.Column="1">
                <StackPanel x:Name="ResultsPanel">
                    <TextBlock Text="结果" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusText"
                               Text="选择一个实验开始评估"
                               Foreground="Gray"
                               FontStyle="Italic"/>
                    <!-- 结果卡片 + 图表 -->
                    <Border x:Name="ChartContainer"
                            BorderBrush="#444" BorderThickness="1"
                            CornerRadius="8" Padding="4"
                            Visibility="Collapsed"
                            MinHeight="300" Margin="0,8">
                        <Canvas x:Name="TrajectoryCanvas"
                                Width="640" Height="360"/>
                    </Border>
                    <ItemsControl x:Name="ResultsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#333" BorderThickness="1"
                                        CornerRadius="8" Padding="12" Margin="0,4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ExperimentName}"
                                                   FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Timestamp}"
                                                   FontSize="11" Foreground="Gray"/>
                                        <TextBlock Text="{Binding Metrics,
                                            Converter={StaticResource MetricsConverter}}"
                                                   FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ── 进度条 ── -->
        <ProgressBar x:Name="ProgressBar"
                     Grid.Row="3"
                     IsIndeterminate="False"
                     Visibility="Collapsed"
                     Margin="0,8,0,0"/>
        <TextBlock x:Name="ProgressText"
                   Grid.Row="3"
                   FontSize="12"
                   Foreground="Gray"
                   Margin="0,4,0,0"/>
    </Grid>
</Page>
