<Page
    x:Class="yanshuai.OobePermissionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="14,16,14,8">
            <TextBlock x:Name="PageTitle" Text="权限设置" FontSize="32" FontWeight="Light"/>
            <TextBlock x:Name="PageSubtitle" Text="应用需要使用以下权限"
                       FontSize="13" Opacity="0.5" Margin="0,4,0,0"/>
            <TextBlock x:Name="PageStepHint" Text="步骤 2 / 3"
                       FontSize="12" Opacity="0.5" Margin="0,8,0,0"/>
            <ProgressBar Value="66" Maximum="100" Margin="0,6,0,0" Height="4"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="14,8,14,24">

                <TextBlock x:Name="InfoText"
                           Text="以下权限已在安装时声明，部分可能需要你在系统设置中手动开启。"
                           FontSize="13" Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- SD 卡 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE7C1;" FontSize="18" VerticalAlignment="Center"
                              Foreground="{ThemeResource SystemAccentColor}"/>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="外部存储（SD 卡）" FontSize="15"/>
                        <TextBlock Text="读取和写入 SD 卡上的文件" FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock x:Name="SdStatus" Grid.Column="2" Text="✓ 已授权" FontSize="13"
                               Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"/>
                </Grid>

                <!-- 文件系统 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE8B7;" FontSize="18" VerticalAlignment="Center"
                              Foreground="{ThemeResource SystemAccentColor}"/>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="文件系统" FontSize="15"/>
                        <TextBlock Text="访问公共目录（当前设备不支持）" FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock x:Name="FsStatus" Grid.Column="2" Text="不可用" FontSize="13"
                               Foreground="Orange" VerticalAlignment="Center"/>
                </Grid>

                <!-- 日历 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE163;" FontSize="18" VerticalAlignment="Center"
                              Foreground="{ThemeResource SystemAccentColor}"/>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="日历" FontSize="15"/>
                        <TextBlock Text="创建和修改日历事件" FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="✓ 已授权" FontSize="13"
                               Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"/>
                </Grid>

                <!-- 联系人 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE77B;" FontSize="18" VerticalAlignment="Center"
                              Foreground="{ThemeResource SystemAccentColor}"/>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="联系人" FontSize="15"/>
                        <TextBlock Text="读取和管理联系人信息" FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="✓ 已授权" FontSize="13"
                               Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"/>
                </Grid>

                <!-- 电话 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE717;" FontSize="18" VerticalAlignment="Center"
                              Foreground="{ThemeResource SystemAccentColor}"/>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="电话" FontSize="15"/>
                        <TextBlock Text="拨打电话和管理通话记录" FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="✓ 已授权" FontSize="13"
                               Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"/>
                </Grid>

                <!-- 短信 -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE8DF;" FontSize="18" VerticalAlignment="Center"
                              Foreground="{ThemeResource SystemAccentColor}"/>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="短信" FontSize="15"/>
                        <TextBlock Text="读取和发送短信" FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="✓ 已授权" FontSize="13"
                               Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"/>
                </Grid>

                <!-- 打开设置按钮 -->
                <Button x:Name="SettingsBtn" Click="SettingsBtn_Click"
                        HorizontalAlignment="Stretch" Padding="14,12"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE713;" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock x:Name="SettingsBtnText" Text="打开系统隐私设置"/>
                    </StackPanel>
                </Button>

                <TextBlock x:Name="NoteText"
                           Text="如果你更改了权限设置，返回后点击下方「继续」即可。"
                           FontSize="12" Opacity="0.45" TextWrapping="Wrap"
                           TextAlignment="Center" Margin="0,0,0,8"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>

    <Page.BottomAppBar>
        <CommandBar>
            <AppBarButton x:Name="NextBtn" Icon="Forward" Label="继续" Click="NextBtn_Click"/>
            <CommandBar.Content>
                <AppBarButton Icon="Back" Label="" Click="BackBtn_Click"/>
            </CommandBar.Content>
        </CommandBar>
    </Page.BottomAppBar>

</Page>
