<Page
    x:Class="yanshuai.ProjectSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="51"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Grid Grid.Row="0" Background="#1A1A1A">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Click="BackBtn_Click"
                    Background="Transparent" BorderThickness="0"
                    Width="52" Height="51">
                <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="White"/>
            </Button>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding ProjectIcon, ElementName=RootGrid}"
                           FontFamily="Segoe MDL2 Assets" FontSize="16"
                           Foreground="White" Opacity="0.7"
                           VerticalAlignment="Center" Margin="4,0,8,0"/>
                <TextBlock x:Name="ProjectTitle" Text="项目"
                           Foreground="White" FontSize="18" FontWeight="Light"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <Button Grid.Column="2" Click="DeleteProjectBtn_Click"
                    Background="Transparent" BorderThickness="0"
                    Width="48" Height="51" Foreground="#FF6666"
                    ToolTipService.ToolTip="删除项目">
                <FontIcon Glyph="&#xE74D;" FontSize="16"/>
            </Button>
        </Grid>

        <!-- Two tabs: 对话 / 设置 -->
        <Pivot Grid.Row="1" x:Name="MainPivot">
            <!-- ════════════════════════════════════════════════════════════════ -->
            <!--  分页一：对话                                                    -->
            <!-- ════════════════════════════════════════════════════════════════ -->
            <PivotItem Header="对话">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 新建对话按钮 -->
                    <Button Grid.Row="0" Click="NewConvInProject_Click"
                            HorizontalAlignment="Stretch"
                            Margin="12,8,12,4">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE710;" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="新建对话" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <!-- 对话列表 -->
                    <ListView x:Name="ConvList" Grid.Row="1"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="ConvList_ItemClick">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="14,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="15"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Preview}" FontSize="12"
                                                   Opacity="0.45" Margin="0,2,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DateLabel}" FontSize="11"
                                                   Opacity="0.35" Margin="0,0,8,0"/>
                                        <Button Tag="{Binding}" Click="ConvDeleteBtn_Click"
                                                Background="Transparent" BorderThickness="0"
                                                Width="28" Height="28" Padding="0">
                                            <FontIcon Glyph="&#xE711;" FontSize="12" Opacity="0.5"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- 空状态 -->
                    <StackPanel x:Name="ConvEmptyState" Grid.Row="1"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="Collapsed">
                        <FontIcon Glyph="&#xE8BD;" FontSize="40" Opacity="0.15"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="还没有对话" FontSize="15" Opacity="0.35"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="点击上方按钮新建对话"
                                   FontSize="12" Opacity="0.25"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </PivotItem>

            <!-- ════════════════════════════════════════════════════════════════ -->
            <!--  分页二：设置                                                    -->
            <!-- ════════════════════════════════════════════════════════════════ -->
            <PivotItem Header="设置">
                <ScrollViewer Padding="12,8,12,24">
                    <StackPanel>

                        <!-- 项目图标 -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Width="48" Height="48"
                                  Background="{ThemeResource SystemControlBackgroundListLowBrush}"
                                  CornerRadius="6" Margin="0,0,12,0">
                                <TextBlock x:Name="IconPreview"
                                           Text="&#xE8B7;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="图标" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <ItemsControl x:Name="IconPickerList">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapGrid Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Tag="{Binding}" Click="IconBtn_Click"
                                                    Width="36" Height="36"
                                                    Padding="0" Margin="0,0,4,4"
                                                    Background="Transparent"
                                                    BorderThickness="0">
                                                <TextBlock Text="{Binding}"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="16"
                                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>

                        <!-- 项目名称 -->
                        <TextBox x:Name="NameBox" Header="项目名称"
                                 PlaceholderText="输入项目名称"
                                 TextChanged="NameBox_TextChanged"/>

                        <!-- 描述 -->
                        <TextBox x:Name="DescBox" Header="描述"
                                 PlaceholderText="简要描述此项目"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="60" MaxHeight="120"
                                 TextChanged="DescBox_TextChanged"/>

                        <!-- 项目指令 -->
                        <TextBox x:Name="SysPromptBox" Header="项目指令（System Prompt）"
                                 PlaceholderText="此项目下所有对话都会注入的指令…"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="100" MaxHeight="200"
                                 TextChanged="SysPromptBox_TextChanged"/>

                        <!-- 知识库 -->
                        <StackPanel Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="知识库文件"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Click="AddKbFileBtn_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="8,4" ToolTipService.ToolTip="添加文件">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE710;" FontSize="12" Margin="0,0,4,0"/>
                                        <TextBlock Text="添加" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <ItemsControl x:Name="KbFileList" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2" Padding="8,6"
                                              Background="{ThemeResource SystemControlBackgroundListLowBrush}"
                                              CornerRadius="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       FontSize="13" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="1" Tag="{Binding}"
                                                    Click="RemoveKbFile_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="28" Height="28" Padding="0">
                                                <FontIcon Glyph="&#xE711;" FontSize="12" Opacity="0.6"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 项目记忆 -->
                        <StackPanel Margin="0,16,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="记忆" FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="MemoryCountLabel" Text="0 条"
                                               FontSize="12" Opacity="0.45"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Click="AddMemoryBtn_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="8,4" ToolTipService.ToolTip="添加记忆">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE710;" FontSize="12" Margin="0,0,4,0"/>
                                        <TextBlock Text="添加" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <TextBlock Text="项目记忆会在该项目的对话中自动注入，帮助 AI 记住关键信息"
                                       FontSize="11" Opacity="0.35" TextWrapping="Wrap"
                                       Margin="0,0,0,6"/>
                            <ItemsControl x:Name="MemoryList" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2" Padding="10,8"
                                              Background="{ThemeResource SystemControlBackgroundListLowBrush}"
                                              CornerRadius="4">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Background="{ThemeResource SystemAccentColor}"
                                                        CornerRadius="3"
                                                        Padding="6,2" Margin="0,0,8,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding CategoryLabel}"
                                                               FontSize="11" Foreground="White"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding ImportanceLabel}"
                                                           FontSize="11" Opacity="0.35"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="2" Tag="{Binding}"
                                                        Click="EditMemoryBtn_Click"
                                                        Background="Transparent" BorderThickness="0"
                                                        Width="28" Height="28" Padding="0"
                                                        ToolTipService.ToolTip="编辑">
                                                    <FontIcon Glyph="&#xE70F;" FontSize="12" Opacity="0.5"/>
                                                </Button>
                                                <Button Grid.Column="3" Tag="{Binding}"
                                                        Click="RemoveMemoryBtn_Click"
                                                        Background="Transparent" BorderThickness="0"
                                                        Width="28" Height="28" Padding="0"
                                                        ToolTipService.ToolTip="删除">
                                                    <FontIcon Glyph="&#xE711;" FontSize="12" Opacity="0.5"/>
                                                </Button>
                                            </Grid>
                                            <TextBlock Grid.Row="1" Text="{Binding Text}"
                                                       FontSize="13" TextWrapping="Wrap"
                                                       Margin="0,4,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
