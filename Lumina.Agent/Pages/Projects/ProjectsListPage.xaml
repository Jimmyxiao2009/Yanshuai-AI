<Page
    x:Class="yanshuai.ProjectsListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="51"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Grid Grid.Row="0" Background="#1A1A1A">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Click="BackBtn_Click"
                    Background="Transparent" BorderThickness="0"
                    Width="52" Height="51">
                <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="White"/>
            </Button>
            <TextBlock Grid.Column="1" Text="项目"
                       Foreground="White" FontSize="18" FontWeight="Light"
                       VerticalAlignment="Center" Margin="4,0"/>
            <Button Grid.Column="2" Click="NewProjectBtn_Click"
                    Background="Transparent" BorderThickness="0"
                    Width="48" Height="51" Foreground="White"
                    ToolTipService.ToolTip="新建项目">
                <FontIcon Glyph="&#xE710;" FontSize="16"/>
            </Button>
        </Grid>

        <!-- Project list -->
        <ListView x:Name="ProjectList" Grid.Row="1"
                  Padding="0,8"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="Project_Click">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="16,12" Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding IconGlyph}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Name}"
                                   FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="{Binding UpdatedAtDisplay}"
                                   FontSize="11" Opacity="0.5"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.ColumnSpan="3"
                                   Text="{Binding Description}"
                                   FontSize="13" Opacity="0.6"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,0,0"/>
                        <TextBlock Grid.Row="2" Grid.ColumnSpan="3"
                                   Text="{Binding ConvCountLabel}"
                                   FontSize="11" Opacity="0.4"
                                   Margin="0,4,0,0"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state -->
        <StackPanel x:Name="EmptyState" Grid.Row="1"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="Collapsed">
            <FontIcon Glyph="&#xE8B7;" FontSize="48" Opacity="0.2"
                      HorizontalAlignment="Center"/>
            <TextBlock Text="还没有项目" FontSize="16" Opacity="0.4"
                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
            <TextBlock Text="项目可以关联多个对话，设置专属指令和知识库"
                       FontSize="13" Opacity="0.3"
                       HorizontalAlignment="Center" Margin="0,4,0,0"
                       TextWrapping="Wrap" TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
