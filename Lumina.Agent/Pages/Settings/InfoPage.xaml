<Page
    x:Class="yanshuai.InfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid"
          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18,20,18,24">

                <!-- ═══ 顶部品牌区 ═══════════════════════════════════════════ -->
                <Grid Margin="0,4,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 头像 96×96，Uniform 不裁剪 -->
                    <Border Grid.Column="0"
                            Width="96" Height="96"
                            CornerRadius="6"
                            BorderBrush="{ThemeResource SystemAccentColor}"
                            BorderThickness="1.5"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <ImageBrush x:Name="AvatarBrush"
                                        ImageSource="Assets/UserAvatar.jpg"
                                        Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="言枢 AI"
                                   FontSize="32" FontWeight="Light"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="AI 对话助手 · 适配 Windows 10 Mobile"
                                   FontSize="12" Opacity="0.55"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="VersionLabel" Text="v3.0.0.0"
                                   FontSize="11" Opacity="0.4"/>
                    </StackPanel>
                </Grid>

                <!-- ═══ 开发者卡片 ══════════════════════════════════════════ -->
                <Border Background="{ThemeResource SystemControlBackgroundListLowBrush}"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,12"
                        Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,14,0">
                            <TextBlock x:Name="UserName" Text="成分复杂"
                                       FontSize="17" FontWeight="SemiBold"/>
                            <TextBlock Text="开发者"
                                       FontSize="11" Opacity="0.5" Margin="0,1,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="UserId" Text="1b4e28ba-2fa1-5f3d-85e5-740e1a5a8a1f"
                                       FontSize="11" Opacity="0.55"
                                       FontFamily="Consolas, Courier New"
                                       IsTextSelectionEnabled="True"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ 致谢 / Credits ═══════════════════════════════════════ -->
                <TextBlock Text="致谢"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource SystemAccentColor}"
                           CharacterSpacing="80"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="{ThemeResource SystemAccentColor}"
                        BorderThickness="0,0,0,1" Opacity="0.35"
                        Margin="0,0,0,10"/>

                <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22" Margin="0,0,0,4">
                    <Run Text="•  原项目 "/>
                    <Run Text="Lumina.Agent" FontFamily="Consolas, Courier New"/>
                    <Run Text="  ——  Windows 10 Mobile 上的 AI 对话客户端，由 " Foreground="{ThemeResource SystemAccentColor}"/>
                    <Run Text="言枢" Foreground="{ThemeResource SystemAccentColor}"/>
                    <Run Text=" 维护与扩展。" Foreground="{ThemeResource SystemAccentColor}"/>
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22" Margin="0,4,0,18">
                    <Run Text="•  AI 回复由用户自行配置的大语言模型接口生成，开发者不提供、不存储任何后端服务。" Foreground="{ThemeResource SystemAccentColor}"/>
                </TextBlock>

                <!-- ═══ 免责声明 ═══════════════════════════════════════════ -->
                <TextBlock Text="免责声明"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource SystemAccentColor}"
                           CharacterSpacing="80"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="{ThemeResource SystemAccentColor}"
                        BorderThickness="0,0,0,1" Opacity="0.35"
                        Margin="0,0,0,10"/>
                <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22" Margin="0,0,0,18"
                           Text="言枢 AI 所提供的对话内容由第三方大语言模型生成，不代表开发者立场。AI 的输出可能存在错误、偏差或不完整的情况，请自行判断其准确性，不应将其作为专业建议的依据。"/>

                <!-- ═══ 使用条款 ═══════════════════════════════════════════ -->
                <TextBlock Text="使用条款"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource SystemAccentColor}"
                           CharacterSpacing="80"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="{ThemeResource SystemAccentColor}"
                        BorderThickness="0,0,0,1" Opacity="0.35"
                        Margin="0,0,0,10"/>
                <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22" Margin="0,0,0,18">
                    <Run Text="•  本软件仅供个人学习与研究使用，禁止用于任何违反法律法规的用途。"/>
                    <LineBreak/>
                    <Run Text="•  用户对通过本软件发起的对话内容及其后果承担全部责任。"/>
                    <LineBreak/>
                    <Run Text="•  本软件不存储、不上传用户的对话内容，所有数据仅保存在本机设备上。"/>
                    <LineBreak/>
                    <Run Text="•  API 密钥由用户自行配置和管理，开发者不对密钥泄露或滥用负责。"/>
                </TextBlock>

                <!-- ═══ 隐私说明 ═══════════════════════════════════════════ -->
                <TextBlock Text="隐私说明"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource SystemAccentColor}"
                           CharacterSpacing="80"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="{ThemeResource SystemAccentColor}"
                        BorderThickness="0,0,0,1" Opacity="0.35"
                        Margin="0,0,0,10"/>
                <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22" Margin="0,0,0,24"
                           Text="本软件不收集任何用户数据，不包含任何遥测或统计功能。对话记录、API 配置等全部信息均以本地文件形式存储于设备上，不会被发送至任何服务器（API 请求除外，该请求由用户自行配置的端点处理）。"/>

                <!-- ═══ 更新日志 ═══════════════════════════════════════════ -->
                <TextBlock Text="更新日志"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource SystemAccentColor}"
                           CharacterSpacing="80"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="{ThemeResource SystemAccentColor}"
                        BorderThickness="0,0,0,1" Opacity="0.35"
                        Margin="0,0,0,10"/>

                <!-- v3.0.0 -->
                <TextBlock Text="v3.0.0  ·  2026" FontSize="13" FontWeight="SemiBold" Margin="0,8,0,6"/>
                <TextBlock TextWrapping="Wrap" FontSize="13" Opacity="0.75" Margin="0,0,0,4" LineHeight="22">
                    <Run Text="🚀 架构飞跃"/><LineBreak/>
                    <Run Text="•  设置页重做为 7 分页 Pivot（通用 / 显示 / 搜索 / 记忆 / 破墙 / 数据 / 关于）"/><LineBreak/>
                    <Run Text="•  记忆系统重构：RAG 向量检索 (rag_search) + 写入式长期记忆 (save_memory) 双轨并行，跨对话共享"/><LineBreak/>
                    <Run Text="•  上下文 auto-compact（OpenCode 风格）：超阈值自动压缩 + 保留原始消息可回看 + Token 进度条"/><LineBreak/>
                    <Run Text="•  子代理系统：spawn_subagent / spawn_subagents 异步后台执行，顶栏 Flyout 查看状态与详情"/><LineBreak/>
                    <Run Text="•  底部统一面板：ask_user 多问题提问（文本/单选/多选/确认），权限申请全部底部弹出"/><LineBreak/>
                    <Run Text="•  新对话附加上下文：设置滑块控制从最近 M 个对话各取 N 条消息注入初始 prompt"/><LineBreak/>
                    <Run Text="•  MCP 服务器管理 + Skills 自定义技能系统"/><LineBreak/>
                    <Run Text="•  项目系统：自定义图标 + 详情页 Pivot + 项目记忆 / 文件管理"/><LineBreak/>
                    <Run Text="•  关于页重做：品牌区 + 开发者卡片 + 致谢 + 新更新日志"/><LineBreak/>
                    <LineBreak/>
                    <Run Text="✨ UI/UX 提升"/><LineBreak/>
                    <Run Text="•  Markdown 渲染全面增强：代码块 header（语言标签/复制/保存）、表格圆角容器 + 内联粗体/代码/链接"/><LineBreak/>
                    <Run Text="•  Token 计数：输入/输出/缓存三列 + 上下文使用率进度条 + 窗口信息"/><LineBreak/>
                    <Run Text="•  侧栏改为: 最近对话 + 最近项目双列表，各限 15 条，对话优先"/><LineBreak/>
                    <Run Text="•  ListView 虚拟化 + 骨架屏：长对话加载性能大幅提升"/><LineBreak/>
                    <Run Text="•  Windows Phone 风格 token bar + MDL2 图标统一"/><LineBreak/>
                    <LineBreak/>
                    <Run Text="🔧 技术改进"/><LineBreak/>
                    <Run Text="•  DataContract 兼容增强：Emoji 中文字体回退链、DateTime 序列化修复"/><LineBreak/>
                    <Run Text="•  API usage 解析 (prompt_tokens/completion_tokens/cached_tokens) 支持 OpenAI + Anthropic 风格"/><LineBreak/>
                    <Run Text="•  子代理线程安全 (Interlocked) + SubagentTracker 全局跟踪"/><LineBreak/>
                </TextBlock>

                <!-- v2.x 历史 -->
                <TextBlock Text="v2.4  —  2026 春" FontSize="13" FontWeight="SemiBold" Margin="0,14,0,6"/>
                <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.65" Margin="0,0,0,4" LineHeight="20">
                    <Run Text="Pivot 设置页 · RAG/记忆系统双轨 · auto-compact · 子代理异步 · 底部面板 · 对话附加上下文 · MCP/Skills · 项目系统 · 关于页重做 · Markdown 增强 · ListView 虚拟化"/>
                </TextBlock>

                <TextBlock Text="v2.0  —  2025" FontSize="13" FontWeight="SemiBold" Margin="0,10,0,6"/>
                <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.65" Margin="0,0,0,4" LineHeight="20">
                    <Run Text="世界书树形分组 · 多选模式重写 · 角色卡 ST V2 扩展 · 对话并行后台生成 · Web 搜索 Bing/百度 · 思考过程动态标签 · 回复声音控制 · 启动行为"/>
                </TextBlock>

                <TextBlock Text="v1.0  —  首发" FontSize="13" FontWeight="SemiBold" Margin="0,10,0,6"/>
                <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.65" Margin="0,0,0,4" LineHeight="20">
                    <Run Text="SplitView 汉堡导航 · 流式 AI 对话 · Markdown 渲染 · 对话分支 · 角色卡/世界书/API 配置管理 · 长期记忆 (自动总结+注入) · SillyTavern 格式导入导出 · 对话外观个性化 · OOBE 引导向导 · 多模态图片上传 · ZIP 备份/恢复 · CommandBar"/>
                </TextBlock>

                <TextBlock Text="移除了 Herobrine。"
                           FontSize="11" Opacity="0.35"
                           Margin="0,32,0,0"
                           HorizontalAlignment="Center"/>

            </StackPanel>
        </ScrollViewer>

    </Grid>

    <Page.BottomAppBar>
        <CommandBar>
            <CommandBar.Content>
                <AppBarButton Icon="Back" Label="" Click="BackButton_Click"/>
            </CommandBar.Content>
        </CommandBar>
    </Page.BottomAppBar>
</Page>
