<Page
    x:Class="yanshuai.SearchSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="14,16,14,8">
            <TextBlock Text="搜索 API 池" FontSize="32" FontWeight="Light"/>
            <TextBlock Text="每次搜索随机挑选一个已启用的条目。内置条目不可删除。"
                       FontSize="12" Opacity="0.5" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- 搜索深度 -->
        <StackPanel Grid.Row="1" Margin="14,0,14,12">
            <TextBlock Text="页面内容完整性" FontSize="12" Opacity="0.5" Margin="0,0,0,6"/>
            <ComboBox x:Name="DepthPicker" HorizontalAlignment="Stretch"
                      SelectionChanged="DepthPicker_SelectionChanged">
                <ComboBoxItem Content="仅摘要（约 2000 字，速度快）"/>
                <ComboBoxItem Content="完整正文（约 8000 字）"/>
                <ComboBoxItem Content="完整页面（不截断，消耗 token 多）"/>
            </ComboBox>
        </StackPanel>

        <!-- 列表 -->
        <ListView x:Name="ApiList" Grid.Row="2"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  IsTabStop="False">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                    <Setter Property="IsTabStop" Value="False"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="0,0,0,1" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="14"/>
                                <TextBlock Text="{Binding TypeLabel}" FontSize="11" Opacity="0.5" Margin="0,2,0,0"/>
                            </StackPanel>
                            <!-- 编辑按钮（自定义条目才显示） -->
                            <Button Grid.Column="1"
                                    Tag="{Binding}"
                                    Click="EditBtn_Click"
                                    Visibility="{Binding CanEdit}"
                                    Background="Transparent"
                                    Padding="10,6" Margin="0,0,4,0"
                                    VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                            </Button>
                            <!-- 启用/禁用开关 -->
                            <ToggleSwitch Grid.Column="2"
                                         IsOn="{Binding Enabled, Mode=TwoWay}"
                                         Toggled="EntryToggle_Toggled"
                                         Tag="{Binding}"
                                         OnContent="" OffContent=""
                                         Margin="0" Padding="0"
                                         VerticalAlignment="Center"
                                         MinWidth="0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>

    <Page.BottomAppBar>
        <CommandBar>
            <AppBarButton Icon="Add" Label="添加" Click="AddBtn_Click"/>
            <CommandBar.Content>
                <AppBarButton Icon="Back" Label="" Click="BackBtn_Click"/>
            </CommandBar.Content>
        </CommandBar>
    </Page.BottomAppBar>
</Page>
