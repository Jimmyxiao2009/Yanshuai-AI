<Page x:Class="yanshuai.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ 顶栏标题 ══════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Margin="14,16,14,12">
            <TextBlock x:Name="PageTitle" Text="设置"
                       FontSize="28" FontWeight="Light"/>
            <TextBlock x:Name="PageSubtitle" Text="偏好与配置"
                       FontSize="12" Opacity="0.5" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- ══ Pivot 主分页 ══════════════════════════════════════════════════ -->
        <Pivot x:Name="MainPivot" Grid.Row="1"
               Margin="0,0,0,0">


            <!-- ─── 1. 通用 ───────────────────────────────────────────────── -->
            <PivotItem x:Name="PivotGeneral">
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE713;" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TabGeneral" Text="通用"/>
                    </StackPanel>
                </PivotItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,8,14,16">

                        <!-- Enter 行为 -->
                        <TextBlock x:Name="EnterBehaviorTitle" Text="Enter 键行为"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,8,0,8"/>
                        <ComboBox x:Name="EnterBehaviorPicker"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,0,0,20"
                                  SelectionChanged="EnterBehaviorPicker_SelectionChanged">
                            <ComboBoxItem Content="Enter 发送，Shift+Enter 换行"/>
                            <ComboBoxItem Content="Enter 换行，Ctrl+Enter 发送"/>
                        </ComboBox>

                        <!-- 启动行为 -->
                        <TextBlock x:Name="StartupBehaviorTitle" Text="启动应用时自动进入"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,8,0,8"/>
                        <ComboBox x:Name="StartupBehaviorPicker"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,0,0,6"
                                  SelectionChanged="StartupBehaviorPicker_SelectionChanged">
                            <ComboBoxItem Content="最近的对话"/>
                            <ComboBoxItem Content="新对话"/>
                            <ComboBoxItem Content="对话列表"/>
                        </ComboBox>
                        <TextBlock x:Name="StartupRestartHint"
                                   Text="✓ 返回主界面后即生效"
                                   FontSize="12"
                                   Foreground="{ThemeResource SystemAccentColor}"
                                   Margin="0,4,0,20"
                                   Visibility="Collapsed"/>

                        <!-- 分隔线 -->
                        <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,0,0,1" Opacity="0.4" Margin="0,4,0,12"/>

                        <!-- 提示音 -->
                        <Grid Margin="0,0,0,12" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="ReplySoundTitle" Text="回复声音" FontSize="15"/>
                                <TextBlock x:Name="ReplySoundDesc" Text="AI 回复完成时播放提示音"
                                           FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="ReplySoundToggle" Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Toggled="ReplySoundToggle_Toggled"
                                          Margin="0,0,-90,0"/>
                        </Grid>

                        <!-- 推理展开 -->
                        <Grid Margin="0,0,0,12" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="ReasoningExpandedTitle" Text="默认展开思考过程" FontSize="15"/>
                                <TextBlock x:Name="ReasoningExpandedDesc" Text="AI 回复完成后自动展开思维链"
                                           FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="ReasoningExpandedToggle" Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Toggled="ReasoningExpandedToggle_Toggled"
                                          Margin="0,0,-90,0"/>
                        </Grid>

                        <!-- API 配置快捷入口 -->
                        <Button HorizontalAlignment="Stretch"
                                Margin="0,16,0,0" Padding="14,10"
                                Click="ApiProfilesBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE713;" FontSize="14" Margin="0,0,10,0"
                                          VerticalAlignment="Center"/>
                                <TextBlock x:Name="ApiProfilesBtn" Text="管理 API 配置"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button HorizontalAlignment="Stretch"
                                Margin="0,8,0,0" Padding="14,10"
                                Click="McpSkillsBtn_Click">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE71A;" FontSize="14" Margin="0,0,10,0"
                                          VerticalAlignment="Center"/>
                                <TextBlock x:Name="McpSkillsBtn" Text="管理 MCP 服务器 / Skills"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,0,0,1" Opacity="0.4" Margin="0,16,0,12"/>

                        <TextBlock x:Name="NewCtxTitle" Text="新对话附加上下文"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <TextBlock x:Name="NewCtxDesc" Text="新建对话时自动附上最近对话的消息作为初始上下文（0=禁用）"
                                   FontSize="12" Opacity="0.45" Margin="0,0,0,8" TextWrapping="Wrap"/>

                        <TextBlock x:Name="NewCtxConvLabel" Text="最近 3 个对话"
                                   FontSize="13" Margin="0,4,0,4"/>
                        <Slider x:Name="NewCtxConvSlider"
                                Minimum="0" Maximum="10" StepFrequency="1"
                                ValueChanged="NewCtxConvSlider_ValueChanged"/>
                        <TextBlock x:Name="NewCtxMsgLabel" Text="每对话取 4 条消息"
                                   FontSize="13" Margin="0,4,0,4"/>
                        <Slider x:Name="NewCtxMsgSlider"
                                Minimum="0" Maximum="20" StepFrequency="1"
                                ValueChanged="NewCtxMsgSlider_ValueChanged"/>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ─── 2. 显示 ───────────────────────────────────────────────── -->
            <PivotItem x:Name="PivotDisplay">
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE7E8;" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TabDisplay" Text="显示"/>
                    </StackPanel>
                </PivotItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,8,14,16">

                        <Grid Margin="0,0,0,12" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="DarkModeLabel" Text="深色模式" FontSize="15"/>
                                <TextBlock x:Name="DarkModeDesc" Text="切换深色/浅色主题"
                                           FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="DarkModeToggle" Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Toggled="DarkModeToggle_Toggled"
                                          Margin="0,0,-90,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,12" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="LangLabel" Text="Language / 语言" FontSize="15"/>
                                <TextBlock x:Name="LangDesc" Text="切换中文 / Switch to English"
                                           FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="LangToggle" Grid.Column="1"
                                          VerticalAlignment="Center"
                                          OnContent="EN" OffContent="中"
                                          Toggled="LangToggle_Toggled"
                                          Margin="0,0,-90,0"/>
                        </Grid>

                        <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,0,0,1" Opacity="0.4" Margin="0,4,0,12"/>

                        <Button HorizontalAlignment="Stretch"
                                Margin="0,8,0,0" Padding="14,10"
                                Tapped="DefaultAppearanceBtn_Tapped">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock x:Name="DefaultAppearanceLabel" Text="默认对话外观" FontSize="15"/>
                                    <TextBlock x:Name="DefaultAppearanceDesc" Text="自定义气泡颜色和背景"
                                               FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                                </StackPanel>
                                <FontIcon Grid.Column="1" Glyph="&#xE76C;" FontSize="13"
                                          Opacity="0.5" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ─── 3. 搜索 ───────────────────────────────────────────────── -->
            <PivotItem x:Name="PivotSearch">
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE721;" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TabSearch" Text="搜索"/>
                    </StackPanel>
                </PivotItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,8,14,16">

                        <TextBlock x:Name="SearchApisTitle" Text="搜索 API 池"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,4,0,6"/>
                        <Button Content="管理搜索 API 池"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,6"
                                Padding="14,10"
                                Click="SearchSettingsBtn_Click"/>
                        <TextBlock x:Name="SearchApisDesc"
                                   Text="配置 SearXNG 实例、DuckDuckGo、Bing API、Tavily 等搜索提供商"
                                   FontSize="12" Opacity="0.5" Margin="0,0,0,20" TextWrapping="Wrap"/>

                        <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,0,0,1" Opacity="0.4" Margin="0,4,0,16"/>

                        <TextBlock x:Name="FetchUATitle" Text="Fetch 请求 User-Agent"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,4,0,8"/>
                        <ComboBox x:Name="FetchUAPicker"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,0,0,6"
                                  SelectionChanged="FetchUAPicker_SelectionChanged">
                            <ComboBoxItem Content="WM10 IE Mobile (Lumia 950)"/>
                            <ComboBoxItem Content="Chrome (Windows)"/>
                            <ComboBoxItem Content="Edge (Windows)"/>
                            <ComboBoxItem Content="Safari (macOS)"/>
                            <ComboBoxItem Content="Firefox (Windows)"/>
                            <ComboBoxItem Content="自定义…"/>
                        </ComboBox>
                        <TextBox x:Name="FetchUACustomBox"
                                 PlaceholderText="输入自定义 User-Agent 字符串"
                                 Margin="0,0,0,6"
                                 Visibility="Collapsed"
                                 TextChanged="FetchUACustomBox_TextChanged"/>
                        <TextBlock x:Name="FetchUAPreview"
                                   FontSize="11" Opacity="0.4"
                                   Margin="0,4,0,12"
                                   TextWrapping="Wrap"/>

                        <TextBlock x:Name="SearchDepthTitle" Text="搜索结果深度"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,8,0,8"/>
                        <ComboBox x:Name="SearchDepthPicker"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,0,0,4"
                                  SelectionChanged="SearchDepthPicker_SelectionChanged">
                            <ComboBoxItem Content="仅摘要"/>
                            <ComboBoxItem Content="完整正文"/>
                            <ComboBoxItem Content="完整页面（含 HTML）"/>
                        </ComboBox>
                        <TextBlock x:Name="SearchDepthDesc"
                                   Text="决定抓取页面时获取多少内容（影响 token 消耗）"
                                   FontSize="12" Opacity="0.5" Margin="0,4,0,8" TextWrapping="Wrap"/>

                        <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,0,0,1" Opacity="0.4" Margin="0,8,0,16"/>

                        <TextBlock x:Name="ToolTurnsTitle" Text="工具调用最大轮次"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,4,0,8"/>
                        <Slider x:Name="ToolTurnsSlider"
                                Minimum="1" Maximum="20" StepFrequency="1"
                                Value="8"
                                Margin="0,0,0,4"
                                ValueChanged="ToolTurnsSlider_ValueChanged"/>
                        <TextBlock x:Name="ToolTurnsLabel" Text="8 轮"
                                   FontSize="12" Opacity="0.55" Margin="0,0,0,8"/>
                        <TextBlock x:Name="ToolTurnsDesc"
                                   Text="单次 AI 回复中最多允许的工具调用次数（多步推理上限）"
                                   FontSize="12" Opacity="0.5" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ─── 4. 记忆 ───────────────────────────────────────────────── -->
            <PivotItem x:Name="PivotRag">
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE8B5;" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TabRag" Text="记忆"/>
                    </StackPanel>
                </PivotItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,8,14,16">

                        <!-- RAG 引擎设置 -->
                        <TextBlock x:Name="RagSettingTitle" Text="RAG 离线索引"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemAccentColor}"
                                   CharacterSpacing="80" Margin="0,0,0,6"/>
                        <Border BorderBrush="{ThemeResource SystemAccentColor}"
                                BorderThickness="0,0,0,1" Opacity="0.35" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,12" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="RagEnabledTitle" Text="启用离线嵌入引擎" FontSize="15"/>
                                <TextBlock x:Name="RagModelStatus" Text="模型: 未加载"
                                           FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="RagEnabledToggle" Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Toggled="RagEnabledToggle_Toggled"
                                          Margin="0,0,-90,0"/>
                        </Grid>

                        <TextBlock x:Name="RagTopKTitle" Text="检索数量 (Top-K)" FontSize="13" Margin="0,4,0,4"/>
                        <Slider x:Name="RagTopKSlider"
                                Minimum="1" Maximum="20" StepFrequency="1"
                                ValueChanged="RagTopKSlider_ValueChanged"/>
                        <TextBlock x:Name="RagTopKLabel" Text="5 条"
                                   FontSize="12" Opacity="0.55" Margin="0,0,0,12"/>

                        <TextBlock x:Name="RagThreshTitle" Text="相似度阈值" FontSize="13" Margin="0,4,0,4"/>
                        <Slider x:Name="RagThreshSlider"
                                Minimum="0.0" Maximum="1.0" StepFrequency="0.05"
                                ValueChanged="RagThreshSlider_ValueChanged"/>
                        <TextBlock x:Name="RagThreshLabel" Text="0.30"
                                   FontSize="12" Opacity="0.55" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,4" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="嵌入模型" FontSize="15"/>
                                <TextBlock x:Name="RagModelDetail" Text="bge-small-zh-v1.5 (512维)"
                                           FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Content="重新加载" Grid.Column="1"
                                    Click="RagReloadModelBtn_Click"
                                    Padding="12,6" FontSize="13"
                                    VerticalAlignment="Center"/>
                        </Grid>

                        <!-- ── RAG 已索引条目列表 ──────────────────────── -->
                        <TextBlock x:Name="RagEntriesTitle" Text="RAG 已索引条目"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemAccentColor}"
                                   CharacterSpacing="80" Margin="0,16,0,6"/>
                        <Border BorderBrush="{ThemeResource SystemAccentColor}"
                                BorderThickness="0,0,0,1" Opacity="0.35" Margin="0,0,0,6"/>

                        <TextBlock x:Name="RagEntriesHint" Text="暂无"
                                   FontSize="12" Opacity="0.45" Margin="0,0,0,4" TextWrapping="Wrap"/>

                        <ListView x:Name="RagEntriesList" SelectionMode="None"
                                  Background="Transparent" BorderThickness="0"
                                  MaxHeight="240" Margin="0,0,0,6">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                            BorderThickness="0,0,0,1" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Text}"
                                                           TextWrapping="Wrap" FontSize="13"
                                                           MaxHeight="40" TextTrimming="WordEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <Border CornerRadius="3"
                                                            Padding="2,1" Margin="0,0,6,0"
                                                            Background="{ThemeResource SystemAccentColor}"
                                                            Opacity="0.75">
                                                        <TextBlock Text="{Binding CategoryLabel}"
                                                                   FontSize="9" Foreground="Black"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding TimeLabel}"
                                                               FontSize="10" Opacity="0.45"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1" Tag="{Binding}"
                                                    Click="RagDeleteEntry_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="32" Height="32" Padding="0">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12" Opacity="0.45"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Button x:Name="RagClearBtn" Content="清除 RAG 索引"
                                Foreground="IndianRed" Background="Transparent"
                                HorizontalAlignment="Left" Padding="12,6" FontSize="12"
                                Click="RagClearBtn_Click"/>

                        <!-- ── 长期记忆（共享）列表 ──────────────────────── -->
                        <TextBlock x:Name="LongMemTitle" Text="长期记忆（共享）"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemAccentColor}"
                                   CharacterSpacing="80" Margin="0,20,0,6"/>
                        <Border BorderBrush="{ThemeResource SystemAccentColor}"
                                BorderThickness="0,0,0,1" Opacity="0.35" Margin="0,0,0,6"/>

                        <TextBlock x:Name="LongMemHint" Text="暂无"
                                   FontSize="12" Opacity="0.45" Margin="0,0,0,4" TextWrapping="Wrap"/>

                        <ListView x:Name="LongMemList" SelectionMode="None"
                                  Background="Transparent" BorderThickness="0"
                                  MaxHeight="280" Margin="0,0,0,6">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                            BorderThickness="0,0,0,1" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Text}"
                                                           TextWrapping="Wrap" FontSize="13"
                                                           MaxHeight="40" TextTrimming="WordEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <Border CornerRadius="3"
                                                            Padding="2,1" Margin="0,0,6,0"
                                                            Background="{ThemeResource SystemAccentColor}"
                                                            Opacity="0.75">
                                                        <TextBlock Text="{Binding CategoryLabel}"
                                                                   FontSize="9" Foreground="Black"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding ImportanceLabel}"
                                                               FontSize="10" Opacity="0.45"
                                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding TimeLabel}"
                                                               FontSize="10" Opacity="0.35"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1" Tag="{Binding}"
                                                    Click="LongMemDelete_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="32" Height="32" Padding="0">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12" Opacity="0.45"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Button x:Name="LongMemClearBtn" Content="清除长期记忆"
                                Foreground="IndianRed" Background="Transparent"
                                HorizontalAlignment="Left" Padding="12,6" FontSize="12"
                                Click="LongMemClearBtn_Click" Margin="0,0,0,24"/>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ─── 5. 破墙 ───────────────────────────────────────────────── -->
            <PivotItem x:Name="PivotJailbreak">
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE72E;" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TabJailbreak" Text="破墙"/>
                    </StackPanel>
                </PivotItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,8,14,16">

                        <Grid Margin="0,0,0,12" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="JailbreakEnabledTitle" Text="全局启用破壁提示词" FontSize="15"/>
                                <TextBlock x:Name="JailbreakEnabledDesc"
                                           Text="对所有 API 配置生效（每个 API 仍可单独覆盖）"
                                           FontSize="12" Opacity="0.55" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="JailbreakEnabledToggle" Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Toggled="JailbreakEnabledToggle_Toggled"
                                          Margin="0,0,-90,0"/>
                        </Grid>

                        <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,0,0,1" Opacity="0.4" Margin="0,4,0,12"/>

                        <TextBlock x:Name="JailbreakPromptTitle" Text="破壁提示词内容"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <TextBox x:Name="JailbreakPromptBox"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="180" MaxHeight="320"
                                 PlaceholderText="在此输入破壁提示词…"
                                 Margin="0,0,0,6"
                                 TextChanged="JailbreakPromptBox_TextChanged"/>
                        <TextBlock x:Name="JailbreakPromptDesc"
                                   Text="系统级指令，会拼接到 system prompt 之前。留空则使用内置默认提示词。"
                                   FontSize="12" Opacity="0.5" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <Button x:Name="JailbreakResetBtn" Content="恢复默认提示词"
                                HorizontalAlignment="Left"
                                Padding="12,6" FontSize="13"
                                Click="JailbreakResetBtn_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ─── 6. 数据 ───────────────────────────────────────────────── -->
            <PivotItem x:Name="PivotData">
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE74E;" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TabData" Text="数据"/>
                    </StackPanel>
                </PivotItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,8,14,16">

                        <TextBlock x:Name="BackupTitle" Text="备份与恢复"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,4,0,6"/>
                        <TextBlock x:Name="BackupDesc"
                                   Text="将所有对话、角色卡、世界书、API 配置打包导出或从备份恢复"
                                   FontSize="12" Opacity="0.5" Margin="0,0,0,12" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="导出备份(.zip)" Click="ExportZip_Click"
                                    Padding="14,8" Margin="0,0,10,0"/>
                            <Button Content="从备份恢复" Click="ImportZip_Click"
                                    Padding="14,8"/>
                        </StackPanel>
                        <TextBlock x:Name="BackupStatus" Text="" FontSize="12" Opacity="0.6"
                                   Margin="0,4,0,20" TextWrapping="Wrap"/>

                        <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,0,0,1" Opacity="0.4" Margin="0,4,0,16"/>

                        <TextBlock x:Name="OobeTitle" Text="引导向导"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,4,0,6"/>
                        <TextBlock x:Name="OobeDesc"
                                   Text="重做首次启动的初始配置流程"
                                   FontSize="12" Opacity="0.5" Margin="0,0,0,12" TextWrapping="Wrap"/>
                        <Button Content="重新进入初始引导向导"
                                Click="ReEnterOobeBtn_Click"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,20" Padding="14,8"/>

                        <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,0,0,1" Opacity="0.4" Margin="0,4,0,16"/>

                        <TextBlock x:Name="DebugTitle" Text="调试"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,4,0,6"/>
                        <Button Content="查看 API 日志"
                                Click="ApiLogBtn_Click"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,8" Padding="14,8"/>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ─── 7. 关于 ───────────────────────────────────────────────── -->
            <PivotItem x:Name="PivotAbout">
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE946;" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TabAbout" Text="关于"/>
                    </StackPanel>
                </PivotItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,8,14,16">

                        <StackPanel Margin="0,8,0,16">
                            <TextBlock x:Name="AboutAppName" Text="言枢"
                                       FontSize="28" FontWeight="Light" Margin="0,0,0,4"/>
                            <TextBlock x:Name="AboutAppSubtitle"
                                       Text="AI 对话助手 · 适配 Windows 10 Mobile"
                                       FontSize="13" Opacity="0.6"/>
                            <TextBlock x:Name="AboutVersion"
                                       Text="Lumina.Agent v1.0"
                                       FontSize="11" Opacity="0.4" Margin="0,4,0,0"/>
                        </StackPanel>

                        <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,0,0,1" Opacity="0.4" Margin="0,4,0,16"/>

                        <TextBlock x:Name="AboutCredits" Text="项目说明"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,4,0,8"/>
                        <TextBlock x:Name="AboutCreditsBody"
                                   Text="言枢 AI 是 Lumina.Agent 项目的延续。原 Lumina.Agent 最初是面向 Windows 10 Mobile 的 AI 对话客户端，由言枢独立维护与扩展。"
                                   FontSize="13" Opacity="0.7" Margin="0,0,0,16" TextWrapping="Wrap"/>

                        <Button x:Name="AboutBtn" Content="关于言枢 AI"
                                Click="OpenWebsiteButton_Click"
                                HorizontalAlignment="Left"
                                Padding="16,8"/>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

        </Pivot>
    </Grid>

    <Page.BottomAppBar>
        <CommandBar>
            <CommandBar.Content>
                <AppBarButton Icon="Back" Label="" Click="BackButton_Click"/>
            </CommandBar.Content>
        </CommandBar>
    </Page.BottomAppBar>
</Page>
