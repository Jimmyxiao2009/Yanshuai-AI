<UserControl
    x:Class="yanshuai.Controls.CharacterCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- 数据上下文 = CardItemViewModel -->
    <Border Width="300"
            Background="{ThemeResource YanshuaiPanelBrush}"
            BorderBrush="{ThemeResource YanshuaiBorderBrush}"
            BorderThickness="1"
            CornerRadius="{ThemeResource YanshuaiControlCornerRadius}"
            Padding="12,10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 头像 -->
            <Grid Grid.Column="0" Width="48" Height="48" VerticalAlignment="Center">
                <Border CornerRadius="24" Background="{ThemeResource YanshuaiSubtlePanelBrush}"/>
                <Border CornerRadius="24" Background="{Binding Avatar}"/>
                <TextBlock Text="?" FontSize="20" Opacity="0.35"
                           Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding PlaceholderVisibility}"/>
            </Grid>

            <!-- 文本 -->
            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Name}"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{ThemeResource YanshuaiTextBrush}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Subtitle}"
                           FontSize="12" Opacity="0.5"
                           Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,2,0,0"/>
                <TextBlock Text="{Binding ConvCountText}"
                           Visibility="{Binding ConvCountVisibility}"
                           FontSize="11" Opacity="0.45"
                           Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- 角标：置顶 / R18G -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                <FontIcon Glyph="&#xE840;" FontFamily="Segoe MDL2 Assets"
                          FontSize="12" Margin="0,0,6,0"
                          Foreground="{ThemeResource YanshuaiAccentBrush}"
                          Visibility="{Binding PinVisibility}"/>
                <Border CornerRadius="3" Padding="4,1"
                        Background="#CCC0392B"
                        Visibility="{Binding R18GVisibility}">
                    <TextBlock Text="R18" FontSize="9" Foreground="White"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
