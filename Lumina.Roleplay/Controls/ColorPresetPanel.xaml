<UserControl
    x:Class="yanshuai.ColorPresetPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel x:Name="PresetStack" Orientation="Horizontal" Margin="18,0,18,10">
        <Button Tag="#000000" Click="Preset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF000000" BorderThickness="1"/>
        <Button Tag="#1E1E1E" Click="Preset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF1E1E1E" BorderThickness="1"/>
        <Button Tag="#1A1A2E" Click="Preset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF1A1A2E" BorderThickness="1"/>
        <Button Tag="#2C3E50" Click="Preset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF2C3E50" BorderThickness="1"/>
        <Button Tag="#F5F0E8" Click="Preset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FFF5F0E8" BorderThickness="1"/>
        <Button Tag="#FFFFFF" Click="Preset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FFFFFFFF" BorderThickness="1"/>
        <Button Tag="#0078D7" Click="Preset_Click" Width="36" Height="36" Margin="0,0,6,0" Padding="0" Background="#FF0078D7" BorderThickness="1"/>
        <Button Tag="#C0392B" Click="Preset_Click" Width="36" Height="36" Margin="0,0,0,0" Padding="0" Background="#FFC0392B" BorderThickness="1"/>
    </StackPanel>
</UserControl>
