<Page
    x:Class="yanshuai.CharaWizardPage1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶栏 -->
        <Grid Grid.Row="0" Background="{ThemeResource YanshuaiPanelBrush}"
              BorderBrush="{ThemeResource YanshuaiBorderBrush}" BorderThickness="0,0,0,1"
              Padding="14,8">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="PageTitle" Text="新建角色卡"
                           FontSize="18" FontWeight="SemiBold" Opacity="0.9"/>
                <TextBlock x:Name="StepText" Text="第 1 步 / 共 4 步  ·  头像与名称"
                           FontSize="12" Opacity="0.5"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="18,18,18,36">

                <!-- 头像区 -->
                <TextBlock x:Name="AvatarLabel" Text="头像" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                    <Border x:Name="AvatarBorder"
                            Width="90" Height="90" CornerRadius="45"
                            Background="{ThemeResource YanshuaiSubtlePanelBrush}"
                            BorderBrush="{ThemeResource YanshuaiAccentBrush}"
                            BorderThickness="2" Margin="0,0,20,0">
                        <Grid>
                            <FontIcon x:Name="AvatarPlaceholder"
                                      Glyph="&#xE77B;" FontSize="40" Opacity="0.55"/>
                            <Image x:Name="AvatarImage"
                                   Stretch="UniformToFill" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <Button x:Name="PickAvatarBtn" Content="选择头像图片"
                                Click="PickAvatarBtn_Click"
                                Padding="20,12" Margin="0,0,0,10"
                                FontSize="15"/>
                        <Button x:Name="ClearAvatarBtn" Content="清除"
                                Click="ClearAvatarBtn_Click"
                                Padding="20,10" FontSize="14"
                                Foreground="Red" Background="Transparent"/>
                    </StackPanel>
                </StackPanel>

                <!-- 名称 -->
                <TextBlock x:Name="NameLabel" Text="角色名称" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="NameBox"
                         PlaceholderText="输入角色名称…"
                         FontSize="16"
                         Padding="12,14"
                         Margin="0,0,0,8"/>

                <!-- 立绘 -->
                <TextBlock x:Name="IllustLabel" Text="立绘图片（可选）" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,8"/>
                <TextBlock x:Name="IllustHint" Text="用于对话背景，建议竖版图片"
                           FontSize="13" Opacity="0.5" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Border x:Name="IllustBorder"
                            Width="70" Height="100" Margin="0,0,16,0"
                            Background="{ThemeResource YanshuaiSubtlePanelBrush}"
                            BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <FontIcon x:Name="IllustPlaceholder"
                                      Glyph="&#xEB9F;" FontSize="28" Opacity="0.3"/>
                            <Image x:Name="IllustImage"
                                   Stretch="UniformToFill" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <Button x:Name="PickIllustBtn" Content="选择立绘" Click="PickIllustBtn_Click"
                                Padding="20,12" Margin="0,0,0,10" FontSize="15"/>
                        <Button x:Name="ClearIllustBtn" Content="清除" Click="ClearIllustBtn_Click"
                                Padding="20,10" FontSize="14"
                                Foreground="Red" Background="Transparent"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton x:Name="NextBtn" Icon="Forward" Label="下一步" Click="NextBtn_Click"/>

        </CommandBar>
    </Grid>
</Page>
