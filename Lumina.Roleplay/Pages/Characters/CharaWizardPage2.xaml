<Page
    x:Class="yanshuai.CharaWizardPage2"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶栏 -->
        <Grid Grid.Row="0" Background="{ThemeResource YanshuaiPanelBrush}"
              BorderBrush="{ThemeResource YanshuaiBorderBrush}" BorderThickness="0,0,0,1"
              Padding="14,8">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="PageTitle" Text="新建角色卡"
                           FontSize="18" FontWeight="SemiBold" Opacity="0.9"/>
                <TextBlock x:Name="StepText" Text="第 2 步 / 共 4 步  ·  描述与性格"
                           FontSize="12" Opacity="0.5"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="18,18,18,36">

                <TextBlock x:Name="DescLabel" Text="描述" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="DescHint" Text="介绍角色的背景、外貌、身份等"
                           FontSize="13" Opacity="0.5" Margin="0,0,0,10"/>
                <TextBox x:Name="DescBox"
                         PlaceholderText="例：一位来自古代的剑客，沉默寡言，却在关键时刻总能挺身而出…"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         FontSize="15" Padding="12,12"
                         Height="130" Margin="0,0,0,28"/>

                <TextBlock x:Name="PersonalityLabel" Text="性格" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="PersonalityHint" Text="角色的个性特点、说话方式"
                           FontSize="13" Opacity="0.5" Margin="0,0,0,10"/>
                <TextBox x:Name="PersonalityBox"
                         PlaceholderText="例：冷静理性，偶尔会流露出温柔，不喜欢拐弯抹角…"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         FontSize="15" Padding="12,12"
                         Height="110" Margin="0,0,0,28"/>

                <TextBlock x:Name="ScenarioLabel" Text="场景（可选）" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="ScenarioHint" Text="对话发生的背景设定"
                           FontSize="13" Opacity="0.5" Margin="0,0,0,10"/>
                <TextBox x:Name="ScenarioBox"
                         PlaceholderText="例：你在一家古朴的茶馆里遇见了他…"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         FontSize="15" Padding="12,12"
                         Height="90"/>

            </StackPanel>
        </ScrollViewer>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton x:Name="NextBtn" Icon="Forward" Label="下一步" Click="NextBtn_Click"/>

        </CommandBar>
    </Grid>
</Page>
