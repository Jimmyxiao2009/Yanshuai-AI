<Page
    x:Class="yanshuai.CharaWizardPage4"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶栏：心象点 + 标题（站酷小薇） + 步骤指示器 -->
        <StackPanel Grid.Row="0" Background="{ThemeResource YanshuaiChromeBrush}"
                    Padding="{StaticResource PagePadding}">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="9" Height="9" Fill="{ThemeResource YanshuaiAccentBrush}"
                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock x:Name="PageTitleBlock" Text="新建角色卡"
                           FontFamily="{ThemeResource YanshuaiTitleFont}" FontSize="30"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource YanshuaiTextBrush}"/>
            </StackPanel>

            <!-- 步骤进度条（第 4 步：四段全为心象色） -->
            <StackPanel Orientation="Horizontal" Margin="0,14,0,2">
                <Rectangle Width="40" Height="3" RadiusX="1.5" RadiusY="1.5"
                           Fill="{ThemeResource YanshuaiAccentBrush}" Margin="0,0,6,0"/>
                <Rectangle Width="40" Height="3" RadiusX="1.5" RadiusY="1.5"
                           Fill="{ThemeResource YanshuaiAccentBrush}" Margin="0,0,6,0"/>
                <Rectangle Width="40" Height="3" RadiusX="1.5" RadiusY="1.5"
                           Fill="{ThemeResource YanshuaiAccentBrush}" Margin="0,0,6,0"/>
                <Rectangle Width="40" Height="3" RadiusX="1.5" RadiusY="1.5"
                           Fill="{ThemeResource YanshuaiAccentBrush}"/>
            </StackPanel>
            <TextBlock x:Name="StepText" Text="第 4 步 / 共 4 步  ·  开场白"
                       Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="{StaticResource PagePadding}" Padding="0,4,0,40">

                <TextBlock x:Name="FirstMsgLabel" Text="开场白"
                           Style="{StaticResource LabelTextStyle}" Margin="0,0,0,6"/>
                <TextBlock x:Name="FirstMsgHint" Text="对话开始时角色发送的第一条消息"
                           Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,10"/>
                <TextBox x:Name="FirstMsgBox"
                         PlaceholderText="例：（抬眸看你一眼，随即收回目光）你找我有何要事？"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         FontFamily="{ThemeResource YanshuaiVoiceFont}"
                         FontSize="{StaticResource FontSizeBodyLarge}" Padding="12,12"
                         Height="180" Margin="0,0,0,12"/>

                <TextBlock x:Name="FirstMsgNote" Text="留空则对话开始时不显示开场白，可随时在角色卡编辑页修改"
                           Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap"/>

                <!-- 预览区：开场白以文楷气泡形式呈现 -->
                <StackPanel x:Name="PreviewPanel" Visibility="Collapsed" Margin="0,24,0,0">
                    <TextBlock x:Name="PreviewLabel" Text="预览"
                               Style="{StaticResource LabelTextStyle}" Margin="0,0,0,10"/>
                    <Border Background="{ThemeResource YanshuaiAiBubbleBrush}"
                            BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14,14,14,4"
                            Padding="18,14">
                        <TextBlock x:Name="PreviewText" TextWrapping="Wrap"
                                   FontFamily="{ThemeResource YanshuaiVoiceFont}"
                                   FontSize="{StaticResource FontSizeBodyLarge}" LineHeight="24"
                                   Foreground="{ThemeResource YanshuaiTextBrush}"/>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton x:Name="FinishBtn" Icon="Accept" Label="完成" Click="FinishBtn_Click"/>

        </CommandBar>
    </Grid>
</Page>
