<Page
    x:Class="yanshuai.CharaWizardPage4"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶栏 -->
        <Grid Grid.Row="0" Background="{ThemeResource YanshuaiPanelBrush}"
              BorderBrush="{ThemeResource YanshuaiBorderBrush}" BorderThickness="0,0,0,1"
              Padding="14,8">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="PageTitleBlock" Text="新建角色卡"
                           FontSize="18" FontWeight="SemiBold" Opacity="0.9"/>
                <TextBlock x:Name="StepText" Text="第 4 步 / 共 4 步  ·  开场白"
                           FontSize="12" Opacity="0.5"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="18,18,18,36">

                <TextBlock x:Name="FirstMsgLabel" Text="开场白" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="FirstMsgHint" Text="对话开始时角色发送的第一条消息"
                           FontSize="13" Opacity="0.5" Margin="0,0,0,10"/>
                <TextBox x:Name="FirstMsgBox"
                         PlaceholderText="例：（抬眸看你一眼，随即收回目光）你找我有何要事？"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         FontSize="15" Padding="12,12"
                         Height="180" Margin="0,0,0,28"/>

                <TextBlock x:Name="FirstMsgNote" Text="留空则对话开始时不显示开场白，可随时在角色卡编辑页修改"
                           FontSize="13" Opacity="0.45" TextWrapping="Wrap"/>

                <!-- 预览区 -->
                <StackPanel x:Name="PreviewPanel" Visibility="Collapsed" Margin="0,24,0,0">
                    <TextBlock x:Name="PreviewLabel" Text="预览" FontSize="14" FontWeight="SemiBold"
                               Opacity="0.7" Margin="0,0,0,10"/>
                    <Border Background="{ThemeResource YanshuaiSurfaceBrush}"
                            Padding="18,14">
                        <TextBlock x:Name="PreviewText" TextWrapping="Wrap"
                                   FontSize="15" Opacity="0.85"/>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton x:Name="FinishBtn" Icon="Accept" Label="完成" Click="FinishBtn_Click"/>

        </CommandBar>
    </Grid>
</Page>
