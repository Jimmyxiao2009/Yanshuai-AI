<Page x:Class="yanshuai.CharacterCardsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:yanshuai"
      xmlns:controls="using:yanshuai.Controls">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 页眉：心象点 + 标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="18,22,18,10">
            <Ellipse Width="9" Height="9" Fill="{ThemeResource YanshuaiAccentBrush}"
                     VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock x:Name="PageTitle" Text="角色卡"
                       FontFamily="{ThemeResource YanshuaiTitleFont}"
                       FontSize="30"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource YanshuaiTextBrush}"/>
        </StackPanel>

        <!-- 角色卡网格（绑定 + 分组 + 自适应列；多选用 GridView 原生选择） -->
        <GridView x:Name="CardsGrid" Grid.Row="1"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="Card_ItemClick"
                  SelectionChanged="Cards_SelectionChanged"
                  RightTapped="Cards_RightTapped"
                  Holding="Cards_Holding"
                  Padding="14,4,14,30">
            <GridView.ItemTemplate>
                <DataTemplate>
                    <controls:CharacterCardView/>
                </DataTemplate>
            </GridView.ItemTemplate>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Padding" Value="6"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="8,14,0,6">
                                <Rectangle Width="3" Height="15" RadiusX="1.5" RadiusY="1.5"
                                           Fill="{ThemeResource YanshuaiAccentBrush}"
                                           VerticalAlignment="Center" Margin="0,0,9,0"/>
                                <TextBlock Text="{Binding Key}"
                                           FontFamily="{ThemeResource YanshuaiTitleFont}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource YanshuaiTextBrush}"/>
                                <TextBlock Text="{Binding CardCount}"
                                           FontSize="12" Opacity="{StaticResource OpacitySubtle}" Margin="9,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource YanshuaiMutedTextBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </GridView.GroupStyle>
        </GridView>

        <!-- 空状态 -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding EmptyVisibility}">
            <Border Width="84" Height="84" CornerRadius="42" HorizontalAlignment="Center"
                    Background="{ThemeResource YanshuaiAccentWashBrush}"
                    BorderBrush="{ThemeResource YanshuaiAccentBrush}" BorderThickness="1">
                <FontIcon Glyph="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                          FontSize="32"
                          Foreground="{ThemeResource YanshuaiAccentBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="EmptyLabel" Margin="0,16,0,0"
                       FontSize="14" Opacity="{StaticResource OpacitySubtle}"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource YanshuaiMutedTextBrush}"/>
        </StackPanel>

        <!-- 底部操作栏：内容内 CommandBar（RowSpan 铺满 + 底部对齐，叠在内容底部，与原 Page.BottomAppBar 视觉/行为一致）。
             不再用 Page.BottomAppBar——后者会让 UWP 在窄屏把 AppBar 调起手柄浮到窗口顶部中间遮住汉堡按钮。
             不指定 Background，沿用随主题自适应的 CommandBar 默认底色。 -->
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <!-- 普通模式 -->
            <AppBarButton x:Name="AddBtn"       Icon="Add"      Label="新建角色" Click="AddButton_Click"/>
            <AppBarButton x:Name="ImportBtn"     Icon="Download" Label="导入"     Click="ImportChara_Click"/>
            <AppBarButton x:Name="SelectBtn"     Icon="Bullets"  Label="多选"     Click="ToggleSelectMode_Click"/>
            <!-- 多选模式 -->
            <AppBarButton x:Name="ToggleAllBtn"    Icon="SelectAll" Label="全选"   Visibility="Collapsed" Click="ToggleAll_Click"/>
            <AppBarButton x:Name="MoveGroupBtn"    Icon="MoveToFolder" Label="分组" Visibility="Collapsed" IsEnabled="False" Click="MoveGroup_Click"/>
            <AppBarButton x:Name="ExportSelectBtn" Icon="Save"      Label="导出"   Visibility="Collapsed" IsEnabled="False" Click="ExportSelected_Click"/>
            <AppBarButton x:Name="DeleteSelectBtn" Icon="Delete"    Label="删除"   Visibility="Collapsed" IsEnabled="False" Click="DeleteSelected_Click"/>
            <AppBarButton x:Name="CancelSelectBtn" Icon="Cancel"    Label="取消"   Visibility="Collapsed" Click="ToggleSelectMode_Click"/>
        </CommandBar>
    </Grid>
</Page>
