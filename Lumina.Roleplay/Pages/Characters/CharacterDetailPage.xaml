<Page x:Class="yanshuai.CharacterDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:yanshuai">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶栏 -->
        <Grid Grid.Row="0" Background="{ThemeResource YanshuaiPanelBrush}"
              BorderBrush="{ThemeResource YanshuaiBorderBrush}" BorderThickness="0,0,0,1"
              Padding="14,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="角色详情" FontSize="18" FontWeight="SemiBold"
                       VerticalAlignment="Center" Opacity="0.9"/>
            <Button x:Name="R18GToggleBtn" Grid.Column="1" Click="R18GToggle_Click"
                    Background="Transparent" BorderThickness="0"
                    Width="48" Height="48" Padding="0"
                    ToolTipService.ToolTip="切换 R18G 标注">
                <FontIcon Glyph="&#xE7FB;" FontSize="16" Opacity="0.7"/>
            </Button>
            <Button Grid.Column="2" Click="EditCharaBtn_Click" Background="Transparent"
                    BorderThickness="0" Width="48" Height="48" Padding="0"
                    ToolTipService.ToolTip="编辑角色卡">
                <FontIcon Glyph="&#xE70F;" FontSize="16" Opacity="0.7"/>
            </Button>
        </Grid>

        <!-- 角色头部：头像 + 名称 + 简介 -->
        <StackPanel Grid.Row="1" Margin="18,16,18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="AvatarBorder"
                        Grid.Column="0"
                        Width="72" Height="72"
                        CornerRadius="36"
                        Background="#44FFFFFF"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1">
                    <TextBlock x:Name="AvatarPlaceholder"
                               Text="?"
                               FontSize="28"
                               Opacity="0.3"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="CharaNameText"
                               FontSize="24" FontWeight="Light" Opacity="0.95"/>
                    <TextBlock x:Name="CharaGroupText"
                               FontSize="13" Opacity="0.45"
                               Margin="0,3,0,0"/>
                    <TextBlock x:Name="SelectionStatusText"
                               FontSize="12"
                               Opacity="0.65"
                               Margin="0,4,0,0"/>
                    <Border x:Name="R18GBadge" Visibility="Collapsed"
                            Background="#CCFF4444" CornerRadius="4"
                            Padding="6,2" Margin="0,4,0,0"
                            HorizontalAlignment="Left">
                        <TextBlock Text="R18G" FontSize="11"
                                   FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="CharaDescText"
                       FontSize="13" Opacity="0.6"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"
                       MaxLines="4"/>
            <Border x:Name="IllustrationFrame"
                    Visibility="Collapsed"
                    Height="180"
                    CornerRadius="6"
                    Margin="0,12,0,0"
                    Background="{ThemeResource YanshuaiPanelBrush}"
                    BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                    BorderThickness="1">
                <Image x:Name="IllustrationImage"
                       Stretch="UniformToFill"/>
            </Border>
        </StackPanel>

        <!-- 分隔线 -->
        <Border Grid.Row="2"
                Background="{ThemeResource YanshuaiBorderBrush}"
                Height="1" Opacity="0.4"
                Margin="18,0"/>

        <!-- 对话区（旧称对话池） -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 对话池表头 — 可点击进入记忆编辑 -->
            <Button Grid.Row="0"
                    Click="MemoryHeader_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalAlignment="Stretch"
                    Height="44"
                    Padding="18,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               x:Name="PoolTitleText"
                               Text="对话池"
                               FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Opacity="0.8"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE945;" FontSize="13" Opacity="0.4"
                                  Margin="0,0,6,0"/>
                        <TextBlock Text="记忆库"
                                   FontSize="12" Opacity="0.4"
                                   VerticalAlignment="Center"/>
                        <FontIcon Glyph="&#xE76C;" FontSize="12" Opacity="0.55"
                                  Margin="6,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Button>

            <!-- 对话列表 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ConvContainer" Margin="14,4,14,30"/>
            </ScrollViewer>
        </Grid>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton Icon="Add" Label="开始对话" Click="NewConvAppBarBtn_Click"/>
            <AppBarButton Icon="Save" Label="导出" Click="ExportBtn_Click"/>
        </CommandBar>
    </Grid>
</Page>
