<Page x:Class="yanshuai.CharacterDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:yanshuai">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶栏：返回区为空，仅图标操作（编辑 / R18G）通过 IconButtonStyle -->
        <Grid Grid.Row="0" Background="{ThemeResource YanshuaiChromeBrush}"
              Padding="16,8,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" Fill="{ThemeResource YanshuaiAccentBrush}"
                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="角色详情"
                           FontFamily="{ThemeResource YanshuaiTitleFont}" FontSize="22"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource YanshuaiTextBrush}"/>
            </StackPanel>
            <Button x:Name="R18GToggleBtn" Grid.Column="1" Click="R18GToggle_Click"
                    Style="{StaticResource IconButtonStyle}"
                    Width="40" Height="40"
                    ToolTipService.ToolTip="切换 R18G 标注">
                <FontIcon Glyph="&#xE7FB;" FontSize="16"
                          Foreground="{ThemeResource YanshuaiTextBrush}"
                          Opacity="{StaticResource OpacityMuted}"/>
            </Button>
            <Button Grid.Column="2" Click="EditCharaBtn_Click"
                    Style="{StaticResource IconButtonStyle}"
                    Width="40" Height="40"
                    ToolTipService.ToolTip="编辑角色卡">
                <FontIcon Glyph="&#xE70F;" FontSize="16"
                          Foreground="{ThemeResource YanshuaiTextBrush}"
                          Opacity="{StaticResource OpacityMuted}"/>
            </Button>
        </Grid>

        <!-- 角色头部（主角区）：头像 + 名称（站酷小薇大字） + 简介 + 立绘 -->
        <StackPanel Grid.Row="1" Margin="18,18,18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 主角头像：心象环 -->
                <Border x:Name="AvatarBorder"
                        Grid.Column="0"
                        Width="92" Height="92"
                        CornerRadius="46"
                        Background="{ThemeResource YanshuaiAccentWashBrush}"
                        BorderBrush="{ThemeResource YanshuaiAccentBrush}"
                        BorderThickness="1.5">
                    <TextBlock x:Name="AvatarPlaceholder"
                               Text="?"
                               FontSize="34"
                               Foreground="{ThemeResource YanshuaiAccentBrush}"
                               Opacity="{StaticResource OpacityFaint}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                    <!-- 角色名：标题字体，主角 -->
                    <TextBlock x:Name="CharaNameText"
                               FontFamily="{ThemeResource YanshuaiTitleFont}"
                               FontSize="30"
                               Foreground="{ThemeResource YanshuaiTextBrush}"/>
                    <TextBlock x:Name="CharaGroupText"
                               Style="{StaticResource CaptionTextStyle}"
                               Margin="0,4,0,0"/>
                    <TextBlock x:Name="SelectionStatusText"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                               Opacity="{StaticResource OpacityMuted}"
                               Margin="0,4,0,0"/>
                    <!-- R18G 标记：用心象徽章而非刺眼红色 -->
                    <Border x:Name="R18GBadge" Visibility="Collapsed"
                            Background="{ThemeResource YanshuaiAccentBrush}"
                            CornerRadius="{StaticResource PillCornerRadius}"
                            Padding="9,2" Margin="0,6,0,0"
                            HorizontalAlignment="Left">
                        <TextBlock Text="R18G" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource YanshuaiOnAccentBrush}"/>
                    </Border>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="CharaDescText"
                       FontFamily="{ThemeResource YanshuaiVoiceFont}"
                       FontSize="{StaticResource FontSizeBodyLarge}" LineHeight="23"
                       Foreground="{ThemeResource YanshuaiTextBrush}"
                       Opacity="{StaticResource OpacityMuted}"
                       TextWrapping="Wrap"
                       Margin="0,14,0,0"
                       MaxLines="4"/>
            <!-- 立绘：作为主角视觉，圆角更大 -->
            <Border x:Name="IllustrationFrame"
                    Visibility="Collapsed"
                    Height="200"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Margin="0,14,0,0"
                    Background="{ThemeResource YanshuaiPanelBrush}"
                    BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                    BorderThickness="1">
                <Image x:Name="IllustrationImage"
                       Stretch="UniformToFill"/>
            </Border>
        </StackPanel>

        <!-- 分隔线 -->
        <Border Grid.Row="2"
                Background="{ThemeResource YanshuaiBorderBrush}"
                Height="1" Opacity="{StaticResource OpacityFaint}"
                Margin="18,0"/>

        <!-- 对话区（旧称对话池） -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 对话池表头 — 可点击进入记忆编辑 -->
            <Button Grid.Row="0"
                    Click="MemoryHeader_Click"
                    Style="{StaticResource GhostButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Height="48"
                    Padding="18,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- 心象竖条标记 -->
                    <Rectangle Grid.Column="0" Width="3" Height="15" RadiusX="1.5" RadiusY="1.5"
                               Fill="{ThemeResource YanshuaiAccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               x:Name="PoolTitleText"
                               Text="对话池"
                               FontFamily="{ThemeResource YanshuaiTitleFont}"
                               FontSize="15"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource YanshuaiTextBrush}"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE945;" FontSize="13"
                                  Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                                  Opacity="{StaticResource OpacityFaint}"
                                  Margin="0,0,6,0"/>
                        <TextBlock Text="记忆库"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                                   Opacity="{StaticResource OpacityFaint}"
                                   VerticalAlignment="Center"/>
                        <FontIcon Glyph="&#xE76C;" FontSize="12"
                                  Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                                  Opacity="{StaticResource OpacitySubtle}"
                                  Margin="6,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Button>

            <!-- 对话列表 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ConvContainer" Margin="14,4,14,30"/>
            </ScrollViewer>
        </Grid>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton Icon="Add" Label="开始对话" Click="NewConvAppBarBtn_Click"/>
            <AppBarButton Icon="Save" Label="导出" Click="ExportBtn_Click"/>
        </CommandBar>
    </Grid>
</Page>
