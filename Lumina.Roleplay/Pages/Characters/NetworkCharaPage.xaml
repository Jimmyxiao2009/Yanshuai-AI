<Page x:Class="yanshuai.NetworkCharaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:yanshuai">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ 顶栏：搜索 + URL导入 + 设置 ═══ -->
        <Grid Grid.Row="0" Background="{ThemeResource YanshuaiChromeBrush}"
              Padding="14,10,8,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 搜索栏：圆角胶囊 + 内嵌搜索图标按钮 -->
            <Border Grid.Column="0"
                    Background="{ThemeResource YanshuaiSurfaceBrush}"
                    BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource PillCornerRadius}"
                    Padding="2,2,2,2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchInput" Grid.Column="0"
                             PlaceholderText="搜索角色卡..."
                             Background="Transparent" BorderThickness="0"
                             Padding="12,7" MinHeight="36" AcceptsReturn="False"
                             VerticalAlignment="Center"
                             KeyDown="SearchInput_KeyDown"/>
                    <Button x:Name="SearchBtn" Grid.Column="1"
                            Style="{StaticResource IconButtonStyle}"
                            Width="38" Height="36"
                            VerticalAlignment="Center"
                            Click="SearchBtn_Click"
                            ToolTipService.ToolTip="搜索">
                        <FontIcon Glyph="&#xE721;" FontSize="14"
                                  Foreground="{ThemeResource YanshuaiAccentBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- URL 导入 -->
            <Button Grid.Column="1" Margin="6,0,0,0"
                    Style="{StaticResource IconButtonStyle}"
                    Width="40" Height="40"
                    ToolTipService.ToolTip="粘贴链接导入">
                <FontIcon Glyph="&#xE71B;" FontSize="16"
                          Foreground="{ThemeResource YanshuaiTextBrush}"
                          Opacity="{StaticResource OpacityMuted}"/>
                <Button.Flyout>
                    <Flyout x:Name="UrlFlyout">
                        <StackPanel Width="280">
                            <TextBlock Text="粘贴角色卡链接"
                                       FontFamily="{ThemeResource YanshuaiTitleFont}"
                                       FontSize="{StaticResource FontSizeSubtitle}"
                                       Foreground="{ThemeResource YanshuaiTextBrush}"/>
                            <TextBlock Text="自动识别 Chub/花屿/星野/云酒馆/电子魅魔 等"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,4,0,8" TextWrapping="Wrap"/>
                            <TextBox x:Name="UrlInput"
                                     PlaceholderText="https://..."
                                     Padding="10,8" AcceptsReturn="False"
                                     Margin="0,0,0,8"/>
                            <Button x:Name="UrlDownloadBtn" Content="下载并预览"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Click="UrlDownloadBtn_Click"/>
                            <StackPanel x:Name="UrlResultPanel"/>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>

            <!-- 设置 -->
            <Button Grid.Column="2" Margin="4,0,0,0"
                    Style="{StaticResource IconButtonStyle}"
                    Width="40" Height="40"
                    ToolTipService.ToolTip="平台开关">
                <FontIcon Glyph="&#xE713;" FontSize="16"
                          Foreground="{ThemeResource YanshuaiTextBrush}"
                          Opacity="{StaticResource OpacityMuted}"/>
                <Button.Flyout>
                    <Flyout x:Name="SettingsFlyout">
                        <StackPanel Width="240">
                            <TextBlock Text="平台开关"
                                       Style="{StaticResource LabelTextStyle}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="关闭后该平台不出现在信息流和搜索中"
                                       Style="{StaticResource CaptionTextStyle}"
                                       Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <ToggleSwitch x:Name="ToggleChub" Header="Chub.ai"
                                          Tag="chub" Toggled="SourceToggle_Toggled"/>
                            <ToggleSwitch x:Name="ToggleHuayu" Header="花屿"
                                          Tag="huayu" Toggled="SourceToggle_Toggled"/>
                            <ToggleSwitch x:Name="ToggleXingye" Header="星野"
                                          Tag="xingye" Toggled="SourceToggle_Toggled"/>
                            <ToggleSwitch x:Name="ToggleQuack" Header="云酒馆"
                                          Tag="quack" Toggled="SourceToggle_Toggled"/>
                            <ToggleSwitch x:Name="ToggleDzmm" Header="电子魅魔"
                                          Tag="dzmm" Toggled="SourceToggle_Toggled"/>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <!-- ═══ 信息流 ═══ -->
        <ScrollViewer x:Name="FeedScrollViewer" Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      ViewChanged="FeedScrollViewer_ViewChanged">
            <StackPanel Margin="10,10,10,30">
                <TextBlock x:Name="FeedStatusText"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                           Opacity="{StaticResource OpacityFaint}"
                           Margin="0,4,0,8" Visibility="Collapsed"
                           HorizontalAlignment="Center" TextWrapping="Wrap"/>

                <Grid x:Name="FeedCardContainer">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel x:Name="FeedCol0" Grid.Column="0" Margin="0,0,3,0"/>
                    <StackPanel x:Name="FeedCol1" Grid.Column="1" Margin="3,0,0,0"/>
                </Grid>

                <Button x:Name="LoadMoreBtn" Content="加载更多"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalAlignment="Stretch" Margin="0,12,0,0"
                        Padding="14,12"
                        Visibility="Collapsed"
                        Click="LoadMoreBtn_Click"/>

                <ProgressRing x:Name="FeedLoadingRing"
                              Width="32" Height="32"
                              Margin="0,16,0,16"
                              HorizontalAlignment="Center"
                              IsActive="False" Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>