<Page x:Class="yanshuai.NetworkCharaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:yanshuai">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ 顶栏：返回 + 搜索 + URL导入 + 设置 ═══ -->
        <Grid Grid.Row="0" Background="{ThemeResource YanshuaiPanelBrush}"
              BorderBrush="{ThemeResource YanshuaiBorderBrush}" BorderThickness="0,0,0,1"
              Padding="2,4,2,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 搜索栏 -->
            <Grid Grid.Column="0" Margin="2,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchInput" Grid.Column="0"
                         PlaceholderText="搜索角色卡..."
                         Padding="10,7" MinHeight="38" AcceptsReturn="False"
                         VerticalAlignment="Center"
                         KeyDown="SearchInput_KeyDown"/>
                <Button x:Name="SearchBtn" Grid.Column="1"
                        MinHeight="38" Margin="4,0,0,0" Padding="12,7" BorderThickness="0"
                        VerticalAlignment="Center"
                        Background="{ThemeResource YanshuaiAccentBrush}"
                        Foreground="White"
                        Click="SearchBtn_Click">
                    <FontIcon Glyph="&#xE721;" FontSize="14"/>
                </Button>
            </Grid>

            <!-- URL 导入 -->
            <Button Grid.Column="1" Background="Transparent"
                    BorderThickness="0" Width="44" Height="44" Padding="0">
                <FontIcon Glyph="&#xE71B;" FontSize="16" Opacity="0.7"/>
                <Button.Flyout>
                    <Flyout x:Name="UrlFlyout">
                        <StackPanel Width="280">
                            <TextBlock Text="粘贴角色卡链接" FontSize="14"
                                       FontWeight="SemiBold" Opacity="0.8"/>
                            <TextBlock Text="自动识别 Chub/花屿/星野/云酒馆/电子魅魔 等"
                                       FontSize="11" Opacity="0.4" TextWrapping="Wrap"/>
                            <TextBox x:Name="UrlInput"
                                     PlaceholderText="https://..."
                                     Padding="10,8" AcceptsReturn="False"/>
                            <Button x:Name="UrlDownloadBtn" Content="下载并预览"
                                    Background="{ThemeResource YanshuaiAccentBrush}"
                                    Foreground="White" BorderThickness="0"
                                    Padding="14,8" HorizontalAlignment="Stretch"
                                    Click="UrlDownloadBtn_Click"/>
                            <StackPanel x:Name="UrlResultPanel"/>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>

            <!-- 设置 -->
            <Button Grid.Column="2" Background="Transparent"
                    BorderThickness="0" Width="44" Height="44" Padding="0">
                <FontIcon Glyph="&#xE713;" FontSize="16" Opacity="0.7"/>
                <Button.Flyout>
                    <Flyout x:Name="SettingsFlyout">
                        <StackPanel Width="240">
                            <TextBlock Text="平台开关" FontSize="14"
                                       FontWeight="SemiBold" Opacity="0.8"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="关闭后该平台不出现在信息流和搜索中"
                                       FontSize="11" Opacity="0.4" Margin="0,0,0,8"
                                       TextWrapping="Wrap"/>
                            <ToggleSwitch x:Name="ToggleChub" Header="Chub.ai"
                                          Tag="chub" Toggled="SourceToggle_Toggled"/>
                            <ToggleSwitch x:Name="ToggleHuayu" Header="花屿"
                                          Tag="huayu" Toggled="SourceToggle_Toggled"/>
                            <ToggleSwitch x:Name="ToggleXingye" Header="星野"
                                          Tag="xingye" Toggled="SourceToggle_Toggled"/>
                            <ToggleSwitch x:Name="ToggleQuack" Header="云酒馆"
                                          Tag="quack" Toggled="SourceToggle_Toggled"/>
                            <ToggleSwitch x:Name="ToggleDzmm" Header="电子魅魔"
                                          Tag="dzmm" Toggled="SourceToggle_Toggled"/>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <!-- ═══ 信息流 ═══ -->
        <ScrollViewer x:Name="FeedScrollViewer" Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      ViewChanged="FeedScrollViewer_ViewChanged">
            <StackPanel Margin="10,8,10,30">
                <TextBlock x:Name="FeedStatusText" FontSize="12" Opacity="0.4"
                           Margin="0,4,0,6" Visibility="Collapsed"
                           HorizontalAlignment="Center" TextWrapping="Wrap"/>

                <Grid x:Name="FeedCardContainer">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel x:Name="FeedCol0" Grid.Column="0" Margin="0,0,3,0"/>
                    <StackPanel x:Name="FeedCol1" Grid.Column="1" Margin="3,0,0,0"/>
                </Grid>

                <Button x:Name="LoadMoreBtn" Content="加载更多"
                        HorizontalAlignment="Stretch" Margin="0,8,0,0"
                        Padding="14,12" BorderThickness="0"
                        Background="{ThemeResource YanshuaiAccentBrush}"
                        Foreground="White" Visibility="Collapsed"
                        Click="LoadMoreBtn_Click"/>

                <ProgressRing x:Name="FeedLoadingRing"
                              Width="32" Height="32"
                              Margin="0,16,0,16"
                              HorizontalAlignment="Center"
                              IsActive="False" Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>