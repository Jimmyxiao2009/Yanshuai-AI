<Page x:Class="yanshuai.NetworkCharaPreviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ 顶栏 ═══ -->
        <Grid Grid.Row="0" Background="{ThemeResource YanshuaiPanelBrush}"
              BorderBrush="{ThemeResource YanshuaiBorderBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="1" Text="预览角色卡" FontSize="18" FontWeight="SemiBold"
                       VerticalAlignment="Center" Opacity="0.9"/>
        </Grid>

        <!-- ═══ 内容区 ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18,16,18,32">

                <!-- 头像 + 名称 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <Border x:Name="AvatarBorder" Width="80" Height="80" CornerRadius="40"
                            Background="{ThemeResource YanshuaiSubtlePanelBrush}"
                            BorderBrush="{ThemeResource YanshuaiAccentBrush}"
                            BorderThickness="2" Margin="0,0,18,0">
                        <TextBlock x:Name="AvatarPlaceholder" Text="?" FontSize="32" Opacity="0.3"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="NameText" FontSize="22" FontWeight="SemiBold" Opacity="0.95"/>
                        <TextBlock x:Name="CreatorText" FontSize="12" Opacity="0.4" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- 标签 -->
                <TextBlock x:Name="TagsLabel" Text="标签" FontSize="13" FontWeight="SemiBold" Opacity="0.6" Margin="0,0,0,4"/>
                <TextBox x:Name="TagsBox" PlaceholderText="逗号分隔" FontSize="14" Padding="10,8" Margin="0,0,0,16"/>

                <!-- 开场白 -->
                <TextBlock x:Name="FirstMsgLabel" Text="开场白" FontSize="13" FontWeight="SemiBold" Opacity="0.6" Margin="0,0,0,4"/>
                <TextBox x:Name="FirstMsgBox" AcceptsReturn="True" TextWrapping="Wrap"
                         FontSize="14" Padding="10,8" Height="80" Margin="0,0,0,16"/>

                <!-- 描述 -->
                <TextBlock x:Name="DescLabel" Text="角色描述" FontSize="13" FontWeight="SemiBold" Opacity="0.6" Margin="0,0,0,4"/>
                <TextBox x:Name="DescBox" AcceptsReturn="True" TextWrapping="Wrap"
                         FontSize="14" Padding="10,8" Height="80" Margin="0,0,0,16"/>

                <!-- 性格 -->
                <TextBlock x:Name="PersonalityLabel" Text="性格特征" FontSize="13" FontWeight="SemiBold" Opacity="0.6" Margin="0,0,0,4"/>
                <TextBox x:Name="PersonalityBox" AcceptsReturn="True" TextWrapping="Wrap"
                         FontSize="14" Padding="10,8" Height="80" Margin="0,0,0,16"/>

                <!-- 场景 -->
                <TextBlock x:Name="ScenarioLabel" Text="情境设定" FontSize="13" FontWeight="SemiBold" Opacity="0.6" Margin="0,0,0,4"/>
                <TextBox x:Name="ScenarioBox" AcceptsReturn="True" TextWrapping="Wrap"
                         FontSize="14" Padding="10,8" Height="60" Margin="0,0,0,16"/>

                <!-- 系统提示词 -->
                <TextBlock x:Name="SysPromptLabel" Text="系统提示词" FontSize="13" FontWeight="SemiBold" Opacity="0.6" Margin="0,0,0,4"/>
                <TextBox x:Name="SysPromptBox" AcceptsReturn="True" TextWrapping="Wrap"
                         FontSize="14" Padding="10,8" Height="80" Margin="0,0,0,16"/>

                <!-- 分组选择 -->
                <TextBlock x:Name="GroupLabel" Text="分配到分组" FontSize="13" FontWeight="SemiBold" Opacity="0.6" Margin="0,0,0,4"/>
                <ComboBox x:Name="GroupCombo" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ 底部操作栏 ═══ -->
        <Grid Grid.Row="2" Background="{ThemeResource YanshuaiSurfaceBrush}"
              BorderBrush="{ThemeResource YanshuaiBorderBrush}" BorderThickness="0,1,0,0"
              Padding="14,8,14,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 自定义指令行 -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InstructionBox" Grid.Column="0"
                         PlaceholderText="输入指令调整角色设定…"
                         FontSize="13" Padding="8,6" Margin="0,0,6,0"/>
                <Button x:Name="AIInstructBtn" Grid.Column="1"
                        Content="按指令重生成" FontSize="12"
                        Padding="10,6" BorderThickness="0"
                        Background="{ThemeResource YanshuaiAccentBrush}"
                        Foreground="White"
                        Click="AIInstructBtn_Click"/>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Stretch">
                <Button x:Name="AIBtn" Content="AI 补全" FontSize="14"
                        Padding="14,10" BorderThickness="0"
                        Background="{ThemeResource YanshuaiAccentBrush}"
                        Foreground="White"
                        HorizontalAlignment="Left"
                        Click="AIBtn_Click"/>
                <TextBlock x:Name="StatusText" FontSize="12" Opacity="0.5"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Button x:Name="ImportBtn" Content="导入" FontSize="14"
                        Padding="24,10" BorderThickness="0"
                        HorizontalAlignment="Right"
                        Click="ImportBtn_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
