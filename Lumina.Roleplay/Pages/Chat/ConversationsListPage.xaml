<Page
    x:Class="yanshuai.ConversationsListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:yanshuai"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页眉：心象点 + 标题 + 新建对话 -->
        <Grid Grid.Row="0" Padding="18,22,18,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" Fill="{ThemeResource YanshuaiAccentBrush}"
                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="对话"
                           FontFamily="{ThemeResource YanshuaiTitleFont}"
                           FontSize="30"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource YanshuaiTextBrush}"/>
            </StackPanel>
            <Button x:Name="NewChatBtn" Grid.Column="1" Click="NewChat_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <FontIcon Glyph="&#xE710;" FontFamily="Segoe MDL2 Assets"
                              FontSize="{StaticResource IconSizeSmall}" Margin="0,0,8,0"/>
                    <TextBlock x:Name="NewChatLabel"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 对话列表：每行一张干净的卡片 -->
        <ListView x:Name="ConvList" Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  IsItemClickEnabled="True"
                  ItemClick="Conv_ItemClick"
                  SelectionMode="None"
                  Padding="14,0,14,16">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorderStyle}"
                            Margin="0,5" Padding="16,13">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <!-- 标题：标题字体 -->
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE840;" FontFamily="Segoe MDL2 Assets"
                                              FontSize="{StaticResource IconSizeSmall}" Margin="0,0,7,0"
                                              Foreground="{ThemeResource YanshuaiAccentBrush}"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding PinIconVisibility}"/>
                                    <TextBlock Text="{Binding Title}"
                                               FontFamily="{ThemeResource YanshuaiTitleFont}"
                                               FontSize="{StaticResource FontSizeBodyLarge}"
                                               Foreground="{ThemeResource YanshuaiTextBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <!-- 最近消息：弱化的说明文字 -->
                                <TextBlock Text="{Binding LastMessagePreview}"
                                           Style="{StaticResource CaptionTextStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                            <!-- 时间戳 -->
                            <TextBlock Grid.Column="1" Text="{Binding UpdatedAtDisplay}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       VerticalAlignment="Top" Margin="10,0,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 空状态：心象强调环 + 图标 + 弱化说明 -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding EmptyVisibility}">
            <Border Width="84" Height="84" CornerRadius="42" HorizontalAlignment="Center"
                    Background="{ThemeResource YanshuaiAccentWashBrush}"
                    BorderBrush="{ThemeResource YanshuaiAccentBrush}" BorderThickness="1">
                <FontIcon Glyph="&#xE8BD;" FontFamily="Segoe MDL2 Assets"
                          FontSize="32"
                          Foreground="{ThemeResource YanshuaiAccentBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="EmptyLabel" Margin="0,16,0,0"
                       FontSize="{StaticResource FontSizeBody}"
                       Opacity="{StaticResource OpacitySubtle}"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource YanshuaiMutedTextBrush}"/>
        </StackPanel>
    </Grid>
</Page>
