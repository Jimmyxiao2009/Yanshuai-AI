<Page
    x:Class="yanshuai.ConversationsListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:yanshuai"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 操作行 -->
        <Grid Grid.Row="0" Padding="16,12">
            <Button x:Name="NewChatBtn" Click="NewChat_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <FontIcon Glyph="&#xE710;" FontFamily="Segoe MDL2 Assets"
                              FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock x:Name="NewChatLabel"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 对话列表 -->
        <ListView x:Name="ConvList" Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  IsItemClickEnabled="True"
                  ItemClick="Conv_ItemClick"
                  SelectionMode="None"
                  Padding="8,0,8,16">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="{ThemeResource YanshuaiPanelBrush}"
                            BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{ThemeResource YanshuaiControlCornerRadius}"
                            Margin="0,4" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE840;" FontFamily="Segoe MDL2 Assets"
                                              FontSize="12" Margin="0,0,6,0"
                                              Foreground="{ThemeResource YanshuaiAccentBrush}"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding PinIconVisibility}"/>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{ThemeResource YanshuaiTextBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <TextBlock Text="{Binding LastMessagePreview}"
                                           FontSize="13"
                                           Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding UpdatedAtDisplay}"
                                       FontSize="12"
                                       Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                                       VerticalAlignment="Top" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 空状态 -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding EmptyVisibility}">
            <FontIcon Glyph="&#xE8BD;" FontFamily="Segoe MDL2 Assets"
                      FontSize="48" Opacity="0.3"
                      HorizontalAlignment="Center"
                      Foreground="{ThemeResource YanshuaiMutedTextBrush}"/>
            <TextBlock x:Name="EmptyLabel" Margin="0,12,0,0"
                       FontSize="14" Opacity="0.6"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource YanshuaiMutedTextBrush}"/>
        </StackPanel>
    </Grid>
</Page>
