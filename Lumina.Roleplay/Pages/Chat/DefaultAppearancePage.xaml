<Page
    x:Class="yanshuai.DefaultAppearancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:yanshuai"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶栏 -->
        <Grid Grid.Row="0" Background="{ThemeResource YanshuaiPanelBrush}"
              BorderBrush="{ThemeResource YanshuaiBorderBrush}" BorderThickness="0,0,0,1"
              Padding="14,8">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="默认对话外观"
                           FontSize="18" FontWeight="SemiBold" Opacity="0.9"/>
                <TextBlock Text="新建对话时使用这些默认外观设置" FontSize="12" Opacity="0.5"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ══ 背景 section ══ -->
                <StackPanel Margin="18,10,18,10">
                    <TextBlock Text="背景" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource YanshuaiAccentBrush}" CharacterSpacing="80"/>
                    <Border BorderBrush="{ThemeResource YanshuaiAccentBrush}"
                            BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                </StackPanel>

                <TextBlock Text="背景类型" FontSize="13" Opacity="0.6" Margin="18,0,18,8"/>
                <ComboBox x:Name="BgTypePicker" HorizontalAlignment="Stretch"
                          Margin="18,0,18,20"
                          SelectionChanged="BgTypePicker_SelectionChanged">
                    <ComboBoxItem Content="默认（无背景）" Tag="none"/>
                    <ComboBoxItem Content="纯色" Tag="solid"/>
                </ComboBox>

                <!-- Solid color picker -->
                <StackPanel x:Name="SolidPanel" Visibility="Collapsed" Margin="0,0,0,12">
                    <Border x:Name="BgColorPreview"
                            Height="48" Margin="18,0,18,10"
                            BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                            BorderThickness="1">
                        <TextBlock x:Name="BgColorHexLabel"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="13" FontFamily="Consolas"/>
                    </Border>
                    <TextBox x:Name="BgHexBox"
                             PlaceholderText="#RRGGBB"
                             Margin="18,0,18,10"
                             TextChanged="BgHexBox_TextChanged"/>
                    <local:ColorPresetPanel ColorSelected="BgPreset_Click"/>
                </StackPanel>

                <!-- ══ 气泡颜色 section ══ -->
                <StackPanel Margin="18,8,18,10">
                    <TextBlock Text="气泡颜色" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource YanshuaiAccentBrush}" CharacterSpacing="80"/>
                    <Border BorderBrush="{ThemeResource YanshuaiAccentBrush}"
                            BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                </StackPanel>

                <!-- User bubble -->
                <Grid Margin="18,0,18,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="用户消息气泡" FontSize="13" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="清除" Click="ClearUserBubble_Click"
                            Padding="12,0" Height="34"/>
                </Grid>
                <Border x:Name="UserBubblePreview"
                        Height="40" Margin="18,0,18,8"
                        BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="UserBubbleHexLabel"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" FontFamily="Consolas" Text="（使用强调色）"/>
                </Border>
                <TextBox x:Name="UserHexBox"
                         PlaceholderText="#RRGGBB"
                         Margin="18,0,18,8"
                         TextChanged="UserHexBox_TextChanged"/>
                <local:ColorPresetPanel ColorSelected="UserPreset_Click"/>

                <!-- AI bubble -->
                <Grid Margin="18,0,18,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="AI 消息气泡" FontSize="13" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="清除" Click="ClearAiBubble_Click"
                            Padding="12,0" Height="34"/>
                </Grid>
                <Border x:Name="AiBubblePreview"
                        Height="40" Margin="18,0,18,8"
                        BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="AiBubbleHexLabel"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" FontFamily="Consolas" Text="（使用强调色暗色）"/>
                </Border>
                <TextBox x:Name="AiHexBox"
                         PlaceholderText="#RRGGBB"
                         Margin="18,0,18,8"
                         TextChanged="AiHexBox_TextChanged"/>
                <local:ColorPresetPanel ColorSelected="AiPreset_Click"/>

                <!-- ══ 引号 / 括号颜色 section ══ -->
                <StackPanel Margin="18,8,18,10">
                    <TextBlock Text="文本高亮颜色" FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource YanshuaiAccentBrush}" CharacterSpacing="80"/>
                    <Border BorderBrush="{ThemeResource YanshuaiAccentBrush}"
                            BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                </StackPanel>

                <!-- Quote color -->
                <TextBlock Text="引号颜色（「」&quot;&quot; 等）" FontSize="13" Opacity="0.7" Margin="18,0,18,5"/>
                <Border x:Name="QuoteColorPreview"
                        Height="40" Margin="18,0,18,8"
                        BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="QuoteColorHexLabel"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" FontFamily="Consolas" Text="（默认橘黄）"/>
                </Border>
                <TextBox x:Name="QuoteHexBox"
                         PlaceholderText="#RRGGBB"
                         Margin="18,0,18,8"
                         TextChanged="QuoteHexBox_TextChanged"/>
                <local:ColorPresetPanel ColorSelected="QuotePreset_Click"/>
                <Button Content="清除（使用默认橘黄）" Click="ClearQuoteColor_Click"
                        Margin="18,0,18,20" Padding="12,0" Height="36"/>

                <!-- Bracket color -->
                <TextBlock Text="括号颜色（（）* * 等）" FontSize="13" Opacity="0.7" Margin="18,0,18,5"/>
                <Border x:Name="BracketColorPreview"
                        Height="40" Margin="18,0,18,8"
                        BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="BracketColorHexLabel"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12" FontFamily="Consolas" Text="（默认灰色）"/>
                </Border>
                <TextBox x:Name="BracketHexBox"
                         PlaceholderText="#RRGGBB"
                         Margin="18,0,18,8"
                         TextChanged="BracketHexBox_TextChanged"/>
                <local:ColorPresetPanel ColorSelected="BracketPreset_Click"/>
                <Button Content="清除（使用默认灰色）" Click="ClearBracketColor_Click"
                        Margin="18,0,18,30" Padding="12,0" Height="36"/>

            </StackPanel>
        </ScrollViewer>

        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton Icon="Refresh" Label="恢复默认" Click="ResetBtn_Click"/>
        </CommandBar>
    </Grid>
</Page>
