<Page
    x:Class="yanshuai.DefaultAppearancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:yanshuai"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页眉：心象点 + 标题 -->
        <StackPanel Grid.Row="0" Margin="18,22,18,12">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="9" Height="9" Fill="{ThemeResource YanshuaiAccentBrush}"
                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="默认对话外观"
                           FontFamily="{ThemeResource YanshuaiTitleFont}"
                           FontSize="30"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource YanshuaiTextBrush}"/>
            </StackPanel>
            <TextBlock Text="新建对话时使用这些默认外观设置"
                       Style="{StaticResource CaptionTextStyle}" Margin="21,2,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18,0,18,30">

                <!-- ══ 背景 section ══ -->
                <TextBlock Text="背景" Style="{StaticResource LabelTextStyle}"
                           Margin="2,4,0,8"/>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="背景类型" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8"/>
                        <ComboBox x:Name="BgTypePicker" HorizontalAlignment="Stretch"
                                  SelectionChanged="BgTypePicker_SelectionChanged">
                            <ComboBoxItem Content="默认（无背景）" Tag="none"/>
                            <ComboBoxItem Content="纯色" Tag="solid"/>
                        </ComboBox>

                        <!-- Solid color picker -->
                        <StackPanel x:Name="SolidPanel" Visibility="Collapsed" Margin="0,16,0,0">
                            <Border x:Name="BgColorPreview"
                                    Height="48" Margin="0,0,0,10"
                                    CornerRadius="{ThemeResource YanshuaiControlCornerRadius}"
                                    BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                                    BorderThickness="1">
                                <TextBlock x:Name="BgColorHexLabel"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontFamily="{ThemeResource YanshuaiEnglishFont}"
                                           FontSize="{StaticResource FontSizeBody}"/>
                            </Border>
                            <TextBox x:Name="BgHexBox"
                                     PlaceholderText="#RRGGBB"
                                     Margin="0,0,0,10"
                                     TextChanged="BgHexBox_TextChanged"/>
                            <local:ColorPresetPanel ColorSelected="BgPreset_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ══ 气泡颜色 section ══ -->
                <TextBlock Text="气泡颜色" Style="{StaticResource LabelTextStyle}"
                           Margin="2,0,0,8"/>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,24">
                    <StackPanel>
                        <!-- User bubble -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="用户消息气泡" Style="{StaticResource BodyTextStyle}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="清除" Click="ClearUserBubble_Click"
                                    Style="{StaticResource GhostButtonStyle}" Padding="12,4"/>
                        </Grid>
                        <Border x:Name="UserBubblePreview"
                                Height="40" Margin="0,8,0,8"
                                CornerRadius="{ThemeResource YanshuaiControlCornerRadius}"
                                BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                                BorderThickness="1">
                            <TextBlock x:Name="UserBubbleHexLabel"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="{ThemeResource YanshuaiEnglishFont}"
                                       FontSize="{StaticResource FontSizeCaption}" Text="（使用强调色）"/>
                        </Border>
                        <TextBox x:Name="UserHexBox"
                                 PlaceholderText="#RRGGBB"
                                 Margin="0,0,0,8"
                                 TextChanged="UserHexBox_TextChanged"/>
                        <local:ColorPresetPanel ColorSelected="UserPreset_Click"/>

                        <Border BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                                BorderThickness="0,1,0,0" Margin="0,16,0,16"/>

                        <!-- AI bubble -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="AI 消息气泡" Style="{StaticResource BodyTextStyle}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="清除" Click="ClearAiBubble_Click"
                                    Style="{StaticResource GhostButtonStyle}" Padding="12,4"/>
                        </Grid>
                        <Border x:Name="AiBubblePreview"
                                Height="40" Margin="0,8,0,8"
                                CornerRadius="{ThemeResource YanshuaiControlCornerRadius}"
                                BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                                BorderThickness="1">
                            <TextBlock x:Name="AiBubbleHexLabel"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="{ThemeResource YanshuaiEnglishFont}"
                                       FontSize="{StaticResource FontSizeCaption}" Text="（使用强调色暗色）"/>
                        </Border>
                        <TextBox x:Name="AiHexBox"
                                 PlaceholderText="#RRGGBB"
                                 Margin="0,0,0,8"
                                 TextChanged="AiHexBox_TextChanged"/>
                        <local:ColorPresetPanel ColorSelected="AiPreset_Click"/>
                    </StackPanel>
                </Border>

                <!-- ══ 引号 / 括号颜色 section ══ -->
                <TextBlock Text="文本高亮颜色" Style="{StaticResource LabelTextStyle}"
                           Margin="2,0,0,8"/>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,24">
                    <StackPanel>
                        <!-- Quote color -->
                        <TextBlock Text="引号颜色（「」&quot;&quot; 等）"
                                   Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8"/>
                        <Border x:Name="QuoteColorPreview"
                                Height="40" Margin="0,0,0,8"
                                CornerRadius="{ThemeResource YanshuaiControlCornerRadius}"
                                BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                                BorderThickness="1">
                            <TextBlock x:Name="QuoteColorHexLabel"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="{ThemeResource YanshuaiEnglishFont}"
                                       FontSize="{StaticResource FontSizeCaption}" Text="（默认橘黄）"/>
                        </Border>
                        <TextBox x:Name="QuoteHexBox"
                                 PlaceholderText="#RRGGBB"
                                 Margin="0,0,0,8"
                                 TextChanged="QuoteHexBox_TextChanged"/>
                        <local:ColorPresetPanel ColorSelected="QuotePreset_Click"/>
                        <Button Content="清除（使用默认橘黄）" Click="ClearQuoteColor_Click"
                                Style="{StaticResource GhostButtonStyle}"
                                HorizontalAlignment="Left" Margin="0,8,0,0"/>

                        <Border BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                                BorderThickness="0,1,0,0" Margin="0,16,0,16"/>

                        <!-- Bracket color -->
                        <TextBlock Text="括号颜色（（）* * 等）"
                                   Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8"/>
                        <Border x:Name="BracketColorPreview"
                                Height="40" Margin="0,0,0,8"
                                CornerRadius="{ThemeResource YanshuaiControlCornerRadius}"
                                BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                                BorderThickness="1">
                            <TextBlock x:Name="BracketColorHexLabel"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="{ThemeResource YanshuaiEnglishFont}"
                                       FontSize="{StaticResource FontSizeCaption}" Text="（默认灰色）"/>
                        </Border>
                        <TextBox x:Name="BracketHexBox"
                                 PlaceholderText="#RRGGBB"
                                 Margin="0,0,0,8"
                                 TextChanged="BracketHexBox_TextChanged"/>
                        <local:ColorPresetPanel ColorSelected="BracketPreset_Click"/>
                        <Button Content="清除（使用默认灰色）" Click="ClearBracketColor_Click"
                                Style="{StaticResource GhostButtonStyle}"
                                HorizontalAlignment="Left" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton Icon="Refresh" Label="恢复默认" Click="ResetBtn_Click"/>
        </CommandBar>
    </Grid>
</Page>
