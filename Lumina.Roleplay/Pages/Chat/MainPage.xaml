<Page
    x:Class="yanshuai.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:yanshuai"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>    <!-- chat -->
            <RowDefinition Height="Auto"/> <!-- suggestions panel -->
            <RowDefinition Height="Auto"/> <!-- input -->
        </Grid.RowDefinitions>

        <!-- ── Chat area ──────────────────────────────────── -->
        <Grid Grid.Row="0">
                        <!-- Appearance: background layer (solid color or image) -->
                        <Border x:Name="ChatBgSolid"
                                Visibility="Collapsed"/>
                        <Image  x:Name="ChatBgImage"
                                Stretch="UniformToFill"
                                Visibility="Collapsed"/>
                        <!-- 图片背景暗度遮罩 -->
                        <Border x:Name="ChatBgDimOverlay"
                                Background="#80000000"
                                Visibility="Collapsed"/>

                        <!-- 新对话欢迎界面 -->
                        <StackPanel x:Name="WelcomePanel"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Visibility="Collapsed"
                                    Margin="32,0">
                            <FontIcon Glyph="&#xE8BD;" FontSize="52"
                                      Opacity="0.4" HorizontalAlignment="Center"
                                      Foreground="{ThemeResource YanshuaiMutedTextBrush}"/>
                            <TextBlock Text="言枢"
                                       FontSize="28" FontWeight="Light"
                                       Foreground="{ThemeResource YanshuaiTextBrush}"
                                       Opacity="{StaticResource ActionIconOpacity}" HorizontalAlignment="Center"
                                       Margin="0,16,0,6"/>
                            <TextBlock x:Name="WelcomeSubtitle"
                                       Text="在下方输入消息开始对话"
                                       FontSize="14" Opacity="0.55"
                                       Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>

                        <ListView x:Name="ChatItems"
                                  Margin="0,8,0,0"
                                  Padding="0,0,0,4"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  ScrollViewer.HorizontalScrollMode="Disabled"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,3">

                                        <!-- Reasoning block: left-accent border style -->
                                        <Border Visibility="{Binding HasReasoningVisibility}"
                                                BorderBrush="{ThemeResource YanshuaiAccentBrush}"
                                                BorderThickness="3,0,0,0"
                                                Background="{ThemeResource YanshuaiSubtlePanelBrush}"
                                                CornerRadius="6"
                                                Margin="12,0,12,5"
                                                MaxWidth="580"
                                                HorizontalAlignment="{Binding Align}">
                                            <StackPanel>
                                                <Button Tag="{Binding}"

                                                        Click="ToggleReasoning_Click"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        HorizontalAlignment="Stretch"
                                                        Padding="10,6">
                                                    <StackPanel Orientation="Horizontal">
                                                        <FontIcon Glyph="&#xE945;" FontSize="12"
                                                                  Opacity="0.65" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding ReasoningLabel}"
                                                                   FontSize="12" Opacity="0.75"/>
                                                    </StackPanel>
                                                </Button>
                                                <TextBlock Text="{Binding ReasoningContent}"
                                                           Visibility="{Binding ReasoningBodyVisibility}"
                                                           TextWrapping="Wrap"
                                                           FontSize="13" Opacity="0.75"
                                                           Padding="10,0,10,8"/>
                                            </StackPanel>
                                        </Border>

                                                        <!-- User bubble: always plain text -->
                                        <!-- 图片缩略图（气泡上方，可点击放大） -->
                                        <Border Visibility="{Binding HasImageVisibility}"
                                                HorizontalAlignment="{Binding Align}"
                                                Margin="14,0"
                                                Tag="{Binding}"
                                                Tapped="BubbleImage_Click"
                                                CornerRadius="8">
                                            <Border.RenderTransform>
                                                <TranslateTransform/>
                                            </Border.RenderTransform>
                                            <Image Source="{Binding ImageSource}"
                                                   Width="120" Height="120"
                                                   Stretch="UniformToFill"/>
                                        </Border>
                                        <Grid Visibility="{Binding UserVisibility}"
                                              Margin="14,4,14,0"
                                              MaxWidth="580"
                                              HorizontalAlignment="{Binding Align}">
                                            <Border Background="{Binding BackgroundColor}"
                                                    CornerRadius="10,10,4,10"
                                                    BorderBrush="#22FFFFFF"
                                                    BorderThickness="1">
                                                <TextBlock Text="{Binding Content}"
                                                           FontSize="15"
                                                           Foreground="{Binding ForegroundColor}"
                                                           TextWrapping="Wrap"
                                                           Padding="12,8"/>
                                            </Border>
                                        </Grid>

                                        <!-- AI bubble while streaming: plain TextBlock for smooth token updates -->
                                        <Grid Visibility="{Binding AiStreamingVisibility}"
                                              Margin="14,2,14,0"
                                              MaxWidth="580"
                                              HorizontalAlignment="{Binding Align}">
                                            <Border Background="{Binding BackgroundColor}"
                                                    CornerRadius="10,10,10,4"
                                                    BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                                                    BorderThickness="1">
                                                <TextBlock Text="{Binding Content}"
                                                           FontSize="15"
                                                           Foreground="{Binding ForegroundColor}"
                                                           TextWrapping="Wrap"
                                                           Padding="12,8"/>
                                            </Border>
                                        </Grid>

                                        <!-- AI bubble after stream: markdown-rendered RichTextBlock -->
                                        <Grid Visibility="{Binding AiRenderedVisibility}"
                                              Margin="14,2,14,0"
                                              MaxWidth="580"
                                              HorizontalAlignment="{Binding Align}">
                                            <!-- 开场白标签 -->
                                            <Border Visibility="{Binding FirstMessageTagVisibility}"
                                                    Background="{ThemeResource YanshuaiAccentBrush}"
                                                    CornerRadius="6,6,0,0"
                                                    Padding="8,2"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Margin="0,-18,0,0"
                                                    Opacity="0.85">
                                                <TextBlock Text="开场白" FontSize="10"
                                                           Foreground="White" Opacity="0.9"/>
                                            </Border>
                                            <Border Background="{Binding BackgroundColor}"
                                                    CornerRadius="10,10,10,4"
                                                    BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                                                    BorderThickness="1">
                                                <RichTextBlock local:MarkdownBlock.Text="{Binding Content}"
                                                               local:MarkdownBlock.QuoteColor="{Binding QuoteColor}"
                                                               local:MarkdownBlock.BracketColor="{Binding BracketColor}"
                                                               FontSize="15"
                                                               Foreground="{Binding ForegroundColor}"
                                                               TextWrapping="Wrap"
                                                               Padding="12,8"
                                                               IsTextSelectionEnabled="True"/>
                                            </Border>
                                        </Grid>

                                        <!-- System message: centered, small, gray -->
                                        <TextBlock Visibility="{Binding SystemMessageVisibility}"
                                                   Text="{Binding Content}"
                                                   FontSize="12" Opacity="0.55"
                                                   Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                                                   TextWrapping="Wrap"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Margin="32,6,32,2"/>

                                        <!-- ── Action strip ───────────────────────────── -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="{Binding Align}"
                                                    Margin="14,2,14,4"
                                                    Visibility="{Binding ActionStripVisibility}">

                                            <!-- Copy (all messages) -->
                                            <Button Tag="{Binding}" Click="CopyMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="复制">
                                                <FontIcon Glyph="&#xE8C8;" FontSize="13" Opacity="{StaticResource ActionIconOpacity}"/>
                                            </Button>

                                            <!-- Edit (user messages only) -->
                                            <Button Visibility="{Binding EditBtnVisibility}"
                                                    Tag="{Binding}" Click="EditMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="编辑">
                                                <FontIcon Glyph="&#xE70F;" FontSize="13" Opacity="{StaticResource ActionIconOpacity}"/>
                                            </Button>

                                            <!-- Delete this msg + all after -->
                                            <Button Tag="{Binding}" Click="DeleteMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="删除此消息及之后所有消息">
                                                <FontIcon Glyph="&#xE74D;" FontSize="13" Opacity="{StaticResource ActionIconOpacity}"/>
                                            </Button>

                                            <!-- Regenerate (AI only, after streaming) -->
                                            <Button Visibility="{Binding RegenerateBtnVisibility}"
                                                    Tag="{Binding}" Click="RegenerateMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="重新生成">
                                                <FontIcon Glyph="&#xE72C;" FontSize="13" Opacity="{StaticResource ActionIconOpacity}"/>
                                            </Button>

                                            <!-- Continue (AI only, after streaming) -->
                                            <Button Visibility="{Binding ContinueBtnVisibility}"
                                                    Tag="{Binding}" Click="ContinueMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="继续">
                                                <FontIcon Glyph="&#xE768;" FontSize="13" Opacity="{StaticResource ActionIconOpacity}"/>
                                            </Button>

                                            <!-- Retry (error bubbles only) -->
                                            <Button Visibility="{Binding RetryBtnVisibility}"
                                                    Tag="{Binding}" Click="RetryMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="重试">
                                                <FontIcon Glyph="&#xE72C;" FontSize="13" Foreground="#FFC040"/>
                                            </Button>

                                            <!-- Branch navigator: < 1/3 > (user msgs with branches) -->
                                            <StackPanel Visibility="{Binding BranchNavVisibility}"
                                                        Orientation="Horizontal">
                                                <Button Tag="{Binding}" Click="PrevBranch_Click"
                                                        Background="Transparent" BorderThickness="0"
                                                        Width="26" Height="28" Padding="0"
                                                        ToolTipService.ToolTip="上一个分支">
                                                    <FontIcon Glyph="&#xE76B;" FontSize="11" Opacity="0.7"/>
                                                </Button>
                                                <TextBlock Text="{Binding BranchLabel}"
                                                           FontSize="12" Opacity="0.6"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0"/>
                                                <Button Tag="{Binding}" Click="NextBranch_Click"
                                                        Background="Transparent" BorderThickness="0"
                                                        Width="26" Height="28" Padding="0"
                                                        ToolTipService.ToolTip="下一个分支">
                                                    <FontIcon Glyph="&#xE76C;" FontSize="11" Opacity="0.7"/>
                                                </Button>
                                            </StackPanel>

                                        </StackPanel>

                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- 加载遮罩（声明在 ScrollViewer 之后，渲染在最上层） -->
                        <Border x:Name="LoadingOverlay"
                                Background="{ThemeResource YanshuaiPageBrush}"
                                Visibility="Collapsed"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <ProgressBar x:Name="LoadingProgress"
                                             Minimum="0" Maximum="100" Value="0"
                                             Width="200" Height="4"
                                             Margin="0,0,0,12"/>
                                <TextBlock x:Name="LoadingText"
                                           Text="加载中…"
                                           FontSize="13" Opacity="0.5"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- 回到底部按钮 -->
                        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,16,16" Visibility="Collapsed"
                                Background="{ThemeResource YanshuaiSurfaceBrush}"
                                BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                                BorderThickness="1"
                                Width="40" Height="40"
                                CornerRadius="20"
                                x:Name="ScrollToBottomBtnBorder">
                            <Button x:Name="ScrollToBottomBtn"
                                    Click="ScrollToBottomBtn_Click"
                                    Background="Transparent" BorderThickness="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    ToolTipService.ToolTip="回到底部">
                                <FontIcon Glyph="&#xE70D;" FontSize="14" Opacity="0.8"
                                          Foreground="{ThemeResource YanshuaiTextBrush}"/>
                            </Button>
                        </Border>
                    </Grid><!-- /ChatArea -->

                    <!-- ── Floating input bar ───────────────────────────── -->
        <Grid Grid.Row="2"
              Margin="12,8,12,12"
              Background="Transparent">
                        <Border Background="{ThemeResource YanshuaiShadowBrush}"
                                CornerRadius="18"
                                Margin="2,5,0,0"
                                Opacity="0.62"/>
                        <Border Background="{ThemeResource YanshuaiSurfaceBrush}"
                                BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- 图片预览 -->
                                    <RowDefinition Height="Auto"/>  <!-- 工具栏 -->
                                    <RowDefinition Height="Auto"/>  <!-- API 信息 -->
                                    <RowDefinition Height="Auto"/>  <!-- 输入行 -->
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>  <!-- 推荐回复 -->
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>  <!-- 发送 -->
                                </Grid.ColumnDefinitions>

                                <!-- 图片预览条（有图片时显示） -->
                                <Border x:Name="ImagePreviewBar"
                                        Grid.Row="0" Grid.ColumnSpan="3"
                                        Visibility="Collapsed"
                                        Padding="12,8"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="18,18,0,0"
                                        Background="{ThemeResource YanshuaiPanelBrush}"
                                        BorderBrush="{ThemeResource YanshuaiBorderBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="PendingImageThumb"
                                               Grid.Column="0"
                                               Width="48" Height="48"
                                               Stretch="UniformToFill"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="已附加图片"
                                                   FontSize="12" Opacity="0.6"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"/>
                                        <Button Grid.Column="2"
                                                Click="ClearImageBtn_Click"
                                                Background="Transparent" BorderThickness="0"
                                                Width="36" Height="36" Padding="0">
                                            <FontIcon Glyph="&#xE711;" FontSize="14" Opacity="0.6"/>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- 工具栏 -->
                                <Border x:Name="ComposerToolbarBorder"
                                        Grid.Row="1" Grid.ColumnSpan="3"
                                        Background="{ThemeResource YanshuaiPanelBrush}"
                                        BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="17,17,0,0">
                                    <Grid Height="36" Margin="4,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <!-- 全屏输入 -->
                                            <Button Click="FullscreenInputBtn_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="40" Height="36" Padding="0"
                                                    ToolTipService.ToolTip="全屏输入">
                                                <FontIcon x:Name="FullscreenInputIcon" Glyph="&#xE740;" FontSize="15" Opacity="0.6"
                                                          Foreground="{ThemeResource ApplicationForegroundThemeBrush}"/>
                                            </Button>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <!-- 插入括号 -->
                                            <Button Click="InsertBracketBtn_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="40" Height="36" Padding="0"
                                                    ToolTipService.ToolTip="插入括号（动作/心理）">
                                                <TextBlock Text="（）" FontSize="13" Opacity="0.6" VerticalAlignment="Center"/>
                                            </Button>
                                            <!-- 插入引号 -->
                                            <Button Click="InsertQuoteBtn_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="40" Height="36" Padding="0"
                                                    ToolTipService.ToolTip="插入引号（对话）">
                                                <TextBlock Text="「」" FontSize="13" Opacity="0.6" VerticalAlignment="Center"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- API 信息 + 好感度 -->
                                <Grid Grid.Row="2" Grid.ColumnSpan="3" Margin="12,2,12,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="ApiInfoLabel" Grid.Column="0"
                                               FontSize="11" Opacity="0.5"
                                               Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                                               Text="API: 未配置" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="FavorabilityLabel" Grid.Column="2"
                                               FontSize="11" Opacity="0.6"
                                               Foreground="{ThemeResource YanshuaiAccentBrush}"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                                </Grid>

                                <!-- 推荐回复/附加按钮（左侧常驻） -->
                                <Button x:Name="SuggestBtn"
                                        Grid.Row="3" Grid.Column="0"
                                        Click="SuggestBtn_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Width="42" MinHeight="42"
                                        Margin="8,7,0,8"
                                        VerticalAlignment="Bottom">
                                    <FontIcon Glyph="&#xE794;" FontSize="18" Opacity="0.6"
                                              Foreground="{ThemeResource YanshuaiTextBrush}"/>
                                </Button>

                                <Border Grid.Row="3" Grid.Column="1"
                                        Margin="4,7,8,8"
                                        Background="{ThemeResource YanshuaiPanelBrush}"
                                        BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <TextBox x:Name="InputTextBox"
                                             PlaceholderText="说点什么…"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{ThemeResource YanshuaiTextBrush}"
                                             TextWrapping="Wrap"
                                             VerticalAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             MinHeight="42"
                                             MaxHeight="160"
                                             Padding="10,6"
                                             Margin="0"
                                             KeyDown="InputTextBox_KeyDown"/>
                                </Border>

                                <Border x:Name="SubmitBtnBorder" Grid.Row="3" Grid.Column="2"
                                        Width="52" MinHeight="42"
                                        Margin="0,7,10,8"
                                        VerticalAlignment="Bottom"
                                        Background="{ThemeResource YanshuaiAccentBrush}"
                                        CornerRadius="12">
                                    <Button x:Name="SubmitButton"
                                            Click="SubmitButton_Click"
                                            Background="Transparent"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                        <FontIcon x:Name="SubmitIcon" Glyph="&#xE74A;" FontSize="18"/>
                                    </Button>
                                </Border>
                            </Grid>
                        </Border>
        </Grid>

        <MediaElement x:Name="ReplySound" AutoPlay="False" Visibility="Collapsed"/>

        <!-- 推荐回复面板（QQ/微信风格弹出层，放在最后以保持最上层） -->
        <Border x:Name="SuggestPanelOverlay"
                Grid.Row="0" Grid.RowSpan="3"
                Background="#40000000"
                Visibility="Collapsed"
                Tapped="SuggestPanelOverlay_Tapped">
            <Border x:Name="SuggestPanel"
                    Background="{ThemeResource YanshuaiSurfaceBrush}"
                    BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="16,16,0,0"
                    VerticalAlignment="Bottom"
                    MaxHeight="260"
                    Padding="0,12,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="16,0,16,8">
                        <Button x:Name="OverlayAttachBtn"
                                Click="AttachImageBtn_Click"
                                Background="Transparent" BorderThickness="0"
                                Padding="8,6"
                                ToolTipService.ToolTip="附加图片">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xEB9F;" FontSize="16" Opacity="0.7"
                                          Foreground="{ThemeResource YanshuaiTextBrush}"/>
                                <TextBlock Text="图片" FontSize="13" Opacity="0.7"
                                           Margin="6,0,0,0"
                                           Foreground="{ThemeResource YanshuaiTextBrush}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <!-- 生成中加载提示 -->
                    <StackPanel x:Name="SuggestLoadingPanel" Orientation="Horizontal"
                                Margin="16,4,16,8" Visibility="Collapsed">
                        <ProgressRing x:Name="SuggestProgressRing" IsActive="False"
                                      Width="16" Height="16" Margin="0,0,8,0"/>
                        <TextBlock x:Name="SuggestLoadingText" FontSize="13" Opacity="0.6"
                                   Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="192">
                        <StackPanel x:Name="SuggestPanelInner" Margin="16,0"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>
