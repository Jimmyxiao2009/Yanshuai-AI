<Page
    x:Class="yanshuai.ImportExportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18,0,18,30">

                <!-- 页眉：心象点 + 标题 -->
                <StackPanel Orientation="Horizontal" Margin="0,22,0,16">
                    <Ellipse Width="9" Height="9" Fill="{ThemeResource YanshuaiAccentBrush}"
                             VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="导入导出"
                               FontFamily="{ThemeResource YanshuaiTitleFont}"
                               FontSize="30"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource YanshuaiTextBrush}"/>
                </StackPanel>

                <!-- ══ 对话 ══ -->
                <TextBlock Text="对话记录" Style="{StaticResource LabelTextStyle}"
                           Margin="2,0,0,8"/>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="导出当前对话" Click="ExportCurrentConv_Click"
                                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="批量导出所有" Click="ExportAllConv_Click"
                                    Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="导入对话(.jsonl)" Click="ImportConv_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </StackPanel>
                        <TextBlock x:Name="ConvStatus" Text="" Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ══ 角色卡 ══ -->
                <TextBlock Text="角色卡" Style="{StaticResource LabelTextStyle}"
                           Margin="2,0,0,8"/>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="批量导出角色卡" Click="ExportChara_Click"
                                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="导入角色卡(.json/.png)" Click="ImportChara_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </StackPanel>
                        <TextBlock x:Name="CharaStatus" Text="" Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ══ 世界书 ══ -->
                <TextBlock Text="世界书" Style="{StaticResource LabelTextStyle}"
                           Margin="2,0,0,8"/>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="导出世界书" Click="ExportWorld_Click"
                                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="导入世界书(.json)" Click="ImportWorld_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </StackPanel>
                        <TextBlock x:Name="WorldStatus" Text="" Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ══ API 配置 ══ -->
                <TextBlock Text="API 配置" Style="{StaticResource LabelTextStyle}"
                           Margin="2,0,0,8"/>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="导出文件包含 API Key，请妥善保管"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,0,0,12" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="导出 API 配置" Click="ExportApi_Click"
                                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="导入 API 配置(.json)" Click="ImportApi_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </StackPanel>
                        <TextBlock x:Name="ApiStatus" Text="" Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ══ 全局备份 ══ -->
                <TextBlock Text="全局备份" Style="{StaticResource LabelTextStyle}"
                           Margin="2,0,0,8"/>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="将所有数据打包为 ZIP 文件，或从备份中恢复"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,0,0,12" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="导出 ZIP 备份" Click="ExportZip_Click"
                                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="从 ZIP 恢复" Click="ImportZip_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </StackPanel>
                        <TextBlock x:Name="ZipStatus" Text="" Style="{StaticResource CaptionTextStyle}"
                                   Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
