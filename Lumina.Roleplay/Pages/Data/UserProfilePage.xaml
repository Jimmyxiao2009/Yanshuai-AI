<Page
    x:Class="yanshuai.UserProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页眉：心象点 + 标题 -->
        <StackPanel Grid.Row="0" Margin="18,22,18,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="9" Height="9" Fill="{ThemeResource YanshuaiAccentBrush}"
                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock x:Name="PageTitle" Text="用户资料"
                           FontFamily="{ThemeResource YanshuaiTitleFont}"
                           FontSize="30"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource YanshuaiTextBrush}"/>
            </StackPanel>
            <TextBlock x:Name="PageSubtitle" Text="资料会注入到每次对话的 System Prompt 中"
                       Style="{StaticResource CaptionTextStyle}"
                       Margin="21,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="18,8,18,32">

                <!-- 头像区 -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="AvatarBorder"
                                Width="80" Height="80" CornerRadius="40"
                                Background="{ThemeResource YanshuaiSubtlePanelBrush}"
                                BorderBrush="{ThemeResource YanshuaiAccentBrush}"
                                BorderThickness="2" Margin="0,0,20,0">
                            <Grid>
                                <FontIcon x:Name="AvatarPlaceholder" Glyph="&#xE77B;"
                                          FontSize="36"
                                          Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                                          Opacity="{StaticResource OpacityFaint}"/>
                                <Image x:Name="AvatarImage" Stretch="UniformToFill"
                                       Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <Button x:Name="PickAvatarBtn" Content="选择头像"
                                    Click="PickAvatarBtn_Click"
                                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,0,8"/>
                            <Button x:Name="ClearAvatarBtn" Content="清除头像"
                                    Click="ClearAvatarBtn_Click"
                                    Style="{StaticResource GhostButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 名字 -->
                <TextBlock x:Name="NameLabel" Text="名字" Style="{StaticResource LabelTextStyle}"
                           Margin="2,0,0,8"/>
                <TextBox x:Name="NameBox"
                         PlaceholderText="你的名字（可选）"
                         FontSize="{StaticResource FontSizeBodyLarge}" Padding="12,14" Margin="0,0,0,20"
                         TextChanged="NameBox_TextChanged"/>

                <!-- 人设简介 -->
                <TextBlock x:Name="DescLabel" Text="人设简介" Style="{StaticResource LabelTextStyle}"
                           Margin="2,0,0,8"/>
                <TextBox x:Name="DescriptionBox"
                         PlaceholderText="介绍一下自己，会注入到 System Prompt 里告知 AI…"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         FontSize="{StaticResource FontSizeBody}" Padding="12,12" Height="120" Margin="0,0,0,6"
                         TextChanged="DescriptionBox_TextChanged"/>
                <TextBlock x:Name="ExampleHint"
                           Text="示例：一个喜欢科幻小说的大学生，性格活泼，说话直接"
                           Style="{StaticResource CaptionTextStyle}"
                           Opacity="{StaticResource OpacityFaint}"
                           Margin="2,0,0,24" TextWrapping="Wrap"/>

                <!-- 注入预览 -->
                <TextBlock x:Name="PreviewHeader" Text="注入预览"
                           Style="{StaticResource LabelTextStyle}"
                           Margin="2,0,0,8"/>
                <Border Style="{StaticResource CardBorderStyle}"
                        Background="{ThemeResource YanshuaiSubtlePanelBrush}">
                    <TextBlock x:Name="PreviewText"
                               Text="（填写名字或简介后显示）"
                               FontSize="{StaticResource FontSizeCaption}"
                               Opacity="{StaticResource OpacitySubtle}"
                               Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </ScrollViewer>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton x:Name="SaveBtn" Icon="Save" Label="保存" Click="BackButton_Click"/>
        </CommandBar>
    </Grid>
</Page>
