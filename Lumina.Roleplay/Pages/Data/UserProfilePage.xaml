<Page
    x:Class="yanshuai.UserProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶栏 -->
        <Grid Grid.Row="0" Background="{ThemeResource YanshuaiPanelBrush}"
              BorderBrush="{ThemeResource YanshuaiBorderBrush}" BorderThickness="0,0,0,1"
              Padding="14,8">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="PageTitle" Text="用户资料"
                           FontSize="18" FontWeight="SemiBold" Opacity="0.9"/>
                <TextBlock x:Name="PageSubtitle" Text="资料会注入到每次对话的 System Prompt 中"
                           FontSize="12" Opacity="0.5"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="14,16,14,32">

                <!-- 头像区 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                    <Border x:Name="AvatarBorder"
                            Width="80" Height="80" CornerRadius="40"
                            Background="{ThemeResource YanshuaiSubtlePanelBrush}"
                            BorderBrush="{ThemeResource YanshuaiAccentBrush}"
                            BorderThickness="2" Margin="0,0,20,0">
                        <Grid>
                            <FontIcon x:Name="AvatarPlaceholder" Glyph="&#xE77B;"
                                      FontSize="36" Opacity="0.4"/>
                            <Image x:Name="AvatarImage" Stretch="UniformToFill"
                                   Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <Button x:Name="PickAvatarBtn" Content="选择头像"
                                Click="PickAvatarBtn_Click"
                                Padding="20,12" FontSize="15" Margin="0,0,0,8"/>
                        <Button x:Name="ClearAvatarBtn" Content="清除头像"
                                Click="ClearAvatarBtn_Click"
                                Padding="20,10" FontSize="14"
                                Foreground="Red" Background="Transparent"/>
                    </StackPanel>
                </StackPanel>

                <!-- 名字 -->
                <TextBlock x:Name="NameLabel" Text="名字" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="NameBox"
                         PlaceholderText="你的名字（可选）"
                         FontSize="16" Padding="12,14" Margin="0,0,0,20"
                         TextChanged="NameBox_TextChanged"/>

                <!-- 人设简介 -->
                <TextBlock x:Name="DescLabel" Text="人设简介" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="DescriptionBox"
                         PlaceholderText="介绍一下自己，会注入到 System Prompt 里告知 AI…"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         FontSize="15" Padding="12,12" Height="120" Margin="0,0,0,6"
                         TextChanged="DescriptionBox_TextChanged"/>
                <TextBlock x:Name="ExampleHint"
                           Text="示例：一个喜欢科幻小说的大学生，性格活泼，说话直接"
                           FontSize="11" Opacity="0.4" Margin="0,0,0,24" TextWrapping="Wrap"/>

                <!-- 注入预览 -->
                <TextBlock x:Name="PreviewHeader" Text="注入预览" FontSize="14" FontWeight="SemiBold"
                           Foreground="{ThemeResource YanshuaiAccentBrush}" CharacterSpacing="80"
                           Margin="0,0,0,8"/>
                <Border Padding="14,12"
                        Background="{ThemeResource YanshuaiSubtlePanelBrush}"
                        CornerRadius="6">
                    <TextBlock x:Name="PreviewText"
                               Text="（填写名字或简介后显示）"
                               FontSize="12" Opacity="0.55"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </ScrollViewer>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton x:Name="SaveBtn" Icon="Save" Label="保存" Click="BackButton_Click"/>
        </CommandBar>
    </Grid>
</Page>
