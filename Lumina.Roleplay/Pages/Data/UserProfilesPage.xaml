<Page
    x:Class="yanshuai.UserProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:yanshuai"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶栏 -->
        <Grid Grid.Row="0" Background="{ThemeResource YanshuaiPanelBrush}"
              BorderBrush="{ThemeResource YanshuaiBorderBrush}" BorderThickness="0,0,0,1"
              Padding="14,8">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="PageTitle" Text="用户资料"
                           FontSize="18" FontWeight="SemiBold" Opacity="0.9"/>
                <TextBlock x:Name="PageSubtitle" Text="选中资料后点击使用，即可切换当前用户身份"
                           FontSize="12" Opacity="0.5"/>
            </StackPanel>
        </Grid>

        <!-- 当前活跃资料提示 -->
        <Border Grid.Row="1" Margin="18,8,18,8"
                Background="{ThemeResource YanshuaiAccentBrush}"
                Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <FontIcon Glyph="&#xE77B;" FontSize="14" Foreground="White" Margin="0,0,8,0"/>
                <TextBlock x:Name="ActiveLabel" Text="当前：未设置"
                           Foreground="White" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ListView x:Name="ProfilesList" Grid.Row="2"
                  SelectionMode="Single"
                  SelectionChanged="ProfilesList_SelectionChanged">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                            BorderThickness="0,0,0,1" Padding="18,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22"
                                    Background="{ThemeResource YanshuaiSubtlePanelBrush}"
                                    Margin="0,0,12,0"
                                    Visibility="{Binding AvatarVisibility}">
                                <Image Source="{Binding AvatarSource}" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" FontSize="16"/>
                                <TextBlock Text="{Binding Description}" FontSize="13"
                                           Opacity="0.55" TextTrimming="CharacterEllipsis"
                                           MaxLines="1" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="2"
                                    CornerRadius="4"
                                    Padding="8,4"
                                    Background="{ThemeResource YanshuaiAccentBrush}"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding ActiveVisibility}">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE930;" FontSize="13" Foreground="White"
                                              Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding ActiveLabel}" FontSize="12" Foreground="White"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton x:Name="UseBtn" Icon="Accept" Label="使用此资料"
                          IsEnabled="False" Click="UseBtn_Click"/>
            <AppBarButton x:Name="EditBtn" Icon="Edit" Label="编辑"
                          IsEnabled="False" Click="EditBtn_Click"/>
            <AppBarButton x:Name="DeleteBtn" Icon="Delete" Label="删除"
                          IsEnabled="False" Click="DeleteBtn_Click"/>
            <AppBarButton x:Name="AddBtn" Icon="Add" Label="新建" Click="AddBtn_Click"/>
        </CommandBar>
    </Grid>
</Page>
