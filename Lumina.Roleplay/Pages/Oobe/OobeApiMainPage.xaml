<Page
    x:Class="yanshuai.OobeApiMainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <Style TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶栏：心象点 + 标题字体 -->
        <Grid Grid.Row="0" Background="{ThemeResource YanshuaiPanelBrush}"
              BorderBrush="{ThemeResource YanshuaiBorderBrush}" BorderThickness="0,0,0,1"
              Padding="18,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" Fill="{ThemeResource YanshuaiAccentBrush}"
                         VerticalAlignment="Top" Margin="0,7,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="PageTitle" Text="主智能体 API"
                               FontFamily="{ThemeResource YanshuaiTitleFont}"
                               FontSize="{StaticResource FontSizeSubtitle}"/>
                    <TextBlock x:Name="PageStepHint" Text="步骤 2 / 8  ·  必须完成"
                               Style="{StaticResource CaptionTextStyle}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="14,16,14,32">

                <TextBlock x:Name="DescText"
                           Text="言枢通过兼容 OpenAI 格式的 API 与 AI 对话。需要填写 API 地址、密钥和模型名称。"
                           Style="{StaticResource BodyTextStyle}"
                           Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                           FontSize="{StaticResource FontSizeBodyLarge}"
                           TextWrapping="Wrap" Margin="0,0,0,24"/>

                <TextBlock x:Name="NameLabel" Text="配置名称" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,8"/>
                <TextBox x:Name="NameBox" PlaceholderText="例：DeepSeek / 我的 API"
                         FontSize="16" Padding="12,14" Margin="0,0,0,20"/>

                <TextBlock x:Name="UrlLabel" Text="API 地址" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,8"/>
                <TextBox x:Name="UrlBox" PlaceholderText="https://api.deepseek.com/v1/chat/completions"
                         FontSize="15" Padding="12,14" TextWrapping="Wrap" Margin="0,0,0,8"/>
                <TextBlock x:Name="UrlHintText" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" Margin="0,0,0,20"
                           Text="OpenAI: api.openai.com/v1/chat/completions&#x0a;DeepSeek: api.deepseek.com/v1/chat/completions&#x0a;Groq: api.groq.com/openai/v1/chat/completions"/>

                <TextBlock x:Name="KeyLabel" Text="API Key" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,8"/>
                <PasswordBox x:Name="KeyBox" PlaceholderText="sk-…" PasswordRevealMode="Peek"
                             FontSize="16" Padding="12,14" Margin="0,0,0,20"/>

                <TextBlock x:Name="ModelLabel" Text="模型" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,8"/>
                <TextBox x:Name="ModelBox" PlaceholderText="例：deepseek-chat / gpt-4o"
                         FontSize="16" Padding="12,14" Margin="0,0,0,8"/>

                <!-- Provider type -->
                <TextBlock x:Name="ProviderLabel" Text="提供商类型" Style="{StaticResource LabelTextStyle}" Margin="0,16,0,8"/>
                <ComboBox x:Name="ProviderBox" Margin="0,0,0,16">
                    <ComboBoxItem x:Name="ProviderOpenai" Content="OpenAI 兼容" Tag="openai"/>
                    <ComboBoxItem x:Name="ProviderClaude" Content="Anthropic Claude" Tag="claude"/>
                </ComboBox>

                <!-- Vision -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="VisionLabel" Text="视觉能力（多模态）" Style="{StaticResource BodyTextStyle}" FontSize="{StaticResource FontSizeBodyLarge}" VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="VisionToggle" Grid.Column="1" HorizontalAlignment="Right"/>
                </Grid>

                <!-- 用途（非 OOBE 模式显示） -->
                <StackPanel x:Name="RolePanel" Visibility="Collapsed">
                    <TextBlock x:Name="RoleLabel" Text="用途" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,8"/>
                    <ComboBox x:Name="RoleBox" Margin="0,0,0,20">
                        <ComboBoxItem x:Name="RoleMain" Content="主模型（对话）"/>
                        <ComboBoxItem x:Name="RoleSub" Content="副模型（记忆/RAG）"/>
                        <ComboBoxItem x:Name="RoleBoth" Content="通用（主+副）"/>
                    </ComboBox>

                    <!-- 副模型 -->
                    <TextBlock x:Name="SubModelLabel" Text="副模型（可选）" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,8"/>
                    <TextBox x:Name="SubModelBox" PlaceholderText="例：gpt-4o-mini / llama-3.1-8b"
                             FontSize="16" Padding="12,14" Margin="0,0,0,4"/>
                    <TextBlock x:Name="SubModelHint" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" Margin="0,0,0,20"
                               Text="用于记忆总结、RAG 嵌入等辅助任务，留空则复用主模型"/>

                    <!-- 分隔线 -->
                    <Border Height="1" Margin="0,4,0,16"
                            Background="{ThemeResource YanshuaiBorderBrush}"/>

                    <!-- 破墙 -->
                    <TextBlock x:Name="JbLabel" Text="破墙（可选）" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="JbEnableLabel" Text="启用" Style="{StaticResource BodyTextStyle}" FontSize="{StaticResource FontSizeBodyLarge}" VerticalAlignment="Center"/>
                        <ToggleSwitch x:Name="JbToggle" Grid.Column="1" HorizontalAlignment="Right" Toggled="JbToggle_Toggled"/>
                    </Grid>
                    <TextBox x:Name="JbBox" PlaceholderText="破墙提示词"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="100"
                             FontSize="15" Padding="12,10" Margin="0,0,0,8"
                             Visibility="Collapsed"/>
                </StackPanel>

                <!-- Test connection -->
                <Button x:Name="TestBtn" Content="测试连接" Click="TestBtn_Click"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalAlignment="Stretch" Padding="0,14" FontSize="15" Margin="0,8,0,8"/>
                <ProgressRing x:Name="TestProgress" Width="24" Height="24" Margin="0,0,0,8"
                              HorizontalAlignment="Center" Visibility="Collapsed"/>
                <TextBlock x:Name="TestResultText" Style="{StaticResource CaptionTextStyle}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,8"/>

                <TextBlock x:Name="ErrorText" Text="" Foreground="Red"
                           FontSize="13" Margin="0,8,0,0" TextWrapping="Wrap"/>

            </StackPanel>
        </ScrollViewer>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton x:Name="NextBtn" Icon="Forward" Label="下一步" Click="NextBtn_Click"/>
            <CommandBar.Content>
                <StackPanel x:Name="ProgressDots" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <Ellipse Width="7" Height="7" Margin="3,0" Fill="{ThemeResource YanshuaiMutedTextBrush}" Opacity="{StaticResource OpacityFaint}"/>
                    <Ellipse Fill="{ThemeResource YanshuaiAccentBrush}" Width="7" Height="7" Margin="3,0"/>
                    <Ellipse Width="7" Height="7" Margin="3,0" Fill="{ThemeResource YanshuaiMutedTextBrush}" Opacity="{StaticResource OpacityFaint}"/>
                    <Ellipse Width="7" Height="7" Margin="3,0" Fill="{ThemeResource YanshuaiMutedTextBrush}" Opacity="{StaticResource OpacityFaint}"/>
                    <Ellipse Width="7" Height="7" Margin="3,0" Fill="{ThemeResource YanshuaiMutedTextBrush}" Opacity="{StaticResource OpacityFaint}"/>
                    <Ellipse Width="7" Height="7" Margin="3,0" Fill="{ThemeResource YanshuaiMutedTextBrush}" Opacity="{StaticResource OpacityFaint}"/>
                    <Ellipse Width="7" Height="7" Margin="3,0" Fill="{ThemeResource YanshuaiMutedTextBrush}" Opacity="{StaticResource OpacityFaint}"/>
                    <Ellipse Width="7" Height="7" Margin="3,0" Fill="{ThemeResource YanshuaiMutedTextBrush}" Opacity="{StaticResource OpacityFaint}"/>
                    <TextBlock x:Name="StepLabel" Text="2/8" Style="{StaticResource CaptionTextStyle}" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </CommandBar.Content>
        </CommandBar>
    </Grid>
</Page>
