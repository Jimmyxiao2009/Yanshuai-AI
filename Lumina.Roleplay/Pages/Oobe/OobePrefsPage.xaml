<Page
    x:Class="yanshuai.OobePrefsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <Style TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶栏：心象点 + 标题字体 -->
        <Grid Grid.Row="0" Background="{ThemeResource YanshuaiPanelBrush}"
              BorderBrush="{ThemeResource YanshuaiBorderBrush}" BorderThickness="0,0,0,1"
              Padding="18,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" Fill="{ThemeResource YanshuaiAccentBrush}"
                         VerticalAlignment="Top" Margin="0,7,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="PageTitle" Text="偏好设置"
                               FontFamily="{ThemeResource YanshuaiTitleFont}"
                               FontSize="{StaticResource FontSizeSubtitle}"/>
                    <TextBlock x:Name="PageStepHint" Text="步骤 6 / 8  ·  可跳过"
                               Style="{StaticResource CaptionTextStyle}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="14,8,14,24">

                <!-- Startup behavior -->
                <TextBlock x:Name="StartupLabel" Text="启动页" Style="{StaticResource LabelTextStyle}" Margin="0,16,0,8"/>
                <RadioButton x:Name="StartupResume" Content="继续上次对话" GroupName="startup" Margin="0,0,0,4"/>
                <RadioButton x:Name="StartupNew" Content="新建对话" GroupName="startup" Margin="0,0,0,16"/>

                <!-- Enter key behavior -->
                <TextBlock x:Name="EnterLabel" Text="回车键行为" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,8"/>
                <RadioButton x:Name="EnterSend" Content="回车发送" GroupName="enter" Margin="0,0,0,4"/>
                <RadioButton x:Name="EnterNewline" Content="回车换行，Ctrl+回车发送" GroupName="enter" Margin="0,0,0,16"/>

                <!-- Background -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CharaBgLabel" Text="角色立绘作为对话背景" Style="{StaticResource BodyTextStyle}" FontSize="{StaticResource FontSizeBodyLarge}" VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="CharaBgToggle" Grid.Column="1" HorizontalAlignment="Right"/>
                </Grid>

                <!-- Reply sound -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="SoundLabel" Text="回复音效" Style="{StaticResource BodyTextStyle}" FontSize="{StaticResource FontSizeBodyLarge}" VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="SoundToggle" Grid.Column="1" HorizontalAlignment="Right"/>
                </Grid>

                <Border BorderBrush="{ThemeResource YanshuaiBorderBrush}" BorderThickness="0,0,0,1" Margin="0,4,0,12"/>

                <!-- Source toggles -->
                <TextBlock x:Name="SourceLabel" Text="角色广场平台" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Chub" Style="{StaticResource BodyTextStyle}" FontSize="{StaticResource FontSizeBodyLarge}" VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="SourceChub" Grid.Column="1" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="花屿" Style="{StaticResource BodyTextStyle}" FontSize="{StaticResource FontSizeBodyLarge}" VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="SourceHuayu" Grid.Column="1" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="星野" Style="{StaticResource BodyTextStyle}" FontSize="{StaticResource FontSizeBodyLarge}" VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="SourceXingye" Grid.Column="1" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="云酒馆" Style="{StaticResource BodyTextStyle}" FontSize="{StaticResource FontSizeBodyLarge}" VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="SourceQuack" Grid.Column="1" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="电子魅魔" Style="{StaticResource BodyTextStyle}" FontSize="{StaticResource FontSizeBodyLarge}" VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="SourceDzmm" Grid.Column="1" HorizontalAlignment="Right"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton x:Name="SkipBtn" Label="跳过" Click="SkipBtn_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE14C;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="NextBtn" Icon="Forward" Label="下一步" Click="NextBtn_Click"/>
            <CommandBar.Content>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <Ellipse Width="7" Height="7" Margin="3,0" Fill="{ThemeResource YanshuaiMutedTextBrush}" Opacity="{StaticResource OpacityFaint}"/>
                    <Ellipse Width="7" Height="7" Margin="3,0" Fill="{ThemeResource YanshuaiMutedTextBrush}" Opacity="{StaticResource OpacityFaint}"/>
                    <Ellipse Width="7" Height="7" Margin="3,0" Fill="{ThemeResource YanshuaiMutedTextBrush}" Opacity="{StaticResource OpacityFaint}"/>
                    <Ellipse Width="7" Height="7" Margin="3,0" Fill="{ThemeResource YanshuaiMutedTextBrush}" Opacity="{StaticResource OpacityFaint}"/>
                    <Ellipse Width="7" Height="7" Margin="3,0" Fill="{ThemeResource YanshuaiMutedTextBrush}" Opacity="{StaticResource OpacityFaint}"/>
                    <Ellipse Fill="{ThemeResource YanshuaiAccentBrush}" Width="7" Height="7" Margin="3,0"/>
                    <Ellipse Width="7" Height="7" Margin="3,0" Fill="{ThemeResource YanshuaiMutedTextBrush}" Opacity="{StaticResource OpacityFaint}"/>
                    <Ellipse Width="7" Height="7" Margin="3,0" Fill="{ThemeResource YanshuaiMutedTextBrush}" Opacity="{StaticResource OpacityFaint}"/>
                    <TextBlock x:Name="StepLabel" Text="6/8" Style="{StaticResource CaptionTextStyle}" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </CommandBar.Content>
        </CommandBar>
    </Grid>
</Page>
