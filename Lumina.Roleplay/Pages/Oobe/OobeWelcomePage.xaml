<Page
    x:Class="yanshuai.OobeWelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="32,40" MaxWidth="360">

            <FontIcon Glyph="&#xE8BD;" FontSize="72" Opacity="0.4"
                      HorizontalAlignment="Center" Margin="0,0,0,32"/>

            <TextBlock Text="言枢"
                       FontSize="48" FontWeight="Light"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

            <TextBlock x:Name="SubtitleText"
                       Text="AI 对话助手"
                       FontSize="18" Opacity="0.6" FontWeight="Light"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <TextBlock x:Name="PlatformText"
                       Text="适配 Windows 10 Mobile"
                       FontSize="14" Opacity="0.55"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,48"/>

            <TextBlock x:Name="DescText"
                       Text="接下来将引导你完成基本设置，只需几分钟。"
                       FontSize="15" Opacity="0.7"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Margin="0,0,0,8"/>

        </StackPanel>
        </ScrollViewer>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton x:Name="NextBtn" Icon="Forward" Label="开始"
                          Click="NextBtn_Click"/>
            <CommandBar.SecondaryCommands>
                <AppBarButton x:Name="RestoreBtn" Icon="Download"
                              Label="从备份恢复" Click="RestoreBackupBtn_Click"/>
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Grid>
</Page>
