<Page
    x:Class="yanshuai.OobeWelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Margin="32,48" MaxWidth="380">

            <!-- 心象环：起始的仪式感 -->
            <Border Width="84" Height="84" CornerRadius="42"
                    Background="{ThemeResource YanshuaiAccentWashBrush}"
                    BorderBrush="{ThemeResource YanshuaiAccentBrush}"
                    BorderThickness="1"
                    HorizontalAlignment="Center" Margin="0,0,0,32">
                <FontIcon Glyph="&#xE8BD;" FontSize="34"
                          Foreground="{ThemeResource YanshuaiAccentBrush}"/>
            </Border>

            <!-- 品牌名：标题字体 -->
            <TextBlock Text="言枢"
                       FontFamily="{ThemeResource YanshuaiTitleFont}"
                       FontSize="48"
                       Foreground="{ThemeResource YanshuaiTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

            <TextBlock x:Name="SubtitleText"
                       Text="AI 对话助手"
                       Style="{StaticResource SubtitleTextStyle}"
                       Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <TextBlock x:Name="PlatformText"
                       Text="适配 Windows 10 Mobile"
                       Style="{StaticResource CaptionTextStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,48"/>

            <!-- 心象色细线分隔 -->
            <Border Height="1" Width="40"
                    Background="{ThemeResource YanshuaiAccentBrush}"
                    Opacity="{StaticResource OpacitySubtle}"
                    HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <TextBlock x:Name="DescText"
                       Text="接下来将引导你完成基本设置，只需几分钟。"
                       Style="{StaticResource BodyTextStyle}"
                       Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                       FontSize="{StaticResource FontSizeBodyLarge}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Margin="0,0,0,8"/>

        </StackPanel>
        </ScrollViewer>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton x:Name="NextBtn" Icon="Forward" Label="开始"
                          Click="NextBtn_Click"/>
            <CommandBar.SecondaryCommands>
                <AppBarButton x:Name="RestoreBtn" Icon="Download"
                              Label="从备份恢复" Click="RestoreBackupBtn_Click"/>
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Grid>
</Page>
