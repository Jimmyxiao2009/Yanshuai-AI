<Page
    x:Class="yanshuai.ApiLogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页眉：心象点 + 标题 + 副标题 -->
        <StackPanel Grid.Row="0" Margin="18,22,18,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="9" Height="9" Fill="{ThemeResource YanshuaiAccentBrush}"
                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="API 日志"
                           FontFamily="{ThemeResource YanshuaiTitleFont}"
                           FontSize="30"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource YanshuaiTextBrush}"/>
            </StackPanel>
            <TextBlock Text="最近 30 条请求，仅保存在内存中，重启后清除"
                       Style="{StaticResource CaptionTextStyle}"
                       Margin="21,4,0,0"/>
        </StackPanel>

        <!-- 列表 / 空状态 -->
        <Grid Grid.Row="1">
            <ListView x:Name="LogList"
                      SelectionMode="Single"
                      IsTabStop="False"
                      Padding="14,4,14,30"
                      SelectionChanged="LogList_SelectionChanged">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="MinHeight" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource YanshuaiPanelBrush}"
                                BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="14,11">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           Style="{StaticResource BodyTextStyle}"/>
                                <TextBlock Text="{Binding Provider}"
                                           Style="{StaticResource CaptionTextStyle}"
                                           FontFamily="{ThemeResource YanshuaiEnglishFont}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- 空状态：心象色光环 -->
            <StackPanel x:Name="EmptyState"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <Border Width="84" Height="84" CornerRadius="42" HorizontalAlignment="Center"
                        Background="{ThemeResource YanshuaiAccentWashBrush}"
                        BorderBrush="{ThemeResource YanshuaiAccentBrush}" BorderThickness="1">
                    <FontIcon Glyph="&#xE8BD;" FontSize="32"
                              Foreground="{ThemeResource YanshuaiAccentBrush}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="暂无日志"
                           Style="{StaticResource SubtitleTextStyle}"
                           HorizontalAlignment="Center" Margin="0,16,0,0"/>
                <TextBlock Text="发送一条消息后日志会出现在这里"
                           Style="{StaticResource CaptionTextStyle}"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>

        <!-- 详情面板 -->
        <Border x:Name="DetailPanel"
                Grid.Row="2"
                Background="{ThemeResource YanshuaiPanelBrush}"
                BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                BorderThickness="0,1,0,0"
                MaxHeight="280"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- tab 切换 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="14,10,14,4">
                    <Button x:Name="ShowRequestBtn" Content="请求"
                            Click="ShowRequestBtn_Click"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button x:Name="ShowResponseBtn" Content="响应"
                            Click="ShowResponseBtn_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button Content="复制" Click="CopyDetailBtn_Click"
                            Style="{StaticResource GhostButtonStyle}"/>
                </StackPanel>

                <Border Grid.Row="1" Margin="14,6,14,12"
                        Background="{ThemeResource YanshuaiSubtlePanelBrush}"
                        BorderBrush="{ThemeResource YanshuaiBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CardCornerRadius}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                        <TextBlock x:Name="DetailText"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   FontFamily="{ThemeResource YanshuaiEnglishFont}"
                                   Foreground="{ThemeResource YanshuaiTextBrush}"
                                   TextWrapping="Wrap" IsTextSelectionEnabled="True"
                                   Opacity="{StaticResource OpacityMuted}"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton Icon="Delete" Label="清除日志" Click="ClearBtn_Click"/>
        </CommandBar>
    </Grid>
</Page>
