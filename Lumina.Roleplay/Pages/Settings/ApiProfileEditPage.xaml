<Page
    x:Class="yanshuai.ApiProfileEditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <Style TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页眉：心象点 + 标题 + 步骤提示 -->
        <StackPanel Grid.Row="0" Margin="18,22,18,10">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="9" Height="9" Fill="{ThemeResource YanshuaiAccentBrush}"
                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock x:Name="PageTitle" Text="API 配置"
                           FontFamily="{ThemeResource YanshuaiTitleFont}"
                           FontSize="30"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource YanshuaiTextBrush}"/>
            </StackPanel>
            <TextBlock x:Name="PageStepHint" Text="设置 API 连接信息"
                       Style="{StaticResource CaptionTextStyle}"
                       Margin="21,4,0,0"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="18,8,18,32">

                <!-- ══ 连接信息 ══ -->
                <TextBlock Text="连接信息"
                           Style="{StaticResource LabelTextStyle}"
                           Margin="2,0,0,8"/>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,18">
                    <StackPanel>
                        <!-- 配置名称 -->
                        <TextBlock x:Name="NameLabel" Text="配置名称"
                                   Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="NameBox" PlaceholderText="例：DeepSeek / 我的 API"
                                 FontSize="{StaticResource FontSizeBodyLarge}" Padding="12,14" Margin="0,0,0,18"/>

                        <!-- API 地址 -->
                        <TextBlock x:Name="UrlLabel" Text="API 地址"
                                   Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="UrlBox" PlaceholderText="https://api.deepseek.com/v1/chat/completions"
                                 FontSize="15" Padding="12,14" TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <TextBlock x:Name="UrlHintText"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Opacity="{StaticResource OpacityMuted}"
                                   TextWrapping="Wrap" Margin="0,0,0,18"
                                   Text="OpenAI: api.openai.com/v1/chat/completions&#x0a;DeepSeek: api.deepseek.com/v1/chat/completions&#x0a;Groq: api.groq.com/openai/v1/chat/completions"/>

                        <!-- API Key -->
                        <TextBlock x:Name="KeyLabel" Text="API Key"
                                   Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <PasswordBox x:Name="KeyBox" PlaceholderText="sk-…" PasswordRevealMode="Peek"
                                     FontSize="{StaticResource FontSizeBodyLarge}" Padding="12,14"/>
                    </StackPanel>
                </Border>

                <!-- ══ 模型 ══ -->
                <TextBlock Text="模型"
                           Style="{StaticResource LabelTextStyle}"
                           Margin="2,0,0,8"/>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,18">
                    <StackPanel>
                        <!-- 主模型 -->
                        <TextBlock x:Name="ModelLabel" Text="模型"
                                   Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="ModelBox" PlaceholderText="例：deepseek-chat / gpt-4o"
                                 FontSize="{StaticResource FontSizeBodyLarge}" Padding="12,14" Margin="0,0,0,18"/>

                        <!-- 提供商类型 -->
                        <TextBlock x:Name="ProviderLabel" Text="提供商类型"
                                   Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="ProviderBox" HorizontalAlignment="Stretch" Margin="0,0,0,16">
                            <ComboBoxItem x:Name="ProviderOpenai" Content="OpenAI 兼容" Tag="openai"/>
                            <ComboBoxItem x:Name="ProviderClaude" Content="Anthropic Claude" Tag="claude"/>
                        </ComboBox>

                        <!-- 视觉能力 -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="VisionLabel" Text="视觉能力（多模态）"
                                           Style="{StaticResource BodyTextStyle}"/>
                                <TextBlock Text="模型可读取图片输入"
                                           Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="VisionToggle" Grid.Column="1"
                                          VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- 用途 -->
                        <TextBlock x:Name="RoleLabel" Text="用途"
                                   Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="RoleBox" HorizontalAlignment="Stretch" Margin="0,0,0,18">
                            <ComboBoxItem x:Name="RoleMain" Content="主模型（对话）"/>
                            <ComboBoxItem x:Name="RoleSub" Content="副模型（记忆/RAG）"/>
                            <ComboBoxItem x:Name="RoleBoth" Content="通用（主+副）"/>
                        </ComboBox>

                        <!-- 副模型 -->
                        <TextBlock x:Name="SubModelLabel" Text="副模型（可选）"
                                   Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="SubModelBox" PlaceholderText="例：gpt-4o-mini / llama-3.1-8b"
                                 FontSize="{StaticResource FontSizeBodyLarge}" Padding="12,14" Margin="0,0,0,6"/>
                        <TextBlock x:Name="SubModelHint"
                                   Style="{StaticResource CaptionTextStyle}"
                                   Opacity="{StaticResource OpacityMuted}"
                                   TextWrapping="Wrap"
                                   Text="用于记忆总结、RAG 嵌入等辅助任务，留空则复用主模型"/>
                    </StackPanel>
                </Border>

                <!-- ══ 破墙（可选） ══ -->
                <TextBlock Text="破墙（可选）"
                           Style="{StaticResource LabelTextStyle}"
                           Margin="2,0,0,8"/>
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="JbLabel" Text="破墙提示词"
                                           Style="{StaticResource BodyTextStyle}"/>
                                <TextBlock x:Name="JbEnableLabel" Text="启用"
                                           Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleSwitch x:Name="JbToggle" Grid.Column="1"
                                          VerticalAlignment="Center" HorizontalAlignment="Right"
                                          Toggled="JbToggle_Toggled"/>
                        </Grid>
                        <TextBox x:Name="JbBox" PlaceholderText="破墙提示词"
                                 AcceptsReturn="True" TextWrapping="Wrap" Height="100"
                                 FontSize="15" Padding="12,10"
                                 Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton x:Name="SaveBtn" Icon="Save" Label="保存" Click="SaveBtn_Click"/>
        </CommandBar>
    </Grid>
</Page>
