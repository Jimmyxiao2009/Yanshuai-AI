<Page
    x:Class="yanshuai.ApiProfileEditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <Style TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶栏 -->
        <Grid Grid.Row="0" Background="{ThemeResource YanshuaiPanelBrush}"
              BorderBrush="{ThemeResource YanshuaiBorderBrush}" BorderThickness="0,0,0,1"
              Padding="14,8">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="PageTitle" Text="API 配置"
                           FontSize="18" FontWeight="SemiBold" Opacity="0.9"/>
                <TextBlock x:Name="PageStepHint" Text="设置 API 连接信息"
                           FontSize="12" Opacity="0.5"/>
            </StackPanel>
        </Grid>

        <!-- Form -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="14,16,14,32">

                <!-- 配置名称 -->
                <TextBlock x:Name="NameLabel" Text="配置名称" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="NameBox" PlaceholderText="例：DeepSeek / 我的 API"
                         FontSize="16" Padding="12,14" Margin="0,0,0,20"/>

                <!-- API 地址 -->
                <TextBlock x:Name="UrlLabel" Text="API 地址" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="UrlBox" PlaceholderText="https://api.deepseek.com/v1/chat/completions"
                         FontSize="15" Padding="12,14" TextWrapping="Wrap" Margin="0,0,0,8"/>
                <TextBlock x:Name="UrlHintText" FontSize="12" Opacity="0.45" TextWrapping="Wrap" Margin="0,0,0,20"
                           Text="OpenAI: api.openai.com/v1/chat/completions&#x0a;DeepSeek: api.deepseek.com/v1/chat/completions&#x0a;Groq: api.groq.com/openai/v1/chat/completions"/>

                <!-- API Key -->
                <TextBlock x:Name="KeyLabel" Text="API Key" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <PasswordBox x:Name="KeyBox" PlaceholderText="sk-…" PasswordRevealMode="Peek"
                             FontSize="16" Padding="12,14" Margin="0,0,0,20"/>

                <!-- 模型 -->
                <TextBlock x:Name="ModelLabel" Text="模型" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="ModelBox" PlaceholderText="例：deepseek-chat / gpt-4o"
                         FontSize="16" Padding="12,14" Margin="0,0,0,8"/>

                <!-- 提供商类型 -->
                <TextBlock x:Name="ProviderLabel" Text="提供商类型" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,8"/>
                <ComboBox x:Name="ProviderBox" Margin="0,0,0,16">
                    <ComboBoxItem x:Name="ProviderOpenai" Content="OpenAI 兼容" Tag="openai"/>
                    <ComboBoxItem x:Name="ProviderClaude" Content="Anthropic Claude" Tag="claude"/>
                </ComboBox>

                <!-- 视觉能力 -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="VisionLabel" Text="视觉能力（多模态）" FontSize="15" VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="VisionToggle" Grid.Column="1" HorizontalAlignment="Right"/>
                </Grid>

                <!-- 用途 -->
                <TextBlock x:Name="RoleLabel" Text="用途" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <ComboBox x:Name="RoleBox" Margin="0,0,0,20">
                    <ComboBoxItem x:Name="RoleMain" Content="主模型（对话）"/>
                    <ComboBoxItem x:Name="RoleSub" Content="副模型（记忆/RAG）"/>
                    <ComboBoxItem x:Name="RoleBoth" Content="通用（主+副）"/>
                </ComboBox>

                <!-- 副模型 -->
                <TextBlock x:Name="SubModelLabel" Text="副模型（可选）" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="SubModelBox" PlaceholderText="例：gpt-4o-mini / llama-3.1-8b"
                         FontSize="16" Padding="12,14" Margin="0,0,0,4"/>
                <TextBlock x:Name="SubModelHint" FontSize="12" Opacity="0.45" TextWrapping="Wrap" Margin="0,0,0,20"
                           Text="用于记忆总结、RAG 嵌入等辅助任务，留空则复用主模型"/>

                <!-- 分隔线 -->
                <Border Height="1" Margin="0,4,0,16"
                        Background="{ThemeResource YanshuaiBorderBrush}"/>

                <!-- 破墙 -->
                <TextBlock x:Name="JbLabel" Text="破墙（可选）" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="JbEnableLabel" Text="启用" FontSize="15" VerticalAlignment="Center"/>
                    <ToggleSwitch x:Name="JbToggle" Grid.Column="1" HorizontalAlignment="Right" Toggled="JbToggle_Toggled"/>
                </Grid>
                <TextBox x:Name="JbBox" PlaceholderText="破墙提示词"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="100"
                         FontSize="15" Padding="12,10" Margin="0,0,0,8"
                         Visibility="Collapsed"/>

            </StackPanel>
        </ScrollViewer>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton x:Name="SaveBtn" Icon="Save" Label="保存" Click="SaveBtn_Click"/>
        </CommandBar>
    </Grid>
</Page>
