<Page
    x:Class="yanshuai.ApiProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:yanshuai"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页眉：心象点 + 标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="18,22,18,10">
            <Ellipse Width="9" Height="9" Fill="{ThemeResource YanshuaiAccentBrush}"
                     VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock x:Name="PageTitle" Text="API 配置"
                       FontFamily="{ThemeResource YanshuaiTitleFont}"
                       FontSize="30"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource YanshuaiTextBrush}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- 空状态：心象色光环 -->
                <StackPanel x:Name="EmptyPanel" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="32,80,32,0">
                    <Border Width="84" Height="84" CornerRadius="42" HorizontalAlignment="Center"
                            Background="{ThemeResource YanshuaiAccentWashBrush}"
                            BorderBrush="{ThemeResource YanshuaiAccentBrush}" BorderThickness="1">
                        <FontIcon Glyph="&#xE8D4;" FontSize="32"
                                  Foreground="{ThemeResource YanshuaiAccentBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="EmptyTitle" Text="还没有 API 配置"
                               Style="{StaticResource SubtitleTextStyle}"
                               HorizontalAlignment="Center" Margin="0,16,0,6"/>
                    <TextBlock x:Name="EmptyDesc" Text="点击下方「新增」添加 API 连接"
                               Style="{StaticResource CaptionTextStyle}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>

                <!-- 配置列表 -->
                <StackPanel x:Name="CardContainer" Margin="14,8,14,30"/>
            </StackPanel>
        </ScrollViewer>
        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <!-- 普通模式 -->
            <AppBarButton x:Name="SetDefaultBtn" Icon="Favorite" Label="设为默认"
                          IsEnabled="False" Click="SetDefaultBtn_Click"/>
            <AppBarButton x:Name="EditBtn" Icon="Edit" Label="编辑"
                          IsEnabled="False" Click="EditButton_Click"/>
            <AppBarButton x:Name="DeleteBtn" Icon="Delete" Label="删除"
                          IsEnabled="False" Click="DeleteButton_Click"/>
            <AppBarButton x:Name="AddBtn" Icon="Add" Label="新增" Click="AddButton_Click"/>
            <!-- 多选模式 -->
            <AppBarButton x:Name="ToggleAllBtn" Icon="SelectAll" Label="全选"
                          Visibility="Collapsed" Click="ToggleAllBtn_Click"/>
            <AppBarButton x:Name="DeleteSelectBtn" Icon="Delete" Label="删除选中"
                          Visibility="Collapsed" IsEnabled="False" Click="DeleteSelectedBtn_Click"/>
            <AppBarButton x:Name="CancelSelectBtn" Icon="Cancel" Label="取消"
                          Visibility="Collapsed" Click="CancelSelectBtn_Click"/>
            <CommandBar.SecondaryCommands>
                <AppBarButton x:Name="ExportBackupBtn" Icon="Upload" Label="导出备份" Click="ExportApi_Click"/>
                <AppBarButton x:Name="ImportBackupBtn" Icon="Download" Label="从备份恢复" Click="ImportApi_Click"/>
            </CommandBar.SecondaryCommands>
            <CommandBar.Content>
                <TextBlock x:Name="SelectHint" Text="" FontSize="13" Opacity="{StaticResource OpacityMuted}"
                           VerticalAlignment="Center" Margin="12,0" Visibility="Collapsed"/>
            </CommandBar.Content>
        </CommandBar>
    </Grid>
</Page>
