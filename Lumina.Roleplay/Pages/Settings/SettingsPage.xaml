<Page x:Class="yanshuai.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:yanshuai"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Page.Resources>
        <Style TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="0"/>
        </Style>
        <!-- Pivot 标签页表头：标题字体，主题色，未选中由 Pivot 自动淡化 -->
        <Style x:Key="SettingsTabHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{ThemeResource YanshuaiTitleFont}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{ThemeResource YanshuaiTextBrush}"/>
        </Style>
        <Style x:Key="SettingsRowDivider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,12"/>
            <Setter Property="Background" Value="{ThemeResource YanshuaiBorderBrush}"/>
            <Setter Property="Opacity" Value="{StaticResource OpacityFaint}"/>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" Background="{ThemeResource YanshuaiPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页眉：心象点 + 标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="18,22,18,6">
            <Ellipse Width="9" Height="9" Fill="{ThemeResource YanshuaiAccentBrush}"
                     VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock x:Name="PageTitle" Text="设置"
                       FontFamily="{ThemeResource YanshuaiTitleFont}"
                       FontSize="30"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource YanshuaiTextBrush}"/>
        </StackPanel>

        <!-- ══ 分页签 ══ -->
        <Pivot x:Name="SettingsPivot" Grid.Row="1" Margin="6,0,6,0">

            <!-- ── Tab 显示 ── -->
            <PivotItem>
                <PivotItem.Header>
                    <TextBlock x:Name="DisplaySectionTitle" Text="显示" Style="{StaticResource SettingsTabHeaderStyle}"/>
                </PivotItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,8,12,64">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <!-- 深色模式 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock x:Name="DarkModeLabel" Text="深色模式"
                                                   Style="{StaticResource BodyTextStyle}"/>
                                        <TextBlock x:Name="DarkModeDesc" Text="切换深色/浅色主题"
                                                   Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="DarkModeToggle" Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  Toggled="DarkModeToggle_Toggled"/>
                                </Grid>

                                <Border Style="{StaticResource SettingsRowDivider}"/>

                                <!-- 主题与字体 → 子页面 -->
                                <Grid Tapped="ThemeSettingsBtn_Tapped">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock x:Name="ThemeFontLabel" Text="主题与字体"
                                                   Style="{StaticResource BodyTextStyle}"/>
                                        <TextBlock x:Name="ThemeFontDesc" Text="切换配色风格、字体和主色调"
                                                   Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <FontIcon Grid.Column="1" Glyph="&#xE76C;" FontSize="13"
                                              Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                                              Opacity="{StaticResource OpacitySubtle}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </Grid>

                                <Border Style="{StaticResource SettingsRowDivider}"/>

                                <!-- 语言 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock x:Name="LangLabel" Text="Language / 语言"
                                                   Style="{StaticResource BodyTextStyle}"/>
                                        <TextBlock x:Name="LangDesc" Text="切换界面语言"
                                                   Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ComboBox x:Name="LangPicker" Grid.Column="1" VerticalAlignment="Center"
                                              MinWidth="140" SelectionChanged="LangPicker_SelectionChanged"/>
                                </Grid>

                                <Border Style="{StaticResource SettingsRowDivider}"/>

                                <!-- 回复声音 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock x:Name="ReplySoundLabel" Text="回复声音"
                                                   Style="{StaticResource BodyTextStyle}"/>
                                        <TextBlock x:Name="ReplySoundDesc" Text="AI 回复完成时播放提示音"
                                                   Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ReplySoundToggle" Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  Toggled="ReplySoundToggle_Toggled"/>
                                </Grid>

                                <Border Style="{StaticResource SettingsRowDivider}"/>

                                <!-- 默认展开思考过程 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock x:Name="ReasoningExpandedLabel" Text="默认展开思考过程"
                                                   Style="{StaticResource BodyTextStyle}"/>
                                        <TextBlock x:Name="ReasoningExpandedDesc" Text="AI 回复完成后自动展开思维链"
                                                   Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ReasoningExpandedToggle" Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  Toggled="ReasoningExpandedToggle_Toggled"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ── Tab 输入/启动行为 ── -->
            <PivotItem>
                <PivotItem.Header>
                    <TextBlock x:Name="InputSectionTitle" Text="输入行为" Style="{StaticResource SettingsTabHeaderStyle}"/>
                </PivotItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,8,12,64">
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock x:Name="EnterBehaviorLabel" Text="Enter 键行为"
                                           Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="EnterBehaviorPicker"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="EnterBehaviorPicker_SelectionChanged">
                                    <ComboBoxItem Content="Enter 发送，Shift+Enter 换行"/>
                                    <ComboBoxItem Content="Enter 换行，Ctrl+Enter 发送"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="StartupSectionTitle" Text="启动行为"
                                   Style="{StaticResource LabelTextStyle}"
                                   Foreground="{ThemeResource YanshuaiAccentBrush}"
                                   Margin="2,4,0,8"/>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock x:Name="StartupBehaviorLabel" Text="启动应用时自动进入"
                                           Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="StartupBehaviorPicker"
                                          HorizontalAlignment="Stretch"
                                          SelectionChanged="StartupBehaviorPicker_SelectionChanged">
                                    <ComboBoxItem Content="最近的对话"/>
                                    <ComboBoxItem Content="新对话"/>
                                </ComboBox>
                                <TextBlock x:Name="StartupRestartHint"
                                           Text="✓ 返回主界面后即生效"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Foreground="{ThemeResource YanshuaiAccentBrush}"
                                           Margin="0,8,0,0"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ── Tab 角色卡 ── -->
            <PivotItem>
                <PivotItem.Header>
                    <TextBlock x:Name="CharaSectionTitle" Text="角色卡" Style="{StaticResource SettingsTabHeaderStyle}"/>
                </PivotItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,8,12,64">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock x:Name="CharaIllustBgLabel" Text="使用角色卡立绘作为对话背景"
                                               Style="{StaticResource BodyTextStyle}"/>
                                    <TextBlock x:Name="CharaIllustBgDesc" Text="有立绘的角色卡会自动设为对话背景图"
                                               Style="{StaticResource CaptionTextStyle}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="CharaIllustBgToggle" Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Toggled="CharaIllustBgToggle_Toggled"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ── Tab 数据备份 / 引导 / 调试 ── -->
            <PivotItem>
                <PivotItem.Header>
                    <TextBlock x:Name="BackupSectionTitle" Text="数据备份" Style="{StaticResource SettingsTabHeaderStyle}"/>
                </PivotItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,8,12,64">
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock x:Name="BackupDesc" Text="将所有对话、角色卡、世界书、API配置打包导出或从备份恢复"
                                           Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,12" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button x:Name="ExportZipBtn" Content="导出备份(.zip)" Click="ExportZip_Click"
                                            Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
                                    <Button x:Name="ImportZipBtn" Content="从备份恢复" Click="ImportZip_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"/>
                                </StackPanel>
                                <TextBlock x:Name="BackupStatus" Text=""
                                           Style="{StaticResource CaptionTextStyle}"
                                           Opacity="{StaticResource OpacityMuted}"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="OobeSectionTitle" Text="引导向导"
                                   Style="{StaticResource LabelTextStyle}"
                                   Foreground="{ThemeResource YanshuaiAccentBrush}"
                                   Margin="2,4,0,8"/>
                        <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,18">
                            <Button x:Name="ReEnterOobeBtn" Content="重新进入初始引导向导"
                                    Click="ReEnterOobeBtn_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    HorizontalAlignment="Left"/>
                        </Border>

                        <TextBlock x:Name="DebugSectionTitle" Text="调试"
                                   Style="{StaticResource LabelTextStyle}"
                                   Foreground="{ThemeResource YanshuaiAccentBrush}"
                                   Margin="2,4,0,8"/>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Button x:Name="ApiLogBtn" Content="查看 API 日志"
                                    Click="ApiLogBtn_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    HorizontalAlignment="Left"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ── Tab 关于 ── -->
            <PivotItem>
                <PivotItem.Header>
                    <TextBlock x:Name="CreditsSectionTitle" Text="关于" Style="{StaticResource SettingsTabHeaderStyle}"/>
                </PivotItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,8,12,64">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="言枢"
                                           FontFamily="{ThemeResource YanshuaiTitleFont}"
                                           FontSize="{StaticResource FontSizeTitle}"
                                           Foreground="{ThemeResource YanshuaiTextBrush}"
                                           Margin="0,0,0,2"/>
                                <TextBlock x:Name="OrigDevLabel"
                                           Text="AI 对话助手 · 适配 Windows 10 Mobile"
                                           Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,14"/>
                                <Button x:Name="AboutBtn" Content="关于言枢 AI"
                                        Click="OpenWebsiteButton_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

        </Pivot>

        <CommandBar Grid.Row="0" Grid.RowSpan="99" VerticalAlignment="Bottom">
            <AppBarButton x:Name="ExportZipBarBtn" Icon="Upload" Label="导出备份" Click="ExportZip_Click"/>
            <AppBarButton x:Name="ImportZipBarBtn" Icon="Download" Label="从备份恢复" Click="ImportZip_Click"/>
        </CommandBar>
    </Grid>
</Page>
