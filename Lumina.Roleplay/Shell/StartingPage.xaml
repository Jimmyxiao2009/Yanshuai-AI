<Page
    x:Class="yanshuai.StartingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:yanshuai"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource YanshuaiPageBrush}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    MaxWidth="380" Margin="{StaticResource PagePadding}">

            <!-- 心象点 + 引语 -->
            <Ellipse Width="9" Height="9" Fill="{ThemeResource YanshuaiAccentBrush}"
                     HorizontalAlignment="Center" Margin="0,0,0,28"/>

            <TextBlock Text="Welcome to"
                       FontFamily="{ThemeResource YanshuaiEnglishFont}"
                       FontSize="{StaticResource FontSizeSubtitle}"
                       Foreground="{ThemeResource YanshuaiMutedTextBrush}"
                       HorizontalAlignment="Center"/>

            <!-- 品牌名：标题字体 -->
            <TextBlock x:Name="AppTitleText"
                       Text="言枢 AI"
                       FontFamily="{ThemeResource YanshuaiTitleFont}"
                       FontSize="{StaticResource FontSizeDisplay}"
                       Foreground="{ThemeResource YanshuaiAccentBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,48"/>

            <!-- 主操作 -->
            <Button x:Name="StartButton"
                    Content="开始对话"
                    Click="StartButton_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Center"
                    MinWidth="200"
                    Padding="28,14"
                    FontSize="{StaticResource FontSizeBodyLarge}"/>
        </StackPanel>
    </Grid>
</Page>
