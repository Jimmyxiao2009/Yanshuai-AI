<Page
    x:Class="yanshuai.StartingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:yanshuai"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource YanshuaiPageBrush}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock FontSize="38"
                       Foreground="{ThemeResource YanshuaiTextBrush}"
                       HorizontalAlignment="Center"
                       FontWeight="SemiBold">
                Welcome to
            </TextBlock>
            <TextBlock x:Name="AppTitleText"
                       FontSize="48"
                       Foreground="{ThemeResource YanshuaiAccentBrush}"
                       HorizontalAlignment="Center"
                       FontWeight="SemiBold"
                       Text="言枢 AI"
                       Margin="0,8,0,40"/>
            <Button x:Name="StartButton"
                    Content="Start Chat"
                    Click="StartButton_Click"
                    HorizontalAlignment="Center"
                    Width="250" Height="60"
                    FontSize="20"
                    BorderBrush="{ThemeResource YanshuaiAccentBrush}"
                    BorderThickness="2"
                    Background="Transparent"
                    Foreground="{ThemeResource YanshuaiTextBrush}"/>
        </StackPanel>
    </Grid>
</Page>
