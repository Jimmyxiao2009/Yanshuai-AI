<!--
    Controls.xaml — 设计系统：控件样式（只定义一次，全主题共用）
    取代原先 InkScroll/Celadon/MidnightVermilion 各自重复的按钮/图标样式。
    所有颜色 / 字体经 {ThemeResource} 引用主题 token，所以同一套样式自动适配每套主题
    + Light/Dark + 自定义主色覆盖。
    注意：不在 Button 上设 CornerRadius（Control.CornerRadius 需 16299，本项目 min=15063），
    需要圆角时由调用方用 Border 包裹 + {ThemeResource YanshuaiControlCornerRadius}。
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ 导航按钮（侧栏） ═══ -->
    <Style x:Key="NavButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height" Value="52"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiBodyFont}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource YanshuaiAccentHoverBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource YanshuaiAccentPressedBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled"/>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter Margin="16,0" VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ 发送按钮（方形，主色底） ═══ -->
    <Style x:Key="SendButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource YanshuaiAccentBrush}"/>
        <Setter Property="Foreground" Value="{ThemeResource YanshuaiOnAccentBrush}"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ═══ 主操作按钮（主色底） ═══ -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{ThemeResource YanshuaiAccentBrush}"/>
        <Setter Property="Foreground" Value="{ThemeResource YanshuaiOnAccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiBodyFont}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ═══ 次操作按钮（描边） ═══ -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{ThemeResource YanshuaiTextBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource YanshuaiBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiBodyFont}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ═══ 主色描边按钮 ═══ -->
    <Style x:Key="AccentOutlineButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{ThemeResource YanshuaiAccentBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource YanshuaiAccentBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiBodyFont}"/>
    </Style>

    <!-- ═══ 工具栏图标 ═══ -->
    <Style x:Key="ToolbarIconStyle" TargetType="FontIcon">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Foreground" Value="{ThemeResource YanshuaiMutedTextBrush}"/>
    </Style>

</ResourceDictionary>
