<!--
    Tokens.xaml — 设计系统：与主题无关的全局刻度（间距 / 字号 / 尺寸 / 圆角默认）
    主题无关：所有主题共用这些刻度，保证间距/排版一致。
    主题相关的颜色 / 字体 / 控件圆角放在各主题文件里（通过 ThemeResource 覆盖）。
    新页面用 {StaticResource SpaceL} 这类键取代散落的魔法数字。
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ 间距刻度 ═══ -->
    <x:Double x:Key="SpaceXS">4</x:Double>
    <x:Double x:Key="SpaceS">8</x:Double>
    <x:Double x:Key="SpaceM">12</x:Double>
    <x:Double x:Key="SpaceL">16</x:Double>
    <x:Double x:Key="SpaceXL">24</x:Double>
    <x:Double x:Key="SpaceXXL">32</x:Double>

    <Thickness x:Key="PagePadding">16</Thickness>
    <Thickness x:Key="CardPadding">16</Thickness>
    <Thickness x:Key="ListItemPadding">14,10</Thickness>

    <!-- ═══ 字号刻度 ═══ -->
    <x:Double x:Key="FontSizeCaption">12</x:Double>
    <x:Double x:Key="FontSizeBody">14</x:Double>
    <x:Double x:Key="FontSizeBodyLarge">15</x:Double>
    <x:Double x:Key="FontSizeSubtitle">18</x:Double>
    <x:Double x:Key="FontSizeTitle">22</x:Double>
    <x:Double x:Key="FontSizeHeader">28</x:Double>

    <!-- ═══ 图标 / 触控尺寸 ═══ -->
    <x:Double x:Key="IconSizeSmall">13</x:Double>
    <x:Double x:Key="IconSizeMedium">16</x:Double>
    <x:Double x:Key="IconSizeLarge">18</x:Double>
    <x:Double x:Key="TouchTargetHeight">44</x:Double>
    <x:Double x:Key="NavItemHeight">52</x:Double>

    <!-- ═══ 圆角（与主题无关的默认；控件级圆角见各主题 YanshuaiControlCornerRadius） ═══ -->
    <CornerRadius x:Key="CardCornerRadius">10</CornerRadius>
    <CornerRadius x:Key="PillCornerRadius">18</CornerRadius>

</ResourceDictionary>
