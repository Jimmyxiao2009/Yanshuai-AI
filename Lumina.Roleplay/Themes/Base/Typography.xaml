<!--
    Typography.xaml — 设计系统：全局文字样式（只定义一次）
    字体族由各主题通过 ThemeResource 提供（YanshuaiBodyFont / YanshuaiTitleFont），
    所以同一套样式在不同主题下自动换字体（古风用书法体，现代用无衬线）。
    YanshuaiVoiceFont（文楷）是"角色话语"专用字体，与主题无关，全主题共用：
    聊天气泡正文用它，让 AI/角色的话有手写温度，区别于界面的无衬线 BodyFont。
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 角色话语字体（主题无关，全主题共用） -->
    <FontFamily x:Key="YanshuaiVoiceFont">ms-appx:///Assets/Fonts/LXGWWenKai-Regular.ttf#LXGW WenKai</FontFamily>

    <!-- 隐式字体样式：界面全局用 BodyFont（无衬线） -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiBodyFont}"/>
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiBodyFont}"/>
    </Style>
    <Style TargetType="PasswordBox">
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiBodyFont}"/>
    </Style>
    <Style TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiBodyFont}"/>
    </Style>

    <!-- 具名文字样式 -->
    <Style x:Key="DisplayTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiTitleFont}"/>
        <Setter Property="FontSize" Value="34"/>
        <Setter Property="Foreground" Value="{ThemeResource YanshuaiTextBrush}"/>
    </Style>
    <Style x:Key="TitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiTitleFont}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{ThemeResource YanshuaiTextBrush}"/>
    </Style>
    <Style x:Key="SubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiTitleFont}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Foreground" Value="{ThemeResource YanshuaiTextBrush}"/>
    </Style>
    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiBodyFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{ThemeResource YanshuaiTextBrush}"/>
    </Style>
    <!-- 角色话语：文楷，给聊天正文用 -->
    <Style x:Key="VoiceTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiVoiceFont}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="LineHeight" Value="24"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Foreground" Value="{ThemeResource YanshuaiTextBrush}"/>
    </Style>
    <!-- 界面标签：小字、字距、次要色（取代散落的小灰字） -->
    <Style x:Key="LabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiBodyFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="CharacterSpacing" Value="60"/>
        <Setter Property="Foreground" Value="{ThemeResource YanshuaiMutedTextBrush}"/>
    </Style>
    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{ThemeResource YanshuaiBodyFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{ThemeResource YanshuaiMutedTextBrush}"/>
    </Style>

</ResourceDictionary>
