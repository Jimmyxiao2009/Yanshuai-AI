<!--
    Celadon.xaml — 青瓷雅韵（淡雅东方）
    天青 + 月白 + 雅墨
    仅提供颜色 token / 字体 / 透明度；控件样式由 Themes/Base/Controls.xaml 统一定义。
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <!-- ═══ Light ═══ -->
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="YanshuaiPageBrush"        Color="#F4F1E8"/>
            <SolidColorBrush x:Key="YanshuaiChromeBrush"      Color="#1F3A3A"/>
            <SolidColorBrush x:Key="YanshuaiAccentBrush"      Color="#7DB6B0"/>
            <SolidColorBrush x:Key="YanshuaiPaneHeaderBrush"  Color="#2D4F4F"/>
            <SolidColorBrush x:Key="YanshuaiSurfaceBrush"     Color="#E8E5DC"/>
            <SolidColorBrush x:Key="YanshuaiPanelBrush"       Color="#FAF8F0"/>
            <SolidColorBrush x:Key="YanshuaiSubtlePanelBrush" Color="#EEEAE0"/>
            <SolidColorBrush x:Key="YanshuaiBorderBrush"      Color="#B8C9C5"/>
            <SolidColorBrush x:Key="YanshuaiTextBrush"        Color="#1F3A3A"/>
            <SolidColorBrush x:Key="YanshuaiMutedTextBrush"   Color="#5A8E89"/>
            <SolidColorBrush x:Key="YanshuaiShadowBrush"      Color="#221F3A3A"/>
            <SolidColorBrush x:Key="YanshuaiUserBubbleBrush"  Color="#7DB6B0"/>
            <SolidColorBrush x:Key="YanshuaiAiBubbleBrush"    Color="#FAF8F0"/>
            <!-- 设计系统新增 token -->
            <SolidColorBrush x:Key="YanshuaiOnAccentBrush"      Color="#142929"/>
            <SolidColorBrush x:Key="YanshuaiAccentHoverBrush"   Color="#337DB6B0"/>
            <SolidColorBrush x:Key="YanshuaiAccentPressedBrush" Color="#557DB6B0"/>
        </ResourceDictionary>
        <!-- ═══ Dark ═══ -->
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="YanshuaiPageBrush"        Color="#142929"/>
            <SolidColorBrush x:Key="YanshuaiChromeBrush"      Color="#0E1F1F"/>
            <SolidColorBrush x:Key="YanshuaiAccentBrush"      Color="#A4D0CB"/>
            <SolidColorBrush x:Key="YanshuaiPaneHeaderBrush"  Color="#2A4747"/>
            <SolidColorBrush x:Key="YanshuaiSurfaceBrush"     Color="#1F3A3A"/>
            <SolidColorBrush x:Key="YanshuaiPanelBrush"       Color="#264343"/>
            <SolidColorBrush x:Key="YanshuaiSubtlePanelBrush" Color="#2C4949"/>
            <SolidColorBrush x:Key="YanshuaiBorderBrush"      Color="#3F5E5E"/>
            <SolidColorBrush x:Key="YanshuaiTextBrush"        Color="#F4F1E8"/>
            <SolidColorBrush x:Key="YanshuaiMutedTextBrush"   Color="#A4D0CB"/>
            <SolidColorBrush x:Key="YanshuaiShadowBrush"      Color="#50000000"/>
            <SolidColorBrush x:Key="YanshuaiUserBubbleBrush"  Color="#A4D0CB"/>
            <SolidColorBrush x:Key="YanshuaiAiBubbleBrush"    Color="#264343"/>
            <!-- 设计系统新增 token -->
            <SolidColorBrush x:Key="YanshuaiOnAccentBrush"      Color="#142929"/>
            <SolidColorBrush x:Key="YanshuaiAccentHoverBrush"   Color="#33A4D0CB"/>
            <SolidColorBrush x:Key="YanshuaiAccentPressedBrush" Color="#55A4D0CB"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- ═══ 控件圆角 ═══ -->
    <CornerRadius x:Key="YanshuaiControlCornerRadius">6</CornerRadius>

    <!-- ═══════ 颜色（兼容 legacy 键） ═══════ -->
    <Color x:Key="ThemeAccentColor">#7DB6B0</Color>          <!-- 天青 -->
    <Color x:Key="ThemeAccentColorDark">#5A8E89</Color>
    <Color x:Key="ThemeAccentColorLight">#A4D0CB</Color>

    <SolidColorBrush x:Key="ThemeAccentBrush"      Color="#7DB6B0"/>
    <SolidColorBrush x:Key="ThemeAccentBrushDark"  Color="#5A8E89"/>
    <SolidColorBrush x:Key="ThemeAccentBrushLight" Color="#A4D0CB"/>

    <Color x:Key="NavHeaderColor">#1F3A3A</Color>
    <Color x:Key="NavHeaderGradientEnd">#2D4F4F</Color>
    <Color x:Key="NavBackground">#142929</Color>

    <Color x:Key="UserBubbleColor">#7DB6B0</Color>
    <Color x:Key="UserBubbleFgColor">#142929</Color>
    <Color x:Key="AiBubbleColor">#F4F1E8</Color>
    <Color x:Key="AiBubbleFgColor">#1F3A3A</Color>
    <Color x:Key="ReasoningBgColor">#227DB6B0</Color>

    <Color x:Key="InputBoxBgColor">#F4F1E8</Color>
    <Color x:Key="InputBoxBorderColor">#557DB6B0</Color>
    <SolidColorBrush x:Key="InputBoxBg"     Color="#F4F1E8"/>
    <SolidColorBrush x:Key="InputBoxBorder" Color="#557DB6B0"/>

    <SolidColorBrush x:Key="BrandTitleBrush"    Color="#1F3A3A"/>
    <SolidColorBrush x:Key="BrandSubtitleBrush" Color="#5A8E89"/>

    <!-- ═══════ 字体（思源宋 + EB Garamond） ═══════ -->
    <FontFamily x:Key="YanshuaiTitleFont">ms-appx:///Assets/Fonts/SourceHanSerif-Bold.ttf#Source Han Serif SC</FontFamily>
    <FontFamily x:Key="YanshuaiBodyFont">ms-appx:///Assets/Fonts/SourceHanSerif-Regular.ttf#Source Han Serif SC</FontFamily>
    <FontFamily x:Key="YanshuaiEnglishFont">ms-appx:///Assets/Fonts/EBGaramond-Regular.ttf#EB Garamond</FontFamily>
    <FontFamily x:Key="YanshuaiEnglishItalicFont">ms-appx:///Assets/Fonts/EBGaramond-Italic.ttf#EB Garamond</FontFamily>

    <!-- ═══════ 透明度常量 ═══════ -->
    <x:Double x:Key="NavIconOpacity">0.85</x:Double>
    <x:Double x:Key="ToolbarIconOpacity">0.65</x:Double>
    <x:Double x:Key="ActionIconOpacity">0.55</x:Double>

</ResourceDictionary>
