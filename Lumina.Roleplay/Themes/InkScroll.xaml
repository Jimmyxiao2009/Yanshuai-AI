<!--
    InkScroll.xaml — 墨韵书卷（古风水墨）
    宣纸米黄 + 墨黑 + 朱红印章
    仅提供颜色 token / 字体 / 透明度；控件样式由 Themes/Base/Controls.xaml 统一定义。
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <!-- ═══ Light ═══ -->
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="YanshuaiPageBrush"        Color="#F5EFE0"/>
            <SolidColorBrush x:Key="YanshuaiChromeBrush"      Color="#2B2620"/>
            <SolidColorBrush x:Key="YanshuaiAccentBrush"      Color="#A33A2C"/>
            <SolidColorBrush x:Key="YanshuaiPaneHeaderBrush"  Color="#3D352B"/>
            <SolidColorBrush x:Key="YanshuaiSurfaceBrush"     Color="#EFE5D2"/>
            <SolidColorBrush x:Key="YanshuaiPanelBrush"       Color="#FAF4E8"/>
            <SolidColorBrush x:Key="YanshuaiSubtlePanelBrush" Color="#F0E5D0"/>
            <SolidColorBrush x:Key="YanshuaiBorderBrush"      Color="#C9B295"/>
            <SolidColorBrush x:Key="YanshuaiTextBrush"        Color="#2B2620"/>
            <SolidColorBrush x:Key="YanshuaiMutedTextBrush"   Color="#6E5A48"/>
            <SolidColorBrush x:Key="YanshuaiShadowBrush"      Color="#28000000"/>
            <SolidColorBrush x:Key="YanshuaiUserBubbleBrush"  Color="#A33A2C"/>
            <SolidColorBrush x:Key="YanshuaiAiBubbleBrush"    Color="#FAF4E8"/>
            <!-- 设计系统新增 token -->
            <SolidColorBrush x:Key="YanshuaiOnAccentBrush"      Color="#F5EFE0"/>
            <SolidColorBrush x:Key="YanshuaiAccentHoverBrush"   Color="#33A33A2C"/>
            <SolidColorBrush x:Key="YanshuaiAccentPressedBrush" Color="#55A33A2C"/>
        </ResourceDictionary>
        <!-- ═══ Dark ═══ -->
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="YanshuaiPageBrush"        Color="#1F1A14"/>
            <SolidColorBrush x:Key="YanshuaiChromeBrush"      Color="#15110D"/>
            <SolidColorBrush x:Key="YanshuaiAccentBrush"      Color="#C75646"/>
            <SolidColorBrush x:Key="YanshuaiPaneHeaderBrush"  Color="#5A3F30"/>
            <SolidColorBrush x:Key="YanshuaiSurfaceBrush"     Color="#2B2620"/>
            <SolidColorBrush x:Key="YanshuaiPanelBrush"       Color="#332B23"/>
            <SolidColorBrush x:Key="YanshuaiSubtlePanelBrush" Color="#3A2F26"/>
            <SolidColorBrush x:Key="YanshuaiBorderBrush"      Color="#5A463A"/>
            <SolidColorBrush x:Key="YanshuaiTextBrush"        Color="#F5EFE0"/>
            <SolidColorBrush x:Key="YanshuaiMutedTextBrush"   Color="#C9B295"/>
            <SolidColorBrush x:Key="YanshuaiShadowBrush"      Color="#50000000"/>
            <SolidColorBrush x:Key="YanshuaiUserBubbleBrush"  Color="#C75646"/>
            <SolidColorBrush x:Key="YanshuaiAiBubbleBrush"    Color="#332B23"/>
            <!-- 设计系统新增 token -->
            <SolidColorBrush x:Key="YanshuaiOnAccentBrush"      Color="#F5EFE0"/>
            <SolidColorBrush x:Key="YanshuaiAccentHoverBrush"   Color="#33C75646"/>
            <SolidColorBrush x:Key="YanshuaiAccentPressedBrush" Color="#55C75646"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- ═══ 控件圆角（古风＝柔和） ═══ -->
    <CornerRadius x:Key="YanshuaiControlCornerRadius">6</CornerRadius>

    <!-- ═══════ 颜色（兼容 legacy 键） ═══════ -->
    <Color x:Key="ThemeAccentColor">#A33A2C</Color>          <!-- 朱砂红 -->
    <Color x:Key="ThemeAccentColorDark">#7A2A1F</Color>      <!-- 深朱砂 -->
    <Color x:Key="ThemeAccentColorLight">#C75646</Color>     <!-- 浅朱砂 -->

    <SolidColorBrush x:Key="ThemeAccentBrush"      Color="#A33A2C"/>
    <SolidColorBrush x:Key="ThemeAccentBrushDark"  Color="#7A2A1F"/>
    <SolidColorBrush x:Key="ThemeAccentBrushLight" Color="#C75646"/>

    <!-- 导航栏 -->
    <Color x:Key="NavHeaderColor">#2B2620</Color>
    <Color x:Key="NavHeaderGradientEnd">#3D352B</Color>
    <Color x:Key="NavBackground">#1F1A14</Color>

    <!-- 对话气泡 -->
    <Color x:Key="UserBubbleColor">#A33A2C</Color>
    <Color x:Key="UserBubbleFgColor">#F5EFE0</Color>
    <Color x:Key="AiBubbleColor">#F5EFE0</Color>
    <Color x:Key="AiBubbleFgColor">#2B2620</Color>
    <Color x:Key="ReasoningBgColor">#22A33A2C</Color>

    <!-- 输入区 -->
    <Color x:Key="InputBoxBgColor">#FAF4E8</Color>
    <Color x:Key="InputBoxBorderColor">#552B2620</Color>
    <SolidColorBrush x:Key="InputBoxBg"     Color="#FAF4E8"/>
    <SolidColorBrush x:Key="InputBoxBorder" Color="#552B2620"/>

    <!-- 标题/品牌 -->
    <SolidColorBrush x:Key="BrandTitleBrush"    Color="#A33A2C"/>
    <SolidColorBrush x:Key="BrandSubtitleBrush" Color="#7A6450"/>

    <!-- ═══════ 字体 ═══════ -->
    <FontFamily x:Key="YanshuaiTitleFont">ms-appx:///Assets/Fonts/LXGWWenKai-Bold.ttf#LXGW WenKai</FontFamily>
    <FontFamily x:Key="YanshuaiBodyFont">ms-appx:///Assets/Fonts/LXGWWenKai-Regular.ttf#LXGW WenKai</FontFamily>
    <FontFamily x:Key="YanshuaiEnglishFont">ms-appx:///Assets/Fonts/EBGaramond-Regular.ttf#EB Garamond</FontFamily>
    <FontFamily x:Key="YanshuaiEnglishItalicFont">ms-appx:///Assets/Fonts/EBGaramond-Italic.ttf#EB Garamond</FontFamily>

    <!-- ═══════ 透明度常量 ═══════ -->
    <x:Double x:Key="NavIconOpacity">0.85</x:Double>
    <x:Double x:Key="ToolbarIconOpacity">0.65</x:Double>
    <x:Double x:Key="ActionIconOpacity">0.55</x:Double>

</ResourceDictionary>
