<!--
    MidnightVermilion.xaml — 朱砂深夜（暗色国风）
    深夜墨蓝 + 朱砂红 + 鎏金
    *** 此主题强烈推荐使用 Dark 模式 ***
    仅提供颜色 token / 字体 / 透明度；控件样式由 Themes/Base/Controls.xaml 统一定义。
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <!-- ═══ Light：朱砂深夜也提供亮色变体 ═══ -->
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="YanshuaiPageBrush"        Color="#F5F0E8"/>
            <SolidColorBrush x:Key="YanshuaiChromeBrush"      Color="#1A1B26"/>
            <SolidColorBrush x:Key="YanshuaiAccentBrush"      Color="#D4504A"/>
            <SolidColorBrush x:Key="YanshuaiPaneHeaderBrush"  Color="#2A2B36"/>
            <SolidColorBrush x:Key="YanshuaiSurfaceBrush"     Color="#EBE3D5"/>
            <SolidColorBrush x:Key="YanshuaiPanelBrush"       Color="#FFFAF0"/>
            <SolidColorBrush x:Key="YanshuaiSubtlePanelBrush" Color="#F0E8D8"/>
            <SolidColorBrush x:Key="YanshuaiBorderBrush"      Color="#C9A86A"/>
            <SolidColorBrush x:Key="YanshuaiTextBrush"        Color="#1A1B26"/>
            <SolidColorBrush x:Key="YanshuaiMutedTextBrush"   Color="#5A4B3A"/>
            <SolidColorBrush x:Key="YanshuaiShadowBrush"      Color="#28000000"/>
            <SolidColorBrush x:Key="YanshuaiUserBubbleBrush"  Color="#D4504A"/>
            <SolidColorBrush x:Key="YanshuaiAiBubbleBrush"    Color="#FFFAF0"/>
            <!-- 设计系统新增 token（hover/press 用鎏金，呼应原设计） -->
            <SolidColorBrush x:Key="YanshuaiOnAccentBrush"      Color="#F5F0E8"/>
            <SolidColorBrush x:Key="YanshuaiAccentHoverBrush"   Color="#33C9A86A"/>
            <SolidColorBrush x:Key="YanshuaiAccentPressedBrush" Color="#55C9A86A"/>
        </ResourceDictionary>
        <!-- ═══ Dark：暗色国风原型 ═══ -->
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="YanshuaiPageBrush"        Color="#0F1015"/>
            <SolidColorBrush x:Key="YanshuaiChromeBrush"      Color="#080A0F"/>
            <SolidColorBrush x:Key="YanshuaiAccentBrush"      Color="#D4504A"/>
            <SolidColorBrush x:Key="YanshuaiPaneHeaderBrush"  Color="#1A1B26"/>
            <SolidColorBrush x:Key="YanshuaiSurfaceBrush"     Color="#1A1B26"/>
            <SolidColorBrush x:Key="YanshuaiPanelBrush"       Color="#23252F"/>
            <SolidColorBrush x:Key="YanshuaiSubtlePanelBrush" Color="#2A2B36"/>
            <SolidColorBrush x:Key="YanshuaiBorderBrush"      Color="#C9A86A"/>
            <SolidColorBrush x:Key="YanshuaiTextBrush"        Color="#F5F0E8"/>
            <SolidColorBrush x:Key="YanshuaiMutedTextBrush"   Color="#888A9D"/>
            <SolidColorBrush x:Key="YanshuaiShadowBrush"      Color="#80000000"/>
            <SolidColorBrush x:Key="YanshuaiUserBubbleBrush"  Color="#D4504A"/>
            <SolidColorBrush x:Key="YanshuaiAiBubbleBrush"    Color="#1A1B26"/>
            <!-- 设计系统新增 token -->
            <SolidColorBrush x:Key="YanshuaiOnAccentBrush"      Color="#F5F0E8"/>
            <SolidColorBrush x:Key="YanshuaiAccentHoverBrush"   Color="#33C9A86A"/>
            <SolidColorBrush x:Key="YanshuaiAccentPressedBrush" Color="#55C9A86A"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- ═══ 控件圆角 ═══ -->
    <CornerRadius x:Key="YanshuaiControlCornerRadius">6</CornerRadius>

    <!-- ═══════ 颜色（兼容 legacy 键） ═══════ -->
    <Color x:Key="ThemeAccentColor">#D4504A</Color>          <!-- 朱砂红 -->
    <Color x:Key="ThemeAccentColorDark">#A33A36</Color>
    <Color x:Key="ThemeAccentColorLight">#E87672</Color>
    <Color x:Key="ThemeGoldColor">#C9A86A</Color>            <!-- 鎏金 -->

    <SolidColorBrush x:Key="ThemeAccentBrush"      Color="#D4504A"/>
    <SolidColorBrush x:Key="ThemeAccentBrushDark"  Color="#A33A36"/>
    <SolidColorBrush x:Key="ThemeAccentBrushLight" Color="#E87672"/>
    <SolidColorBrush x:Key="ThemeGoldBrush"        Color="#C9A86A"/>

    <Color x:Key="NavHeaderColor">#1A1B26</Color>
    <Color x:Key="NavHeaderGradientEnd">#2A2B36</Color>
    <Color x:Key="NavBackground">#0F1015</Color>

    <Color x:Key="UserBubbleColor">#D4504A</Color>
    <Color x:Key="UserBubbleFgColor">#F5F0E8</Color>
    <Color x:Key="AiBubbleColor">#1A1B26</Color>
    <Color x:Key="AiBubbleFgColor">#F5F0E8</Color>
    <Color x:Key="ReasoningBgColor">#22C9A86A</Color>

    <Color x:Key="InputBoxBgColor">#1A1B26</Color>
    <Color x:Key="InputBoxBorderColor">#55C9A86A</Color>
    <SolidColorBrush x:Key="InputBoxBg"     Color="#1A1B26"/>
    <SolidColorBrush x:Key="InputBoxBorder" Color="#55C9A86A"/>

    <SolidColorBrush x:Key="BrandTitleBrush"    Color="#C9A86A"/>
    <SolidColorBrush x:Key="BrandSubtitleBrush" Color="#888A9D"/>

    <!-- ═══════ 字体（站酷小薇 + Cormorant） ═══════ -->
    <FontFamily x:Key="YanshuaiTitleFont">ms-appx:///Assets/Fonts/ZCOOLXiaoWei-Regular.ttf#ZCOOL XiaoWei</FontFamily>
    <FontFamily x:Key="YanshuaiBodyFont">ms-appx:///Assets/Fonts/LXGWWenKai-Regular.ttf#LXGW WenKai</FontFamily>
    <FontFamily x:Key="YanshuaiEnglishFont">ms-appx:///Assets/Fonts/Cormorant-Regular.ttf#Cormorant Light</FontFamily>
    <FontFamily x:Key="YanshuaiEnglishItalicFont">ms-appx:///Assets/Fonts/Cormorant-Italic.ttf#Cormorant Light</FontFamily>

    <!-- ═══════ 透明度常量 ═══════ -->
    <x:Double x:Key="NavIconOpacity">0.85</x:Double>
    <x:Double x:Key="ToolbarIconOpacity">0.7</x:Double>
    <x:Double x:Key="ActionIconOpacity">0.6</x:Double>

</ResourceDictionary>
