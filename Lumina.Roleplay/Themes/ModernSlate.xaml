<!--
    ModernSlate.xaml — 现代·石板靛蓝（扁平现代）
    冷调石板灰 + 靛蓝强调 + 无衬线系统字体 + 更锐的圆角
    用于验证设计系统：同一套 base 控件样式，仅换 token 即得到与古风主题
    截然不同的现代观感（不是只换配色）。
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <!-- ═══ Light ═══ -->
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="YanshuaiPageBrush"        Color="#F7F8FA"/>
            <SolidColorBrush x:Key="YanshuaiChromeBrush"      Color="#1E2530"/>
            <SolidColorBrush x:Key="YanshuaiAccentBrush"      Color="#4F6BED"/>
            <SolidColorBrush x:Key="YanshuaiPaneHeaderBrush"  Color="#2A3340"/>
            <SolidColorBrush x:Key="YanshuaiSurfaceBrush"     Color="#FFFFFF"/>
            <SolidColorBrush x:Key="YanshuaiPanelBrush"       Color="#FFFFFF"/>
            <SolidColorBrush x:Key="YanshuaiSubtlePanelBrush" Color="#EEF1F5"/>
            <SolidColorBrush x:Key="YanshuaiBorderBrush"      Color="#D8DEE6"/>
            <SolidColorBrush x:Key="YanshuaiTextBrush"        Color="#1A1F28"/>
            <SolidColorBrush x:Key="YanshuaiMutedTextBrush"   Color="#6B7585"/>
            <SolidColorBrush x:Key="YanshuaiShadowBrush"      Color="#1A000000"/>
            <SolidColorBrush x:Key="YanshuaiUserBubbleBrush"  Color="#4F6BED"/>
            <SolidColorBrush x:Key="YanshuaiAiBubbleBrush"    Color="#FFFFFF"/>
            <!-- 设计系统新增 token -->
            <SolidColorBrush x:Key="YanshuaiOnAccentBrush"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="YanshuaiAccentHoverBrush"   Color="#224F6BED"/>
            <SolidColorBrush x:Key="YanshuaiAccentPressedBrush" Color="#334F6BED"/>
        </ResourceDictionary>
        <!-- ═══ Dark ═══ -->
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="YanshuaiPageBrush"        Color="#14171C"/>
            <SolidColorBrush x:Key="YanshuaiChromeBrush"      Color="#0E1116"/>
            <SolidColorBrush x:Key="YanshuaiAccentBrush"      Color="#6B86F0"/>
            <SolidColorBrush x:Key="YanshuaiPaneHeaderBrush"  Color="#1B2029"/>
            <SolidColorBrush x:Key="YanshuaiSurfaceBrush"     Color="#1B2029"/>
            <SolidColorBrush x:Key="YanshuaiPanelBrush"       Color="#20262F"/>
            <SolidColorBrush x:Key="YanshuaiSubtlePanelBrush" Color="#262D38"/>
            <SolidColorBrush x:Key="YanshuaiBorderBrush"      Color="#333B47"/>
            <SolidColorBrush x:Key="YanshuaiTextBrush"        Color="#E6EAF0"/>
            <SolidColorBrush x:Key="YanshuaiMutedTextBrush"   Color="#8A94A6"/>
            <SolidColorBrush x:Key="YanshuaiShadowBrush"      Color="#60000000"/>
            <SolidColorBrush x:Key="YanshuaiUserBubbleBrush"  Color="#5C77E8"/>
            <SolidColorBrush x:Key="YanshuaiAiBubbleBrush"    Color="#20262F"/>
            <!-- 设计系统新增 token -->
            <SolidColorBrush x:Key="YanshuaiOnAccentBrush"      Color="#FFFFFF"/>
            <SolidColorBrush x:Key="YanshuaiAccentHoverBrush"   Color="#226B86F0"/>
            <SolidColorBrush x:Key="YanshuaiAccentPressedBrush" Color="#336B86F0"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- ═══ 控件圆角（现代＝更锐） ═══ -->
    <CornerRadius x:Key="YanshuaiControlCornerRadius">4</CornerRadius>

    <!-- ═══ 兼容：扁平 legacy 颜色键 ═══ -->
    <Color x:Key="ThemeAccentColor">#4F6BED</Color>
    <Color x:Key="ThemeAccentColorDark">#3A52C4</Color>
    <Color x:Key="ThemeAccentColorLight">#6B86F0</Color>
    <SolidColorBrush x:Key="ThemeAccentBrush"      Color="#4F6BED"/>
    <SolidColorBrush x:Key="ThemeAccentBrushDark"  Color="#3A52C4"/>
    <SolidColorBrush x:Key="ThemeAccentBrushLight" Color="#6B86F0"/>

    <Color x:Key="NavHeaderColor">#1E2530</Color>
    <Color x:Key="NavHeaderGradientEnd">#2A3340</Color>
    <Color x:Key="NavBackground">#14171C</Color>

    <Color x:Key="UserBubbleColor">#4F6BED</Color>
    <Color x:Key="UserBubbleFgColor">#FFFFFF</Color>
    <Color x:Key="AiBubbleColor">#FFFFFF</Color>
    <Color x:Key="AiBubbleFgColor">#1A1F28</Color>
    <Color x:Key="ReasoningBgColor">#224F6BED</Color>

    <Color x:Key="InputBoxBgColor">#FFFFFF</Color>
    <Color x:Key="InputBoxBorderColor">#D8DEE6</Color>
    <SolidColorBrush x:Key="InputBoxBg"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBoxBorder" Color="#D8DEE6"/>

    <SolidColorBrush x:Key="BrandTitleBrush"    Color="#4F6BED"/>
    <SolidColorBrush x:Key="BrandSubtitleBrush" Color="#6B7585"/>

    <!-- ═══ 字体（系统无衬线，刻意区别于古风书法体） ═══ -->
    <FontFamily x:Key="YanshuaiTitleFont">Segoe UI</FontFamily>
    <FontFamily x:Key="YanshuaiBodyFont">Segoe UI</FontFamily>
    <FontFamily x:Key="YanshuaiEnglishFont">Segoe UI</FontFamily>
    <FontFamily x:Key="YanshuaiEnglishItalicFont">Segoe UI</FontFamily>

    <!-- ═══ 透明度 ═══ -->
    <x:Double x:Key="NavIconOpacity">0.9</x:Double>
    <x:Double x:Key="ToolbarIconOpacity">0.7</x:Double>
    <x:Double x:Key="ActionIconOpacity">0.6</x:Double>

</ResourceDictionary>
