<Application
    x:Class="YanshuaiChat.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="BgColor">#0B0B0B</Color>
            <Color x:Key="AccentColor">#1BA1E2</Color>
            <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
            <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="DimBrush" Color="#999999"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#1B1B1B"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
