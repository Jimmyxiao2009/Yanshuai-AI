<Page
    x:Class="YanshuaiChat.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Metro 页眉 -->
        <TextBlock Grid.Row="0" Text="言枢 · ONDEVICE AI"
                   Margin="16,14,16,0" FontSize="12" CharacterSpacing="180"
                   Foreground="{StaticResource DimBrush}"/>
        <TextBlock Grid.Row="1" Text="对话"
                   Margin="14,0,16,4" FontSize="40" FontWeight="Light"
                   Foreground="{StaticResource TextBrush}"/>

        <!-- 消息流 -->
        <ScrollViewer x:Name="ChatScroll" Grid.Row="2" Margin="16,4,16,4"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ChatPanel">
                <TextBlock x:Name="StatusText"
                           Text="正在检查模型…"
                           Foreground="{StaticResource DimBrush}" FontSize="13"
                           TextWrapping="Wrap" Margin="0,4,0,8"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 输入区 -->
        <Grid Grid.Row="3" Margin="16,4,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="InputBox" Grid.Column="0"
                     PlaceholderText="输入内容…"
                     Background="{StaticResource SurfaceBrush}"
                     Foreground="{StaticResource TextBrush}"
                     BorderThickness="0"
                     IsEnabled="False"
                     KeyDown="OnInputKeyDown"/>
            <Button x:Name="SendButton" Grid.Column="1" Content="发送"
                    Margin="8,0,0,0" MinWidth="72"
                    Background="{StaticResource AccentBrush}" Foreground="White"
                    BorderThickness="0"
                    IsEnabled="False"
                    Click="OnSendClick"/>
        </Grid>
    </Grid>

    <Page.BottomAppBar>
        <CommandBar Background="{StaticResource SurfaceBrush}" ClosedDisplayMode="Minimal">
            <AppBarButton x:Name="ImportButton" Icon="Import" Label="导入模型" Click="OnImportModelClick"/>
            <AppBarButton Icon="Delete" Label="清空会话" Click="OnClearClick"/>
        </CommandBar>
    </Page.BottomAppBar>
</Page>
