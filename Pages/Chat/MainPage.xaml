<Page
    x:Class="yanshuai.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:yanshuai"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <!-- SplitView: Pane = hamburger menu, Content = chat UI -->
        <SplitView x:Name="NavPane"
                   DisplayMode="Overlay"
                   IsPaneOpen="False"
                   PanePlacement="Left"
                   OpenPaneLength="260">

            <!-- ══ Hamburger pane ══════════════════════════════════════════ -->
            <SplitView.Pane>
                <Grid Background="#1A1A1A">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="51"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Pane accent header strip -->
                    <Grid Grid.Row="0" Background="{ThemeResource SystemAccentColor}">
                        <TextBlock Text="言枢"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Light"
                                   VerticalAlignment="Center"
                                   Margin="16,0"/>
                    </Grid>

                    <!-- Nav items -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,4">

                        <Button Click="Nav_Conversations_Click"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0"
                                Height="52" Padding="16,0">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE8F1;" FontSize="18" Width="28"
                                          Foreground="White" Opacity="0.85"/>
                                <TextBlock Text="对话列表" Foreground="White" Opacity="0.85"
                                           VerticalAlignment="Center" FontSize="15" Margin="14,0,0,0"/>
                            </StackPanel>
                        </Button>





                        <Button Click="Nav_Api_Click"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0"
                                Height="52" Padding="16,0">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE774;" FontSize="18" Width="28"
                                          Foreground="White" Opacity="0.85"/>
                                <TextBlock Text="API 配置" Foreground="White" Opacity="0.85"
                                           VerticalAlignment="Center" FontSize="15" Margin="14,0,0,0"/>
                            </StackPanel>
                        </Button>



                        </StackPanel>

                        <!-- 底部固定区：用户资料 + 设置 -->
                        <StackPanel Grid.Row="1">
                            <Border BorderBrush="#3A3A3A" BorderThickness="0,1,0,0"/>

                            <Button Click="Nav_Settings_Click"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Background="Transparent" BorderThickness="0"
                                    Height="52" Padding="16,0">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE713;" FontSize="18" Width="28"
                                              Foreground="White" Opacity="0.85"/>
                                    <TextBlock Text="设置" Foreground="White" Opacity="0.85"
                                               VerticalAlignment="Center" FontSize="15" Margin="14,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </SplitView.Pane>

            <!-- ══ Main content ═══════════════════════════════════════════ -->
            <SplitView.Content>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="51"/>   <!-- top bar -->
                        <RowDefinition Height="40"/>   <!-- conv title -->
                        <RowDefinition Height="*"/>    <!-- chat -->
                        <RowDefinition Height="Auto"/> <!-- input -->
                    </Grid.RowDefinitions>

                    <!-- ── Top bar ────────────────────────────────────── -->
                    <Grid Grid.Row="0" Background="#1A1A1A">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 汉堡按钮：用 Grid 作 Content，确保图标真正居左 -->
                        <Button Grid.Column="0"
                                Click="HamburgerBtn_Click"
                                Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                Height="51" Padding="0">
                            <Grid Width="52" Height="51">
                                <FontIcon Glyph="&#xE700;" FontSize="18" Foreground="White"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Margin="14,0,0,0"/>
                            </Grid>
                        </Button>

                        <TextBlock Grid.Column="1"
                                   Text="言枢"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="Light"
                                   VerticalAlignment="Center"
                                   Margin="4,0"/>
                    </Grid>

                    <!-- ── Conversation title bar ─────────────────────── -->
                    <Grid Grid.Row="1"
                          Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                          BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>     <!-- title -->
                            <ColumnDefinition Width="Auto"/>  <!-- appearance -->
                            <ColumnDefinition Width="Auto"/>  <!-- settings -->
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="ConvTitleLabel"
                                   Grid.Column="0"
                                   Text="新对话"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="14,0,8,0"
                                   Opacity="0.7"
                                   TextTrimming="CharacterEllipsis"/>

                        <Button Grid.Column="1"
                                Click="ConvAppearanceBtn_Click"
                                Background="Transparent" BorderThickness="0"
                                Width="40" Height="40"
                                ToolTipService.ToolTip="外观设置">
                            <FontIcon Glyph="&#xE771;" FontSize="15"/>
                        </Button>

                        <Button Grid.Column="2"
                                Click="ConvSettingsBtn_Click"
                                Background="Transparent" BorderThickness="0"
                                Width="44" Height="40">
                            <FontIcon Glyph="&#xE713;" FontSize="16"/>
                        </Button>
                    </Grid>

                    <!-- ── Chat area ──────────────────────────────────── -->
                    <Grid Grid.Row="2">
                        <!-- Appearance: background layer (solid color or image) -->
                        <Border x:Name="ChatBgSolid"
                                Visibility="Collapsed"/>
                        <Image  x:Name="ChatBgImage"
                                Stretch="UniformToFill"
                                Visibility="Collapsed"/>
                        <!-- 图片背景暗度遮罩 -->
                        <Border x:Name="ChatBgDimOverlay"
                                Background="#80000000"
                                Visibility="Collapsed"/>

                        <!-- 新对话欢迎界面 -->
                        <StackPanel x:Name="WelcomePanel"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Visibility="Collapsed"
                                    Margin="32,0">
                            <FontIcon Glyph="&#xE8BD;" FontSize="52"
                                      Opacity="0.18" HorizontalAlignment="Center"/>
                            <TextBlock Text="言枢"
                                       FontSize="28" FontWeight="Light"
                                       Opacity="0.55" HorizontalAlignment="Center"
                                       Margin="0,16,0,6"/>
                            <TextBlock x:Name="WelcomeSubtitle"
                                       Text="在下方输入消息开始对话"
                                       FontSize="14" Opacity="0.35"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>

                        <ScrollViewer x:Name="ChatScrollViewer"
                                  Margin="0,4,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="ChatItems" VerticalAlignment="Top">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,3">

                                        <!-- Reasoning block: left-accent border style -->
                                        <Border Visibility="{Binding HasReasoningVisibility}"
                                                BorderBrush="{ThemeResource SystemAccentColor}"
                                                BorderThickness="3,0,0,0"
                                                Background="{ThemeResource SystemControlBackgroundListLowBrush}"
                                                Margin="12,0,12,3"
                                                MaxWidth="580"
                                                HorizontalAlignment="{Binding Align}">
                                            <StackPanel>
                                                <Button Tag="{Binding}"

                                                        Click="ToggleReasoning_Click"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        HorizontalAlignment="Stretch"
                                                        Padding="10,6">
                                                    <StackPanel Orientation="Horizontal">
                                                        <FontIcon Glyph="&#xE945;" FontSize="12"
                                                                  Opacity="0.65" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding ReasoningLabel}"
                                                                   FontSize="12" Opacity="0.75"/>
                                                    </StackPanel>
                                                </Button>
                                                <TextBlock Text="{Binding ReasoningContent}"
                                                           Visibility="{Binding ReasoningBodyVisibility}"
                                                           TextWrapping="Wrap"
                                                           FontSize="13" Opacity="0.75"
                                                           Padding="10,0,10,8"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- 工具调用步骤（思维链） -->
                                        <Border Visibility="{Binding ToolStepsVisibility}"
                                                Margin="12,4,12,2" MaxWidth="580"
                                                HorizontalAlignment="{Binding Align}"
                                                CornerRadius="8"
                                                BorderThickness="1"
                                                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                                            <Border.Background>
                                                <SolidColorBrush Color="{ThemeResource SystemAltHighColor}" Opacity="0.6"/>
                                            </Border.Background>
                                            <StackPanel>
                                                <!-- 标题行 -->
                                                <Button Tag="{Binding}" Click="ToggleToolSteps_Click"
                                                        Background="Transparent" BorderThickness="0"
                                                        HorizontalAlignment="Stretch" Padding="10,8,10,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <FontIcon Grid.Column="0" Glyph="&#xE9F5;" FontSize="13"
                                                                  Foreground="{ThemeResource SystemAccentColor}"
                                                                  Margin="0,0,8,0"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ToolStepsLabel}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{ThemeResource SystemAccentColor}"
                                                                   VerticalAlignment="Center"/>
                                                        <FontIcon Grid.Column="2"
                                                                  Glyph="{Binding ToolStepsChevron}"
                                                                  FontFamily="Segoe MDL2 Assets"
                                                                  FontSize="10" Opacity="0.6"
                                                                  Foreground="{ThemeResource ApplicationForegroundThemeBrush}"/>
                                                    </Grid>
                                                </Button>
                                                <!-- 分隔线 -->
                                                <Rectangle Visibility="{Binding ToolStepsBodyVisibility}"
                                                           Height="1" HorizontalAlignment="Stretch"
                                                           Fill="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                                           Margin="0"/>
                                                <!-- 步骤内容 -->
                                                <ItemsControl Visibility="{Binding ToolStepsBodyVisibility}"
                                                              ItemsSource="{Binding ToolStepsList}"
                                                              Padding="8,6,8,8">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="2,3">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="20"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                                           FontSize="12" VerticalAlignment="Top"
                                                                           Margin="0,1,0,0"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding ToolName}"
                                                                           FontSize="12" FontWeight="SemiBold"
                                                                           Foreground="{ThemeResource SystemAccentColor}"
                                                                           VerticalAlignment="Top"
                                                                           Margin="0,0,6,0"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding Detail}"
                                                                           FontSize="11" Opacity="0.7"
                                                                           TextWrapping="Wrap"
                                                                           VerticalAlignment="Top"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                                        <!-- User bubble: always plain text -->
                                        <!-- 图片缩略图（气泡上方，可点击放大） -->
                                        <Border Visibility="{Binding HasImageVisibility}"
                                                HorizontalAlignment="{Binding Align}"
                                                Margin="12,0"
                                                Tag="{Binding}"
                                                Tapped="BubbleImage_Click"
                                                CornerRadius="4">
                                            <Border.RenderTransform>
                                                <TranslateTransform/>
                                            </Border.RenderTransform>
                                            <Image Source="{Binding ImageSource}"
                                                   Width="120" Height="120"
                                                   Stretch="UniformToFill"/>
                                        </Border>
                                        <Border Background="{Binding BackgroundColor}"
                                                Visibility="{Binding UserVisibility}"
                                                Margin="12,2,12,0"
                                                MaxWidth="580"
                                                HorizontalAlignment="{Binding Align}">
                                            <TextBlock Text="{Binding Content}"
                                                       FontSize="16"
                                                       Foreground="{Binding ForegroundColor}"
                                                       TextWrapping="Wrap"
                                                       Padding="10,8"/>
                                        </Border>

                                        <!-- AI bubble while streaming: plain TextBlock for smooth token updates -->
                                        <Border Background="{Binding BackgroundColor}"
                                                Visibility="{Binding AiStreamingVisibility}"
                                                Margin="12,0"
                                                MaxWidth="580"
                                                HorizontalAlignment="{Binding Align}">
                                            <TextBlock Text="{Binding Content}"
                                                       FontSize="16"
                                                       Foreground="{Binding ForegroundColor}"
                                                       TextWrapping="Wrap"
                                                       Padding="10,8"/>
                                        </Border>

                                        <!-- 搜索状态提示（tool use 进行中，有动画感） -->
                                        <Border Visibility="{Binding SearchStatusVisibility}"
                                                Margin="12,2,12,2"
                                                HorizontalAlignment="{Binding Align}"
                                                Padding="8,4" CornerRadius="4">
                                            <Border.Background>
                                                <SolidColorBrush Color="{ThemeResource SystemAccentColor}" Opacity="0.12"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding SearchStatusText}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource SystemAccentColor}"
                                                       TextWrapping="Wrap"/>
                                        </Border>

                                        <!-- AI bubble after stream: markdown-rendered RichTextBlock -->
                                        <Border Background="{Binding BackgroundColor}"
                                                Visibility="{Binding AiRenderedVisibility}"
                                                Margin="12,0"
                                                MaxWidth="580"
                                                HorizontalAlignment="{Binding Align}">
                                            <RichTextBlock local:MarkdownBlock.Text="{Binding Content}"
                                                           local:MarkdownBlock.QuoteColor="{Binding QuoteColor}"
                                                           local:MarkdownBlock.BracketColor="{Binding BracketColor}"
                                                           FontSize="16"
                                                           Foreground="{Binding ForegroundColor}"
                                                           TextWrapping="Wrap"
                                                           Padding="10,8"
                                                           IsTextSelectionEnabled="True"/>
                                        </Border>

                                        <!-- ── Action strip ───────────────────────────── -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="{Binding Align}"
                                                    Margin="12,1,12,2">

                                            <!-- Copy (all messages) -->
                                            <Button Tag="{Binding}" Click="CopyMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="复制">
                                                <FontIcon Glyph="&#xE8C8;" FontSize="13" Opacity="0.55"/>
                                            </Button>

                                            <!-- Edit (user messages only) -->
                                            <Button Visibility="{Binding EditBtnVisibility}"
                                                    Tag="{Binding}" Click="EditMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="编辑">
                                                <FontIcon Glyph="&#xE70F;" FontSize="13" Opacity="0.55"/>
                                            </Button>

                                            <!-- Delete this msg + all after -->
                                            <Button Tag="{Binding}" Click="DeleteMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="删除此消息及之后所有消息">
                                                <FontIcon Glyph="&#xE74D;" FontSize="13" Opacity="0.55"/>
                                            </Button>

                                            <!-- Regenerate (AI only, after streaming) -->
                                            <Button Visibility="{Binding RegenerateBtnVisibility}"
                                                    Tag="{Binding}" Click="RegenerateMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="重新生成">
                                                <FontIcon Glyph="&#xE72C;" FontSize="13" Opacity="0.55"/>
                                            </Button>

                                            <!-- Continue (AI only, after streaming) -->
                                            <Button Visibility="{Binding ContinueBtnVisibility}"
                                                    Tag="{Binding}" Click="ContinueMsg_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Width="30" Height="28" Padding="0"
                                                    ToolTipService.ToolTip="继续">
                                                <FontIcon Glyph="&#xE768;" FontSize="13" Opacity="0.55"/>
                                            </Button>

                                            <!-- Branch navigator: < 1/3 > (user msgs with branches) -->
                                            <StackPanel Visibility="{Binding BranchNavVisibility}"
                                                        Orientation="Horizontal">
                                                <Button Tag="{Binding}" Click="PrevBranch_Click"
                                                        Background="Transparent" BorderThickness="0"
                                                        Width="26" Height="28" Padding="0">
                                                    <FontIcon Glyph="&#xE76B;" FontSize="11" Opacity="0.7"/>
                                                </Button>
                                                <TextBlock Text="{Binding BranchLabel}"
                                                           FontSize="12" Opacity="0.6"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0"/>
                                                <Button Tag="{Binding}" Click="NextBranch_Click"
                                                        Background="Transparent" BorderThickness="0"
                                                        Width="26" Height="28" Padding="0">
                                                    <FontIcon Glyph="&#xE76C;" FontSize="11" Opacity="0.7"/>
                                                </Button>
                                            </StackPanel>

                                        </StackPanel>

                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                        <!-- 加载遮罩（声明在 ScrollViewer 之后，渲染在最上层） -->
                        <Border x:Name="LoadingOverlay"
                                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                                Visibility="Collapsed"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <ProgressBar x:Name="LoadingProgress"
                                             Minimum="0" Maximum="100" Value="0"
                                             Width="200" Height="4"
                                             Margin="0,0,0,12"/>
                                <TextBlock x:Name="LoadingText"
                                           Text="加载中…"
                                           FontSize="13" Opacity="0.5"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid><!-- /ChatArea -->

                    <!-- ── Input bar ───────────────────────────────────── -->
                    <Grid Grid.Row="3"
                          Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                          BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="0,1,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- 图片预览 -->
                            <RowDefinition Height="Auto"/>  <!-- 工具栏 -->
                            <RowDefinition Height="Auto"/>  <!-- 输入行 -->
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- 图片按钮 -->
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>  <!-- 发送 -->
                        </Grid.ColumnDefinitions>

                        <!-- 图片预览条（有图片时显示） -->
                        <Border x:Name="ImagePreviewBar"
                                Grid.Row="0" Grid.ColumnSpan="3"
                                Visibility="Collapsed"
                                Padding="10,6" BorderThickness="0,0,0,1"
                                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image x:Name="PendingImageThumb"
                                       Grid.Column="0"
                                       Width="48" Height="48"
                                       Stretch="UniformToFill"/>
                                <TextBlock Grid.Column="1"
                                           Text="已附加图片"
                                           FontSize="12" Opacity="0.6"
                                           VerticalAlignment="Center"
                                           Margin="10,0"/>
                                <Button Grid.Column="2"
                                        Click="ClearImageBtn_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Width="36" Height="36" Padding="0">
                                    <FontIcon Glyph="&#xE711;" FontSize="14" Opacity="0.6"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- 工具栏 -->
                        <Border Grid.Row="1" Grid.ColumnSpan="3"
                                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,1,0,0">
                            <Grid Height="36">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <!-- 全屏输入 -->
                                    <Button Click="FullscreenInputBtn_Click"
                                            Background="Transparent" BorderThickness="0"
                                            Width="40" Height="36" Padding="0"
                                            ToolTipService.ToolTip="全屏输入">
                                        <FontIcon x:Name="FullscreenInputIcon" Glyph="&#xE740;" FontSize="15" Opacity="0.6"
                                                  Foreground="{ThemeResource ApplicationForegroundThemeBrush}"/>
                                    </Button>
                                    <!-- Web 搜索（空壳） -->
                                    <Button x:Name="WebSearchBtn" Click="WebSearchBtn_Click"
                                            Background="Transparent" BorderThickness="0"
                                            Width="40" Height="36" Padding="0"
                                            ToolTipService.ToolTip="Web 搜索">
                                        <FontIcon x:Name="WebSearchIcon" Glyph="&#xE721;" FontSize="15" Opacity="0.6"
                                                  Foreground="{ThemeResource ApplicationForegroundThemeBrush}"/>
                                    </Button>
                                    <!-- Full Trust：跳过敏感操作权限确认 -->
                                    <Button x:Name="FullTrustBtn" Click="FullTrustBtn_Click"
                                            Background="Transparent" BorderThickness="0"
                                            Width="40" Height="36" Padding="0"
                                            ToolTipService.ToolTip="完全信任模式（跳过权限确认）">
                                        <FontIcon x:Name="FullTrustIcon" Glyph="&#xE72E;" FontSize="15" Opacity="0.6"
                                                  Foreground="{ThemeResource ApplicationForegroundThemeBrush}"/>
                                    </Button>
                                    <!-- 允许 AI 直接 Fetch 搜索页 -->
                                    <Button x:Name="FetchSearchBtn" Click="FetchSearchBtn_Click"
                                            Background="Transparent" BorderThickness="0"
                                            Width="40" Height="36" Padding="0"
                                            Visibility="Collapsed"
                                            ToolTipService.ToolTip="允许 AI 直接读取搜索页面">
                                        <FontIcon x:Name="FetchSearchIcon" Glyph="&#xE909;" FontSize="15" Opacity="0.6"
                                                  Foreground="{ThemeResource ApplicationForegroundThemeBrush}"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 图片附加按钮 -->
                        <Button x:Name="AttachImageBtn"
                                Grid.Row="2" Grid.Column="0"
                                Click="AttachImageBtn_Click"
                                Background="Transparent" BorderThickness="0"
                                Width="42" MinHeight="42"
                                Margin="4,6,0,6"
                                VerticalAlignment="Bottom">
                            <FontIcon x:Name="AttachImageIcon" Glyph="&#xEB9F;" FontSize="18" Opacity="0.6"
                                      Foreground="{ThemeResource ApplicationForegroundThemeBrush}"/>
                        </Button>

                        <TextBox x:Name="InputTextBox"
                                 Grid.Row="2" Grid.Column="1"
                                 PlaceholderText="说点什么…"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 TextWrapping="Wrap"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 MinHeight="42"
                                 MaxHeight="160"
                                 Margin="4,6,6,6"
                                 KeyDown="InputTextBox_KeyDown"/>

                        <Button x:Name="SubmitButton"
                                Grid.Row="2" Grid.Column="2"
                                Click="SubmitButton_Click"
                                Width="52"
                                MinHeight="42"
                                Margin="0,6,8,6"
                                VerticalAlignment="Bottom"
                                Background="{ThemeResource SystemAccentColor}"
                                Foreground="White"
                                BorderBrush="Transparent">
                            <FontIcon x:Name="SubmitIcon" Glyph="&#xE74A;" FontSize="18"/>
                        </Button>
                    </Grid>
                </Grid>
            </SplitView.Content>
        </SplitView>

        <MediaElement x:Name="ReplySound" AutoPlay="False" Visibility="Collapsed"/>
    </Grid>
</Page>
