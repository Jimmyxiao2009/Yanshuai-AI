<Page
    x:Class="yanshuai.OobeBasicPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="14,24,14,8">
            <TextBlock x:Name="PageTitle" Text="基础设置"
                       FontSize="32" FontWeight="Light"/>
            <TextBlock x:Name="PageSubtitle"
                       Text="你可以随时在设置页面更改这些选项。"
                       FontSize="13" Opacity="0.5" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="14,8,14,24">

                <!-- 深色模式 -->
                <Grid Margin="0,16,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="DarkModeLabel" Text="深色模式" FontSize="15"/>
                        <TextBlock x:Name="DarkModeDesc" Text="切换深色/浅色界面" FontSize="12" Opacity="0.5" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ToggleSwitch x:Name="DarkModeToggle" Grid.Column="1"
                                  Margin="0,0,-90,0"
                                  Toggled="DarkModeToggle_Toggled"/>
                </Grid>

                <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="0,0,0,1" Margin="0,0,0,0"/>

                <!-- 语言 -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="LangLabel" Text="语言 / Language" FontSize="15"/>
                        <TextBlock x:Name="LangDesc" Text="切换中文/英文界面" FontSize="12" Opacity="0.5" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ToggleSwitch x:Name="LangToggle" Grid.Column="1"
                                  OnContent="EN" OffContent="中"
                                  Margin="0,0,-90,0"
                                  Toggled="LangToggle_Toggled"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>

    <Page.BottomAppBar>
        <CommandBar>
            <AppBarButton x:Name="NextBtn" Icon="Forward" Label="下一步" Click="NextBtn_Click"/>
            <CommandBar.Content>
                <AppBarButton Icon="Back" Label="" Click="BackBtn_Click"/>
            </CommandBar.Content>
        </CommandBar>
    </Page.BottomAppBar>

</Page>
