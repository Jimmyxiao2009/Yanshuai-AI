<Page
    x:Class="yanshuai.OobePage2"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="14,16,14,8">
            <TextBlock x:Name="PageTitle" Text="API 配置" FontSize="32" FontWeight="Light"/>
            <TextBlock x:Name="PageStepHint" Text="步骤 3 / 3"
                       FontSize="12" Opacity="0.5" Margin="0,4,0,0"/>
            <ProgressBar Value="100" Maximum="100" Margin="0,10,0,0" Height="4"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="14,16,14,32">

                <TextBlock Text="言枢通过兼容 OpenAI 格式的 API 与 AI 对话。"
                           FontSize="15" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,8"/>
                <TextBlock Text="需要填写 API 地址、密钥和模型名称。"
                           FontSize="15" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,24"/>

                <TextBlock Text="配置名称" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="NameBox" PlaceholderText="例：DeepSeek / 我的 API"
                         FontSize="16" Padding="12,14" Margin="0,0,0,20"/>

                <TextBlock Text="API 地址" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="UrlBox"
                         PlaceholderText="https://api.deepseek.com/v1/chat/completions"
                         FontSize="15" Padding="12,14" TextWrapping="Wrap" Margin="0,0,0,8"/>
                <TextBlock FontSize="12" Opacity="0.45" TextWrapping="Wrap" Margin="0,0,0,20"
                           Text="OpenAI: api.openai.com/v1/chat/completions&#x0a;DeepSeek: api.deepseek.com/v1/chat/completions&#x0a;Groq: api.groq.com/openai/v1/chat/completions"/>

                <TextBlock Text="API Key" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <PasswordBox x:Name="KeyBox" PlaceholderText="sk-…"
                             FontSize="16" Padding="12,14" Margin="0,0,0,20"/>

                <TextBlock Text="模型" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="ModelBox" PlaceholderText="例：deepseek-chat / gpt-4o"
                         FontSize="16" Padding="12,14" Margin="0,0,0,8"/>

                <TextBlock x:Name="ErrorText" Text="" Foreground="Red"
                           FontSize="13" Margin="0,8,0,0" TextWrapping="Wrap"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>

    <Page.BottomAppBar>
        <CommandBar>
            <AppBarButton x:Name="NextBtn" Icon="Accept" Label="保存" Click="NextBtn_Click"/>
            <CommandBar.Content>
                <AppBarButton Icon="Back" Label="" Click="BackButton_Click"/>
            </CommandBar.Content>
        </CommandBar>
    </Page.BottomAppBar>
</Page>
