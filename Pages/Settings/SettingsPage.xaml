<Page x:Class="yanshuai.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <StackPanel Margin="14,16,14,20">
                    <TextBlock x:Name="PageTitle" Text="设置"
                               FontSize="32" FontWeight="Light"/>
                </StackPanel>

                <!-- ══ 显示 section ════════════════════════════════════ -->
                <Grid Margin="14,0,14,10" Tapped="DisplaySection_Tapped">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="DisplaySectionTitle"
                                   Text="显示"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemAccentColor}"
                                   CharacterSpacing="80"/>
                        <Border BorderBrush="{ThemeResource SystemAccentColor}"
                                BorderThickness="0,0,0,1" Margin="0,3,0,0"
                                Opacity="0.4"/>
                    </StackPanel>
                    <FontIcon x:Name="DisplaySectionIcon" Grid.Column="1"
                              Glyph="&#xE76C;" FontSize="11"
                              Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <StackPanel x:Name="DisplaySection">
                    <Grid Margin="14,0,14,0"
                          BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="0,0,0,1"
                          Padding="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="DarkModeLabel" Text="深色模式" FontSize="15"/>
                            <TextBlock x:Name="DarkModeDesc" Text="切换深色/浅色主题"
                                       FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="DarkModeToggle" Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Toggled="DarkModeToggle_Toggled"
                                      Margin="0,0,-90,0"/>
                    </Grid>

                    <Grid Margin="14,0,14,0"
                          BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="0,0,0,1"
                          Padding="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="LangLabel" Text="Language / 语言" FontSize="15"/>
                            <TextBlock x:Name="LangDesc" Text="切换中文 / Switch to English"
                                       FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="LangToggle" Grid.Column="1"
                                      VerticalAlignment="Center"
                                      OnContent="EN" OffContent="中"
                                      Toggled="LangToggle_Toggled"
                                      Margin="0,0,-90,0"/>
                    </Grid>

                    <Grid Margin="14,0,14,0"
                          BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="0,0,0,1"
                          Padding="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="回复声音" FontSize="15"/>
                            <TextBlock Text="AI 回复完成时播放提示音"
                                       FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="ReplySoundToggle" Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Toggled="ReplySoundToggle_Toggled"
                                      Margin="0,0,-90,0"/>
                    </Grid>

                    <Grid Margin="14,0,14,0"
                          BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="0,0,0,1"
                          Padding="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="默认展开思考过程" FontSize="15"/>
                            <TextBlock Text="AI 回复完成后自动展开思维链"
                                       FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="ReasoningExpandedToggle" Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Toggled="ReasoningExpandedToggle_Toggled"
                                      Margin="0,0,-90,0"/>
                    </Grid>

                    <!-- 默认对话外观 -->
                    <Grid Margin="14,0,14,20"
                          Padding="0,10"
                          Tapped="DefaultAppearanceBtn_Tapped">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="DefaultAppearanceLabel" Text="默认对话外观" FontSize="15"/>
                            <TextBlock x:Name="DefaultAppearanceDesc" Text="自定义气泡颜色和背景"
                                       FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                        </StackPanel>
                        <FontIcon Grid.Column="1" Glyph="&#xE76C;" FontSize="13"
                                  Opacity="0.5" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- ══ 输入行为 section ══════════════════════════════ -->
                <Grid Margin="14,0,14,10" Tapped="InputSection_Tapped">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="输入行为"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemAccentColor}"
                                   CharacterSpacing="80"/>
                        <Border BorderBrush="{ThemeResource SystemAccentColor}"
                                BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                    </StackPanel>
                    <FontIcon x:Name="InputSectionIcon" Grid.Column="1"
                              Glyph="&#xE76C;" FontSize="11"
                              Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <StackPanel x:Name="InputSection">
                    <TextBlock Text="Enter 键行为"
                               FontSize="12" Opacity="0.5" Margin="14,0,14,8"/>
                    <ComboBox x:Name="EnterBehaviorPicker"
                              HorizontalAlignment="Stretch"
                              Margin="14,0,14,24"
                              SelectionChanged="EnterBehaviorPicker_SelectionChanged">
                        <ComboBoxItem Content="Enter 发送，Shift+Enter 换行"/>
                        <ComboBoxItem Content="Enter 换行，Ctrl+Enter 发送"/>
                    </ComboBox>
                </StackPanel>

                <!-- ══ 启动行为 section ══════════════════════════════ -->
                <Grid Margin="14,0,14,10" Tapped="StartupSection_Tapped">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="启动行为"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemAccentColor}"
                                   CharacterSpacing="80"/>
                        <Border BorderBrush="{ThemeResource SystemAccentColor}"
                                BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                    </StackPanel>
                    <FontIcon x:Name="StartupSectionIcon" Grid.Column="1"
                              Glyph="&#xE76C;" FontSize="11"
                              Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <StackPanel x:Name="StartupSection">
                    <TextBlock Text="启动应用时自动进入"
                               FontSize="12" Opacity="0.5" Margin="14,0,14,8"/>
                    <ComboBox x:Name="StartupBehaviorPicker"
                              HorizontalAlignment="Stretch"
                              Margin="14,0,14,6"
                              SelectionChanged="StartupBehaviorPicker_SelectionChanged">
                        <ComboBoxItem Content="最近的对话"/>
                        <ComboBoxItem Content="新对话"/>
                        <ComboBoxItem Content="对话列表"/>
                    </ComboBox>
                    <TextBlock x:Name="StartupRestartHint"
                               Text="✓ 返回主界面后即生效"
                               FontSize="12"
                               Foreground="{ThemeResource SystemAccentColor}"
                               Margin="14,0,14,24"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- ══ Web 搜索 section ══════════════════════════════════ -->
                <Grid Margin="14,0,14,10" Tapped="SearchSection_Tapped">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Web 搜索"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemAccentColor}"
                                   CharacterSpacing="80"/>
                        <Border BorderBrush="{ThemeResource SystemAccentColor}"
                                BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                    </StackPanel>
                    <FontIcon x:Name="SearchSectionIcon" Grid.Column="1"
                              Glyph="&#xE76C;" FontSize="11"
                              Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <StackPanel x:Name="SearchSection">
                    <Button Content="管理搜索 API 池"
                            HorizontalAlignment="Stretch"
                            Margin="14,0,14,8"
                            Padding="14,10"
                            Click="SearchSettingsBtn_Click"/>
                    <TextBlock Text="配置 SearXNG 实例、DuckDuckGo、Bing API 等搜索提供商"
                               FontSize="12" Opacity="0.45" Margin="14,0,14,16" TextWrapping="Wrap"/>

                    <TextBlock Text="Fetch 请求 User-Agent"
                               FontSize="12" Opacity="0.5" Margin="14,0,14,6"/>
                    <ComboBox x:Name="FetchUAPicker"
                              HorizontalAlignment="Stretch"
                              Margin="14,0,14,6"
                              SelectionChanged="FetchUAPicker_SelectionChanged">
                        <ComboBoxItem Content="WM10 IE Mobile (Lumia 950)"/>
                        <ComboBoxItem Content="Chrome (Windows)"/>
                        <ComboBoxItem Content="Edge (Windows)"/>
                        <ComboBoxItem Content="Safari (macOS)"/>
                        <ComboBoxItem Content="Firefox (Windows)"/>
                        <ComboBoxItem Content="自定义…"/>
                    </ComboBox>
                    <TextBox x:Name="FetchUACustomBox"
                             PlaceholderText="输入自定义 User-Agent 字符串"
                             Margin="14,0,14,4"
                             Visibility="Collapsed"
                             TextChanged="FetchUACustomBox_TextChanged"/>
                    <TextBlock x:Name="FetchUAPreview"
                               FontSize="11" Opacity="0.4"
                               Margin="14,0,14,20"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- ══ RAG 记忆 section ══════════════════════════════════ -->
                <Grid Margin="14,0,14,10" Tapped="RagSection_Tapped">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="RAG 记忆"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemAccentColor}"
                                   CharacterSpacing="80"/>
                        <Border BorderBrush="{ThemeResource SystemAccentColor}"
                                BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                    </StackPanel>
                    <FontIcon x:Name="RagSectionIcon" Grid.Column="1"
                              Glyph="&#xE76C;" FontSize="11"
                              Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <StackPanel x:Name="RagSection">
                    <!-- 启用离线 RAG -->
                    <Grid Margin="14,0,14,0"
                          BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="0,0,0,1" Padding="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="启用离线嵌入引擎" FontSize="15"/>
                            <TextBlock x:Name="RagModelStatus" Text="模型: 未加载"
                                       FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="RagEnabledToggle" Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Toggled="RagEnabledToggle_Toggled"
                                      Margin="0,0,-90,0"/>
                    </Grid>

                    <!-- Top-K -->
                    <Grid Margin="14,0,14,0"
                          BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="0,0,0,1" Padding="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="检索数量 (Top-K)" FontSize="15"/>
                            <TextBlock x:Name="RagTopKLabel" Text="5 条"
                                       FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Slider x:Name="RagTopKSlider" Grid.Column="1"
                                Minimum="1" Maximum="20" StepFrequency="1"
                                Width="120" VerticalAlignment="Center"
                                ValueChanged="RagTopKSlider_ValueChanged"
                                Margin="0,0,-60,0"/>
                    </Grid>

                    <!-- 相似度阈值 -->
                    <Grid Margin="14,0,14,0"
                          BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="0,0,0,1" Padding="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="相似度阈值" FontSize="15"/>
                            <TextBlock x:Name="RagThreshLabel" Text="0.30"
                                       FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Slider x:Name="RagThreshSlider" Grid.Column="1"
                                Minimum="0.0" Maximum="1.0" StepFrequency="0.05"
                                Width="120" VerticalAlignment="Center"
                                ValueChanged="RagThreshSlider_ValueChanged"
                                Margin="0,0,-60,0"/>
                    </Grid>

                    <!-- 模型状态 -->
                    <Grid Margin="14,0,14,20" Padding="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="嵌入模型" FontSize="15"/>
                            <TextBlock x:Name="RagModelDetail" Text="bge-small-zh-v1.5 (512维)"
                                       FontSize="12" Opacity="0.55" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Content="重新加载" Grid.Column="1"
                                Click="RagReloadModelBtn_Click"
                                Padding="12,6" FontSize="13"
                                VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- ══ 数据备份 section ══════════════════════════════════ -->
                <Grid Margin="14,0,14,10" Tapped="BackupSection_Tapped">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="数据备份"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemAccentColor}"
                                   CharacterSpacing="80"/>
                        <Border BorderBrush="{ThemeResource SystemAccentColor}"
                                BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                    </StackPanel>
                    <FontIcon x:Name="BackupSectionIcon" Grid.Column="1"
                              Glyph="&#xE76C;" FontSize="11"
                              Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <StackPanel x:Name="BackupSection">
                    <TextBlock Text="将所有对话、角色卡、世界书、API配置打包导出或从备份恢复"
                               FontSize="12" Opacity="0.5" Margin="14,0,14,10" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="14,0,14,8">
                        <Button Content="导出备份(.zip)" Click="ExportZip_Click"
                                Padding="14,8" Margin="0,0,10,0"/>
                        <Button Content="从备份恢复" Click="ImportZip_Click"
                                Padding="14,8"/>
                    </StackPanel>
                    <TextBlock x:Name="BackupStatus" Text="" FontSize="12" Opacity="0.6"
                               Margin="14,4,14,24" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- ══ 引导 section ════════════════════════════════════ -->
                <Grid Margin="14,0,14,10" Tapped="OobeSection_Tapped">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="引导向导"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemAccentColor}"
                                   CharacterSpacing="80"/>
                        <Border BorderBrush="{ThemeResource SystemAccentColor}"
                                BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                    </StackPanel>
                    <FontIcon x:Name="OobeSectionIcon" Grid.Column="1"
                              Glyph="&#xE76C;" FontSize="11"
                              Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <StackPanel x:Name="OobeSection">
                    <Button Content="重新进入初始引导向导"
                            Click="ReEnterOobeBtn_Click"
                            HorizontalAlignment="Left"
                            Margin="14,0,0,24" Padding="16,10"/>
                </StackPanel>

                <!-- ══ API 日志 section ════════════════════════════════════ -->
                <Grid Margin="14,0,14,10">
                    <StackPanel>
                        <TextBlock Text="调试"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemAccentColor}"
                                   CharacterSpacing="80"/>
                        <Border BorderBrush="{ThemeResource SystemAccentColor}"
                                BorderThickness="0,0,0,1" Margin="0,3,0,0" Opacity="0.4"/>
                    </StackPanel>
                </Grid>
                <StackPanel Margin="0,0,0,8">
                    <Button Content="查看 API 日志"
                            Click="ApiLogBtn_Click"
                            HorizontalAlignment="Left"
                            Margin="14,0,0,16" Padding="16,10"/>
                </StackPanel>

                <!-- ══ 关于 section ════════════════════════════════════ -->
                <Grid Margin="14,0,14,10" Tapped="AboutSection_Tapped">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="CreditsSectionTitle"
                                   Text="关于"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemAccentColor}"
                                   CharacterSpacing="80"/>
                        <Border BorderBrush="{ThemeResource SystemAccentColor}"
                                BorderThickness="0,0,0,1" Margin="0,3,0,0"
                                Opacity="0.4"/>
                    </StackPanel>
                    <FontIcon x:Name="AboutSectionIcon" Grid.Column="1"
                              Glyph="&#xE76C;" FontSize="11"
                              Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <StackPanel x:Name="AboutSection">
                    <StackPanel Margin="14,0,14,16">
                        <TextBlock Text="言枢"
                                   FontSize="22" FontWeight="Light" Margin="0,0,0,2"/>
                        <TextBlock x:Name="OrigDevLabel"
                                   Text="AI 对话助手 · 适配 Windows 10 Mobile"
                                   FontSize="12" Opacity="0.55"/>
                    </StackPanel>

                    <Button x:Name="AboutBtn" Content="关于言枢 AI"
                            Click="OpenWebsiteButton_Click"
                            HorizontalAlignment="Left"
                            Margin="14,0,0,32"
                            Padding="16,8"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>

    <Page.BottomAppBar>
        <CommandBar>
            <CommandBar.Content>
                <AppBarButton Icon="Back" Label="" Click="BackButton_Click"/>
            </CommandBar.Content>
        </CommandBar>
    </Page.BottomAppBar>
</Page>
